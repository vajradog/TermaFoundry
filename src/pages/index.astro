---
import SiteLayout from '@layouts/SiteLayout.astro';
---

<SiteLayout
  title="Free Tibetan Typography Tools | CSS Framework, Fonts & Pecha"
  description="Free open-source tools for Tibetan text on the web. termaUI CSS framework, 36 curated fonts, PechaForge manuscript creator, and Tibetan typing practice. No account needed."
  ogType="website"
  schema={{
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "https://termafoundry.com/#organization",
        "name": "Terma Type Foundry",
        "url": "https://termafoundry.com",
        "sameAs": "https://github.com/vajradog/TermaFoundry",
        "description": "Open-source studio designing and building digital tools for Tibetan script on the modern web.",
        "email": "termastudios@gmail.com",
        "founder": { "@type": "Person", "name": "Thupten Chakrishar" },
        "knowsAbout": ["Tibetan typography", "termaUI CSS framework", "Tibetan fonts", "Pecha manuscript", "Unicode Tibetan"]
      },
      {
        "@type": "WebSite",
        "@id": "https://termafoundry.com/#website",
        "url": "https://termafoundry.com",
        "name": "Terma Foundry",
        "description": "Free open-source tools for Tibetan script on the modern web",
        "publisher": { "@id": "https://termafoundry.com/#organization" }
      }
    ]
  }}
>

  <!-- HERO -->
  <section class="hub-hero">
    <div class="hub-hero-glow" aria-hidden="true"></div>
    <div class="hub-hero-content">
      <div class="hub-hero-eyebrow reveal">Open tools for Tibetan text</div>
      <div class="hero-display-zone reveal reveal-delay-1">
        <h1 class="hub-hero-heading" id="hero-phase-en">
          Ensuring Tibetan Script<br>Thrives in the
          <span class="hero-tibetan-word">Modern World.</span>
        </h1>
        <div class="hero-phase-tib tr-guard" lang="bo" id="hero-phase-tib" aria-hidden="true">
          <span id="hero-tib-text" class="tr-leading-normal tr-guard-lg tr-ligatures"></span>
        </div>
      </div>

      <p class="hub-hero-sub reveal reveal-delay-2">
        We design and build the tools Tibetan script needs in the digital world — an original CSS framework, typefaces we create with master calligraphers, layout systems, and learning utilities. Everything made from the ground up.
      </p>
      <div class="hub-hero-actions reveal reveal-delay-3">
        <a href="/ocr" class="btn btn-primary">Try TermaOCR</a>
        <a href="/termaui/" class="btn btn-outline">Explore termaUI</a>
      </div>
    </div>
  </section>

  <!-- TOOLS -->
  <section class="page-section">
    <div class="section-eyebrow reveal">Our Tools</div>
    <h2 class="section-heading reveal">Everything Tibetan needs<br>on the modern web.</h2>
    <p class="section-sub reveal">Six tools built on the same mission — making Tibetan script thrive in digital spaces.</p>

    <div class="cards-grid cards-grid-2 reveal">
      <!-- termaUI -->
      <a href="/termaui/" class="tool-card tool-card-featured">
        <div class="tool-card-badge">Available Now</div>
        <div class="tool-card-icon">◈</div>
        <h3 class="tool-card-title">termaUI</h3>
        <p class="tool-card-desc">The world's first utility-first CSS framework for Tibetan language rendering. Guards, fonts, effects, pecha layouts — in one stylesheet.</p>
        <div class="tool-card-link">Explore termaUI →</div>
      </a>

      <!-- TermaOCR -->
      <a href="/ocr" class="tool-card tool-card-featured">
        <div class="tool-card-badge">Beta</div>
        <div class="tool-card-icon">⊡</div>
        <h3 class="tool-card-title">TermaOCR</h3>
        <p class="tool-card-desc">Upload an image or PDF of Tibetan text, draw selection boxes around text areas, and get accurate Unicode output instantly. Supports batch processing with reusable templates.</p>
        <div class="tool-card-link">Try TermaOCR →</div>
      </a>

      <!-- TermaType -->
      <a href="/type" class="tool-card tool-card-featured">
        <div class="tool-card-badge">Beta</div>
        <div class="tool-card-icon">⌨</div>
        <h3 class="tool-card-title">TermaType</h3>
        <p class="tool-card-desc">A Tibetan word processor with built-in Monlam IME, live dictionary, rich formatting, and multi-format export. Works entirely in your browser.</p>
        <div class="tool-card-link">Open TermaType →</div>
      </a>

      <!-- PechaForge -->
      <a href="/pecha" class="tool-card tool-card-featured">
        <div class="tool-card-badge">Beta</div>
        <div class="tool-card-icon">༺</div>
        <h3 class="tool-card-title">PechaForge</h3>
        <p class="tool-card-desc">Create traditional Tibetan pecha manuscripts in the browser. Yig mgo, Tibetan folios, four themes, duplex printing, and PDF export. The first web-based pecha maker.</p>
        <div class="tool-card-link">Open PechaForge →</div>
      </a>

      <!-- TermaDictionary -->
      <a href="/dictionary" class="tool-card tool-card-featured">
        <div class="tool-card-badge">Beta</div>
        <div class="tool-card-icon" lang="bo" style="font-family:'Noto Serif Tibetan','Jomolhari',serif;font-size:0.75em;line-height:1.8">ཚིག་མཛོད།</div>
        <h3 class="tool-card-title">TermaDictionary</h3>
        <p class="tool-card-desc">The world's largest free Tibetan dictionary — 1.2+ million entries across 64 authoritative sources. Search by Tibetan script, Wylie, or English instantly.</p>
        <div class="tool-card-link">Open TermaDictionary →</div>
      </a>

      <!-- TermaFonts -->
      <a href="/fonts/library" class="tool-card tool-card-featured">
        <div class="tool-card-badge">Available Now</div>
        <div class="tool-card-icon">Ꭿ</div>
        <h3 class="tool-card-title">TermaFonts</h3>
        <p class="tool-card-desc">A curated library of 36 Tibetan web fonts — Uchen, Umed, cursive, and display styles — ready to embed in any website or app via CDN.</p>
        <div class="tool-card-link">Browse TermaFonts →</div>
      </a>
    </div>
  </section>

  <hr class="divider" style="max-width:1100px; margin: 0 auto;">

  <!-- TERMAUI PREVIEW -->
  <section class="page-section">
    <div class="section-eyebrow reveal">termaUI in Action</div>
    <h2 class="section-heading reveal">One class. Beautiful Tibetan.</h2>
    <p class="section-sub reveal">This entire website is built using termaUI — proving it's production-ready for real Tibetan digital projects.</p>

    <div class="termaui-preview reveal">
      <div class="preview-col preview-demo">
        <div class="preview-text-stack">
          <div class="preview-item">
            <span class="preview-cls">.tr-jomolhari</span>
            <span class="tr-jomolhari tr-text-xl tr-guard" lang="bo">བཀྲ་ཤིས་བདེ་ལེགས།</span>
          </div>
          <div class="preview-item">
            <span class="preview-cls">.tr-text-rainbow</span>
            <span class="tr-jomolhari tr-text-rainbow tr-text-xl tr-guard" lang="bo">བཀྲ་ཤིས་བདེ་ལེགས།</span>
          </div>
          <div class="preview-item">
            <span class="preview-cls">.tr-text-saffron</span>
            <span class="tr-jomolhari tr-text-saffron tr-text-xl tr-guard" lang="bo">བཀྲ་ཤིས་བདེ་ལེགས།</span>
          </div>
          <div class="preview-item">
            <span class="preview-cls">.tr-glow-aurora</span>
            <span class="tr-jomolhari tr-glow-aurora tr-text-xl tr-guard" lang="bo" style="color:#2dd4bf;">བཀྲ་ཤིས་བདེ་ལེགས།</span>
          </div>
          <div class="preview-item">
            <span class="preview-cls">.tr-noto</span>
            <span class="tr-noto tr-text-xl tr-guard" lang="bo">བཀྲ་ཤིས་བདེ་ལེགས།</span>
          </div>
        </div>
      </div>
      <div class="preview-col preview-cta">
        <h3>Built for Tibetan.<br>Works like any CSS framework.</h3>
        <p>Prefix-based utility classes (<code>.tr-*</code>) that compose cleanly with any stack. Self-hosted fonts. No external dependencies.</p>
        <a href="/termaui/" class="btn btn-primary" style="margin-top:1.5rem;">See All Classes</a>
        <a href="/termaui/docs/" class="btn btn-ghost" style="margin-top:.75rem;">Read the Docs</a>
      </div>
    </div>
  </section>

  <hr class="divider" style="max-width:1100px; margin: 0 auto;">

  <!-- MISSION / FONTS IN DEVELOPMENT -->
  <section class="page-section">
    <div class="section-eyebrow reveal">Original Fonts</div>
    <h2 class="section-heading reveal">Three fonts we're building<br>from scratch.</h2>
    <p class="section-sub reveal">Working with master calligrapher Jamyang Dorjee, we're creating fonts that don't exist anywhere in the world yet.</p>

    <div class="cards-grid cards-grid-3 reveal">
      <div class="card">
        <div class="card-eyebrow">In Development</div>
        <div class="font-preview-glyph tr-jomolhari" lang="bo">ཀ</div>
        <div class="card-title">Terma Serif</div>
        <div class="card-desc">Elegant, culturally authentic. Designed for print, long-form reading, and formal publications.</div>
      </div>
      <div class="card">
        <div class="card-eyebrow">In Development</div>
        <div class="font-preview-glyph tr-noto" lang="bo">ཀ</div>
        <div class="card-title">Terma Sans-Serif</div>
        <div class="card-desc">Clean, screen-optimized. Built for digital interfaces, apps, and modern multilingual documents.</div>
      </div>
      <div class="card">
        <div class="card-eyebrow">In Development</div>
        <div class="font-preview-glyph tr-noto" lang="bo" style="color:#fbbf24;">ཀ</div>
        <div class="card-title">Terma Child-Friendly</div>
        <div class="card-desc">Simplified, approachable letterforms for young learners and semi-literate readers in the diaspora.</div>
      </div>
    </div>


  </section>

  <hr class="divider" style="max-width:1100px; margin: 0 auto;">

  <!-- WHY IT MATTERS -->
  <section class="page-section">
    <div class="section-eyebrow reveal">Why It Matters</div>
    <h2 class="section-heading reveal">Tibetan as a first-class<br>citizen of the internet.</h2>

    <div class="cards-grid cards-grid-2 reveal">
      <div class="card">
        <div class="why-icon">◈</div>
        <div class="card-title">Style Tibetan the Web Way</div>
        <div class="card-desc">Every web project that displays Tibetan text re-solves the same bugs from scratch — clipped vowels, broken line wrapping, no standard font API. termaUI fixes all of it in one stylesheet, so developers and designers can build instead of patch.</div>
      </div>
      <div class="card">
        <div class="why-icon">⊡</div>
        <div class="card-title">Digitize the Canon</div>
        <div class="card-desc">Centuries of Tibetan scholarship exist only as ink on paper. TermaOCR converts scanned pecha pages, manuscripts, and books into searchable Unicode text — making the written tradition accessible to everyone, instantly.</div>
      </div>
      <div class="card">
        <div class="why-icon">⌨</div>
        <div class="card-title">Write in Tibetan, Anywhere</div>
        <div class="card-desc">Most people who want to write Tibetan hit the same wall: no keyboard, no font, wrong software. TermaType removes every barrier — built-in IME, live dictionary, rich formatting, and export — all in a browser tab.</div>
      </div>
      <div class="card">
        <div class="why-icon">༺</div>
        <div class="card-title">Keep Pecha Alive</div>
        <div class="card-desc">The traditional three-column pecha format carries fifteen centuries of Tibetan literary culture. PechaForge is the first tool that lets anyone create, format, and print authentic pecha manuscripts — no monastery printing press required.</div>
      </div>
    </div>
  </section>

</SiteLayout>

<style>
  /* ── HERO ── */
  .hub-hero {
    position: relative; overflow: hidden;
    padding: 10rem 2rem 8rem;
    text-align: center;
    max-width: 1100px; margin: 0 auto;
  }
  .hub-hero-glow {
    position: absolute; top: -200px; left: 50%; transform: translateX(-50%);
    width: 900px; height: 600px; pointer-events: none;
    background: radial-gradient(ellipse 65% 50%, rgba(56,189,248,0.1) 0%, rgba(139,92,246,0.05) 50%, transparent 80%);
  }
  .hub-hero-content { position: relative; z-index: 2; max-width: 700px; margin: 0 auto; }
  .hub-hero-eyebrow {
    font-size: .75rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: .12em; color: var(--accent); margin-bottom: 1.25rem;
  }
  /* ── Two-phase hero display zone (English ↔ Tibetan cycling) ── */
  .hero-display-zone {
    display: grid;
    margin-bottom: 1.5rem;
  }
  .hub-hero-heading {
    grid-area: 1/1;
    font-size: clamp(2rem, 4.5vw, 3.25rem); font-weight: 900;
    letter-spacing: -.04em; line-height: 1.08; color: var(--text);
    margin-bottom: 0;
    transition: opacity 0.45s ease;
  }
  /* Accent colour on "Tibetan." in the English phase */
  .hero-tibetan-word { color: var(--accent); }

  /* Tibetan overlay — its own spacing context, no h1 inheritance */
  .hero-phase-tib {
    grid-area: 1/1;
    display: flex; align-items: center; justify-content: center;
    opacity: 0; pointer-events: none;
    transition: opacity 0.45s ease;
    padding-block: 0.25em;
  }
  #hero-tib-text {
    display: block;
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    text-align: center;
  }

  .hub-hero-sub {
    font-size: 1.1rem; color: var(--text2); line-height: 1.8;
    margin-bottom: 2.5rem; max-width: 560px; margin-left: auto; margin-right: auto;
  }
  .hub-hero-actions { display: flex; gap: .75rem; justify-content: center; flex-wrap: wrap; }

  /* ── TOOL CARDS ── */
  .tool-card {
    display: block; background: var(--surface);
    padding: 2.25rem 2rem; position: relative;
    transition: background .25s; text-decoration: none;
  }
  .tool-card:hover { background: var(--surface2); }
  .tool-card-featured { border-top: 2px solid var(--accent); }
  .tool-card-soon { border-top: 2px solid rgba(148,163,184,0.15); }
  .tool-card-badges {
    display: flex; flex-wrap: wrap; gap: .4rem; margin-bottom: 1.25rem;
  }
  .tool-card-badge {
    display: inline-block; font-size: .65rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: .08em; padding: .2rem .6rem; border-radius: 3px;
    background: rgba(56,189,248,0.12); color: var(--accent);
    border: 1px solid rgba(56,189,248,0.2); margin-bottom: 1.25rem;
  }
  .tool-card-badges .tool-card-badge { margin-bottom: 0; }
  .tool-card-badge-funding {
    background: rgba(251,191,36,0.12); color: #fbbf24;
    border-color: rgba(251,191,36,0.25);
  }
  .tool-card-badge-soon {
    background: rgba(148,163,184,0.08); color: var(--muted);
    border-color: rgba(148,163,184,0.15);
  }
  .tool-card-icon { font-size: 1.75rem; margin-bottom: .75rem; line-height: 1; }
  .tool-card-title { font-size: 1.2rem; font-weight: 700; color: var(--text); margin-bottom: .5rem; }
  .tool-card-desc { font-size: .85rem; color: var(--muted); line-height: 1.65; margin-bottom: 1.25rem; }
  .tool-card-link { font-size: .82rem; font-weight: 600; color: var(--accent); }

  /* ── termaUI preview ── */
  .termaui-preview {
    display: grid; grid-template-columns: 1.1fr 1fr; gap: 1px;
    background: var(--border); border: 1px solid var(--border);
    border-radius: 16px; overflow: hidden;
  }
  .preview-col { background: var(--surface); padding: 2.5rem; }
  .preview-text-stack { display: flex; flex-direction: column; gap: 1.5rem; }
  .preview-item { display: flex; flex-direction: column; gap: .35rem; }
  .preview-cls {
    font-family: 'JetBrains Mono', monospace; font-size: .68rem;
    color: var(--muted); letter-spacing: .03em;
  }
  .preview-cta { display: flex; flex-direction: column; justify-content: center; }
  .preview-cta h3 { font-size: 1.4rem; font-weight: 700; color: var(--text); line-height: 1.35; margin-bottom: 1rem; }
  .preview-cta p { font-size: .88rem; color: var(--muted); line-height: 1.7; }
  .preview-cta code {
    font-family: 'JetBrains Mono', monospace; font-size: .82em;
    color: var(--accent); background: rgba(56,189,248,0.08);
    padding: .1em .35em; border-radius: 3px;
  }

  /* ── Font preview glyphs ── */
  .font-preview-glyph {
    font-size: 3.5rem; color: var(--text2); margin-bottom: .75rem; display: block;
    padding-block: .25em;
  }

  /* ── Mission CTA ── */
  .mission-cta { display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; }
  .mission-cta p { font-size: .92rem; color: var(--muted); max-width: 380px; }

  /* ── Why icon ── */
  .why-icon { font-size: 1.6rem; margin-bottom: .9rem; }

  @media (max-width: 900px) {
    .termaui-preview { grid-template-columns: 1fr; }
    .hub-hero { padding: 7rem 1.5rem 5rem; }
    .mission-cta { flex-direction: column; align-items: flex-start; }
  }
</style>

<script is:inline>
(function () {
  var phaseEn  = document.getElementById('hero-phase-en');
  var phaseTib = document.getElementById('hero-phase-tib');
  var tibText  = document.getElementById('hero-tib-text');
  if (!phaseEn || !phaseTib || !tibText) return;

  var FADE = 450; // ms — match CSS transition duration

  // 4-phase cycle: English heading, then 3 Tibetan phrases
  // Each Tibetan phase has its own font class, effect class, and display duration
  var phases = [
    {
      type: 'en',
      duration: 5500
    },
    {
      type: 'tib',
      html: 'བོད་ཡིག་ནི་བོད་ཀྱི་བླ་སྲོག་ཡིན།',
      font: 'tr-drutsa',
      effect: 'tr-text-rainbow',
      color: '',
      duration: 4400
    },
    {
      type: 'tib',
      html: 'བོད་ཡིག་སྦྱོང་བ་ནི་སེམས་ཉིད་སྦྱོང་བ་ཡིན།',
      font: 'tr-jomolhari',
      effect: 'tr-text-fire',
      color: '',
      duration: 4400
    },
    {
      type: 'tib',
      html: 'གངས་ཅན་བོད་ཀྱི་ཡི་གེ་འདི། །<br>བོད་ཀྱི་རིག་གནས་ཀུན་གྱི་གཞི། །',
      font: 'tr-riwoche',
      effect: '',
      color: 'var(--text)',
      duration: 5000
    }
  ];

  // All possible font/effect classes — for cleanup before each Tibetan phase
  var tibFonts   = ['tr-drutsa', 'tr-jomolhari', 'tr-riwoche'];
  var tibEffects = ['tr-text-rainbow', 'tr-text-fire', 'tr-text-saffron', 'tr-glow-aurora', 'tr-outline-gold'];

  var idx  = 0;
  var busy = false;

  function applyPhase(p) {
    if (p.type === 'en') {
      // Restore English heading
      phaseEn.style.opacity      = '1';
      phaseEn.style.pointerEvents = '';
      phaseTib.style.opacity     = '0';
      phaseTib.style.pointerEvents = 'none';
      phaseTib.setAttribute('aria-hidden', 'true');
    } else {
      // Strip previous Tibetan classes, set new content
      tibFonts.forEach(function(c)   { tibText.classList.remove(c); });
      tibEffects.forEach(function(c) { tibText.classList.remove(c); });
      tibText.style.color = '';
      tibText.innerHTML = p.html;
      tibText.classList.add(p.font);
      if (p.effect) tibText.classList.add(p.effect);
      if (p.color) tibText.style.color = p.color;
      // Show Tibetan overlay, hide English
      phaseEn.style.opacity      = '0';
      phaseEn.style.pointerEvents = 'none';
      phaseTib.style.opacity     = '1';
      phaseTib.style.pointerEvents = '';
      phaseTib.removeAttribute('aria-hidden');
    }
  }

  function advance() {
    if (busy) return;
    busy = true;

    // Fade out the currently visible element
    var cur = phases[idx];
    if (cur.type === 'en') { phaseEn.style.opacity  = '0'; }
    else                   { phaseTib.style.opacity = '0'; }

    // Wait for fade, then switch to next phase and schedule the one after
    setTimeout(function () {
      idx = (idx + 1) % phases.length;
      applyPhase(phases[idx]);
      busy = false;
      setTimeout(advance, phases[idx].duration);
    }, FADE + 20);
  }

  // Initialise: English fully visible, Tibetan hidden
  phaseEn.style.opacity       = '1';
  phaseTib.style.opacity      = '0';
  phaseTib.style.pointerEvents = 'none';

  // Kick off the first transition after the English phase duration
  setTimeout(advance, phases[0].duration);
})();
</script>
