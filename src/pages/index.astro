---
import SiteLayout from '@layouts/SiteLayout.astro';
---

<SiteLayout
  title="Free Tibetan Typography Tools | CSS Framework, Fonts & Pecha"
  description="Free open-source tools for Tibetan text on the web. termaUI CSS framework, 36 curated fonts, PechaForge manuscript creator, and Tibetan typing practice. No account needed."
  ogType="website"
  schema={{
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "https://termafoundry.com/#organization",
        "name": "Terma Type Foundry",
        "url": "https://termafoundry.com",
        "sameAs": "https://github.com/vajradog/TermaFoundry",
        "description": "Open-source studio designing and building digital tools for Tibetan script on the modern web.",
        "email": "termastudios@gmail.com",
        "founder": { "@type": "Person", "name": "Thupten Chakrishar" },
        "knowsAbout": ["Tibetan typography", "termaUI CSS framework", "Tibetan fonts", "Pecha manuscript", "Unicode Tibetan"]
      },
      {
        "@type": "WebSite",
        "@id": "https://termafoundry.com/#website",
        "url": "https://termafoundry.com",
        "name": "Terma Foundry",
        "description": "Free open-source tools for Tibetan script on the modern web",
        "publisher": { "@id": "https://termafoundry.com/#organization" }
      }
    ]
  }}
>

  <!-- ═══════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════ -->
  <section class="hub-hero">
    <div class="hub-hero-glow" aria-hidden="true"></div>
    <div class="hub-hero-content">
      <div class="hub-hero-eyebrow reveal">Open-source ecosystem for Tibetan script</div>
      <div class="hero-display-zone reveal reveal-delay-1">
        <h1 class="hub-hero-heading" id="hero-phase-en">
          Ensuring Tibetan Script<br>Thrives in the
          <span class="hero-tibetan-word">Modern World.</span>
        </h1>
        <div class="hero-phase-tib tr-guard" lang="bo" id="hero-phase-tib" aria-hidden="true">
          <span id="hero-tib-text" class="tr-leading-normal tr-guard-lg tr-ligatures"></span>
        </div>
      </div>

      <p class="hub-hero-sub reveal reveal-delay-2">
        No word processor. No CSS framework. No manuscript tool. OCR tools exist but struggle with Tibetan's stacked consonants. We're building every missing piece — from scratch, in the open, for everyone.
      </p>
      <div class="hub-hero-actions reveal reveal-delay-3">
        <a href="#ecosystem" class="btn btn-primary">See the Ecosystem</a>
        <a href="/ocr" class="btn btn-outline">Try TermaOCR</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       THE GAP — why this matters (moved up, before tools)
       ═══════════════════════════════════════════════════════════════ -->
  <section class="page-section gap-section">
    <div class="section-eyebrow reveal">The Problem</div>
    <h2 class="section-heading reveal">A language spoken by millions.<br>Almost invisible online.</h2>
    <p class="section-sub reveal" style="max-width:640px; margin-left:auto; margin-right:auto;">
      Tibetan script powers one of the world's great literary traditions — yet the digital tools it needs barely exist. Letters get clipped on websites. Fonts don't load. There's no word processor, no way to create traditional manuscripts digitally, and OCR can't reliably read Tibetan's stacked consonants. Terma Foundry exists to change that.
    </p>

    <div class="gap-stats reveal">
      <div class="gap-stat">
        <div class="gap-stat-num">0</div>
        <div class="gap-stat-label">Dedicated Tibetan<br>word processors</div>
      </div>
      <div class="gap-stat">
        <div class="gap-stat-num">0</div>
        <div class="gap-stat-label">CSS frameworks for<br>Tibetan rendering</div>
      </div>
      <div class="gap-stat">
        <div class="gap-stat-num">0</div>
        <div class="gap-stat-label">Pecha manuscript<br>tools</div>
      </div>
      <div class="gap-stat gap-stat-accent">
        <div class="gap-stat-num">6</div>
        <div class="gap-stat-label">Tools we're<br>building right now</div>
      </div>
    </div>
  </section>

  <hr class="divider" style="max-width:1100px; margin: 0 auto;">

  <!-- ═══════════════════════════════════════════════════════════════
       THE ECOSYSTEM — all 6 tools
       ═══════════════════════════════════════════════════════════════ -->
  <section class="page-section" id="ecosystem">
    <div class="section-eyebrow reveal">The Ecosystem</div>
    <h2 class="section-heading reveal">Six tools. One mission.</h2>
    <p class="section-sub reveal">Each tool solves a specific gap in Tibetan digital infrastructure. Together, they form a complete ecosystem.</p>

    <div class="cards-grid cards-grid-2 reveal">
      <!-- termaUI -->
      <a href="/termaui/" class="tool-card tool-card-featured">
        <div class="tool-card-badge">Available Now</div>
        <div class="tool-card-icon">◈</div>
        <h3 class="tool-card-title">termaUI</h3>
        <p class="tool-card-desc">The first CSS framework built for Tibetan script. Fixes clipped letters, broken line spacing, and missing fonts — developers add one file and Tibetan just works, beautifully, on any device.</p>
        <div class="tool-card-link">Explore termaUI →</div>
      </a>

      <!-- TermaOCR -->
      <a href="/ocr" class="tool-card tool-card-featured">
        <div class="tool-card-badge tool-card-badge-proto">Web Prototype</div>
        <div class="tool-card-icon">⊡</div>
        <h3 class="tool-card-title">TermaOCR</h3>
        <p class="tool-card-desc">Turn photos of Tibetan text into editable digital text. Upload an image or PDF, draw boxes around the text you want, and get results instantly. Process entire books in batch mode.</p>
        <div class="tool-card-link">Try TermaOCR →</div>
      </a>

      <!-- TermaType -->
      <a href="/type" class="tool-card tool-card-featured">
        <div class="tool-card-badge tool-card-badge-proto">Web Prototype</div>
        <div class="tool-card-icon">⌨</div>
        <h3 class="tool-card-title">TermaType</h3>
        <p class="tool-card-desc">A Tibetan word processor with a built-in keyboard, live dictionary, rich formatting, and export to multiple formats. Works entirely in your browser — no installation needed.</p>
        <div class="tool-card-link">Open TermaType →</div>
      </a>

      <!-- PechaForge -->
      <a href="/pecha" class="tool-card tool-card-featured">
        <div class="tool-card-badge tool-card-badge-proto">Web Prototype</div>
        <div class="tool-card-icon">༺</div>
        <h3 class="tool-card-title">PechaForge</h3>
        <p class="tool-card-desc">The first digital tool for creating traditional Tibetan pecha manuscripts. Choose fonts and themes, then export as print-ready PDFs — including double-sided layouts.</p>
        <div class="tool-card-link">Open PechaForge →</div>
      </a>

      <!-- TermaDictionary -->
      <a href="/dictionary" class="tool-card tool-card-featured">
        <div class="tool-card-badge tool-card-badge-proto">Web Prototype</div>
        <div class="tool-card-icon" lang="bo" style="font-family:'Noto Serif Tibetan','Jomolhari',serif;font-size:0.75em;line-height:1.8">ཚིག་མཛོད།</div>
        <h3 class="tool-card-title">TermaDictionary</h3>
        <p class="tool-card-desc">1.2 million entries from 64 dictionaries, all searchable in one place. Look up any Tibetan word by typing in Tibetan, English, or romanized Tibetan.</p>
        <div class="tool-card-link">Open TermaDictionary →</div>
      </a>

      <!-- TermaFonts -->
      <a href="/fonts/library" class="tool-card tool-card-featured">
        <div class="tool-card-badge">Available Now</div>
        <div class="tool-card-icon">Ꭿ</div>
        <h3 class="tool-card-title">TermaFonts</h3>
        <p class="tool-card-desc">A curated library of 36 Tibetan fonts — from traditional formal scripts to modern clean styles — free to use on any website or application.</p>
        <div class="tool-card-link">Browse TermaFonts →</div>
      </a>
    </div>
  </section>

  <hr class="divider" style="max-width:1100px; margin: 0 auto;">

  <!-- ═══════════════════════════════════════════════════════════════
       PROTOTYPE → PRODUCT CALLOUT
       ═══════════════════════════════════════════════════════════════ -->
  <section class="page-section">
    <div class="proto-callout reveal">
      <div class="proto-callout-icon">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
      </div>
      <div class="proto-callout-body">
        <h3 class="proto-callout-title">Web prototypes today. Desktop applications tomorrow.</h3>
        <p class="proto-callout-desc">
          Every tool on this site is a functional prototype you can use right now. Each one is being developed into a full desktop application — TermaType, PechaForge, TermaOCR, TermaDictionary. We build in the open so the community can use them today and help shape what they become.
        </p>
        <div class="proto-roadmap">
          <div class="proto-stage">
            <div class="proto-stage-dot proto-stage-done"></div>
            <div class="proto-stage-text">
              <strong>Now</strong>
              <span>Working web prototypes</span>
            </div>
          </div>
          <div class="proto-stage-line"></div>
          <div class="proto-stage">
            <div class="proto-stage-dot proto-stage-next"></div>
            <div class="proto-stage-text">
              <strong>Next</strong>
              <span>Desktop apps (Windows, Mac, Linux)</span>
            </div>
          </div>
          <div class="proto-stage-line"></div>
          <div class="proto-stage">
            <div class="proto-stage-dot"></div>
            <div class="proto-stage-text">
              <strong>Future</strong>
              <span>Mobile apps, offline-first</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <hr class="divider" style="max-width:1100px; margin: 0 auto;">

  <!-- ═══════════════════════════════════════════════════════════════
       termaUI LIVE PREVIEW
       ═══════════════════════════════════════════════════════════════ -->
  <section class="page-section">
    <div class="section-eyebrow reveal">termaUI in Action</div>
    <h2 class="section-heading reveal">One class. Beautiful Tibetan.</h2>
    <p class="section-sub reveal">This entire website is rendered using termaUI — proof that the framework is production-ready.</p>

    <div class="termaui-preview reveal">
      <div class="preview-col preview-demo">
        <div class="preview-text-stack">
          <div class="preview-item">
            <span class="preview-cls">.tr-jomolhari</span>
            <span class="tr-jomolhari tr-text-xl tr-guard" lang="bo">བཀྲ་ཤིས་བདེ་ལེགས།</span>
          </div>
          <div class="preview-item">
            <span class="preview-cls">.tr-text-rainbow</span>
            <span class="tr-jomolhari tr-text-rainbow tr-text-xl tr-guard" lang="bo">བཀྲ་ཤིས་བདེ་ལེགས།</span>
          </div>
          <div class="preview-item">
            <span class="preview-cls">.tr-text-saffron</span>
            <span class="tr-jomolhari tr-text-saffron tr-text-xl tr-guard" lang="bo">བཀྲ་ཤིས་བདེ་ལེགས།</span>
          </div>
          <div class="preview-item">
            <span class="preview-cls">.tr-glow-aurora</span>
            <span class="tr-jomolhari tr-glow-aurora tr-text-xl tr-guard" lang="bo" style="color:#2dd4bf;">བཀྲ་ཤིས་བདེ་ལེགས།</span>
          </div>
          <div class="preview-item">
            <span class="preview-cls">.tr-noto</span>
            <span class="tr-noto tr-text-xl tr-guard" lang="bo">བཀྲ་ཤིས་བདེ་ལེགས།</span>
          </div>
        </div>
      </div>
      <div class="preview-col preview-cta">
        <h3>Built for Tibetan script.<br>Works on any website.</h3>
        <p>termaUI handles fonts, spacing, effects, and layout so that Tibetan text renders beautifully everywhere — no workarounds needed.</p>
        <a href="/termaui/" class="btn btn-primary" style="margin-top:1.5rem;">See All Classes</a>
        <a href="/termaui/docs/" class="btn btn-ghost" style="margin-top:.75rem;">Read the Docs</a>
      </div>
    </div>
  </section>

  <hr class="divider" style="max-width:1100px; margin: 0 auto;">

  <!-- ═══════════════════════════════════════════════════════════════
       ORIGINAL FONTS IN DEVELOPMENT
       ═══════════════════════════════════════════════════════════════ -->
  <section class="page-section">
    <div class="section-eyebrow reveal">Original Fonts</div>
    <h2 class="section-heading reveal">Three fonts we're building<br>from scratch.</h2>
    <p class="section-sub reveal">Working with master calligrapher Jamyang Dorjee, we're creating fonts that don't exist anywhere in the world yet.</p>

    <div class="cards-grid cards-grid-3 reveal">
      <div class="card">
        <div class="card-eyebrow">In Development</div>
        <div class="font-preview-glyph tr-jomolhari" lang="bo">ཀ</div>
        <div class="card-title">Terma Serif</div>
        <div class="card-desc">Elegant, culturally authentic. Designed for print, long-form reading, and formal publications.</div>
      </div>
      <div class="card">
        <div class="card-eyebrow">In Development</div>
        <div class="font-preview-glyph tr-noto" lang="bo">ཀ</div>
        <div class="card-title">Terma Sans-Serif</div>
        <div class="card-desc">Clean, screen-optimized. Built for digital interfaces, apps, and modern multilingual documents.</div>
      </div>
      <div class="card">
        <div class="card-eyebrow">In Development</div>
        <div class="font-preview-glyph tr-noto" lang="bo" style="color:#fbbf24;">ཀ</div>
        <div class="card-title">Terma Child-Friendly</div>
        <div class="card-desc">Simplified, approachable letterforms for young learners and semi-literate readers in the diaspora.</div>
      </div>
    </div>
  </section>

  <hr class="divider" style="max-width:1100px; margin: 0 auto;">

  <!-- ═══════════════════════════════════════════════════════════════
       WHY IT MATTERS — for funders
       ═══════════════════════════════════════════════════════════════ -->
  <section class="page-section">
    <div class="section-eyebrow reveal">Why It Matters</div>
    <h2 class="section-heading reveal">Making Tibetan script a first-class<br>citizen of the digital world.</h2>

    <div class="cards-grid cards-grid-2 reveal">
      <div class="card">
        <div class="why-icon">◈</div>
        <div class="card-title">Style Tibetan the Web Way</div>
        <div class="card-desc">Every website that shows Tibetan text faces the same problems — letters get cut off, lines overlap, fonts don't load. termaUI fixes all of it in one toolkit, so builders can create instead of troubleshoot.</div>
      </div>
      <div class="card">
        <div class="why-icon">⊡</div>
        <div class="card-title">Digitize the Canon</div>
        <div class="card-desc">Centuries of Tibetan scholarship exist only as ink on paper. TermaOCR converts scanned pages, manuscripts, and books into editable digital text — making the written tradition searchable and accessible to everyone.</div>
      </div>
      <div class="card">
        <div class="why-icon">⌨</div>
        <div class="card-title">Write in Tibetan, Anywhere</div>
        <div class="card-desc">Most people who want to write in Tibetan hit the same wall: no keyboard, no font, wrong software. TermaType removes every barrier — a built-in keyboard, live dictionary, rich formatting, and export — all in a browser tab.</div>
      </div>
      <div class="card">
        <div class="why-icon">༺</div>
        <div class="card-title">Keep Pecha Alive</div>
        <div class="card-desc">The traditional pecha format carries fifteen centuries of Tibetan literary culture. PechaForge is the first tool that lets anyone create, format, and print authentic pecha manuscripts digitally.</div>
      </div>
    </div>
  </section>

  <hr class="divider" style="max-width:1100px; margin: 0 auto;">

  <!-- ═══════════════════════════════════════════════════════════════
       CLOSING CTA — for funders
       ═══════════════════════════════════════════════════════════════ -->
  <section class="page-section" style="text-align:center;">
    <div class="cta-final reveal">
      <div class="cta-final-eyebrow">Open Source. Community Driven.</div>
      <h2 class="cta-final-heading">Help us build what Tibetan script<br>has been waiting for.</h2>
      <p class="cta-final-desc">
        Terma Foundry is an open-source project. Every tool we build is free to use, free to inspect, and free to contribute to. We're actively seeking partners and funding to bring these prototypes to full production.
      </p>
      <div class="cta-final-actions">
        <a href="/about" class="btn btn-primary">Learn About Us</a>
        <a href="https://github.com/vajradog/TermaFoundry" target="_blank" rel="noopener" class="btn btn-outline">View on GitHub</a>
      </div>
    </div>
  </section>

</SiteLayout>

<style>
  /* ══════════════════════════════════════════════════════════════════
     HERO
     ══════════════════════════════════════════════════════════════════ */
  .hub-hero {
    position: relative; overflow: hidden;
    padding: 10rem 2rem 8rem;
    text-align: center;
    max-width: 1100px; margin: 0 auto;
  }
  .hub-hero-glow {
    position: absolute; top: -200px; left: 50%; transform: translateX(-50%);
    width: 900px; height: 600px; pointer-events: none;
    background: radial-gradient(ellipse 65% 50%, rgba(217,119,87,0.08) 0%, rgba(237,161,0,0.04) 50%, transparent 80%);
  }
  .hub-hero-content { position: relative; z-index: 2; max-width: 700px; margin: 0 auto; }
  .hub-hero-eyebrow {
    font-size: .75rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: .12em; color: var(--accent); margin-bottom: 1.25rem;
  }
  .hero-display-zone { display: grid; margin-bottom: 1.5rem; }
  .hub-hero-heading {
    grid-area: 1/1;
    font-size: clamp(2rem, 4.5vw, 3.25rem); font-weight: 900;
    letter-spacing: -.04em; line-height: 1.08; color: var(--text);
    margin-bottom: 0;
    transition: opacity 0.45s ease;
  }
  .hero-tibetan-word { color: var(--accent); }
  .hero-phase-tib {
    grid-area: 1/1;
    display: flex; align-items: center; justify-content: center;
    opacity: 0; pointer-events: none;
    transition: opacity 0.45s ease;
    padding-block: 0.25em;
  }
  #hero-tib-text {
    display: block;
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    text-align: center;
  }
  .hub-hero-sub {
    font-size: 1.1rem; color: var(--text2); line-height: 1.8;
    margin-bottom: 2.5rem; max-width: 600px; margin-left: auto; margin-right: auto;
  }
  .hub-hero-actions { display: flex; gap: .75rem; justify-content: center; flex-wrap: wrap; }

  /* ══════════════════════════════════════════════════════════════════
     THE GAP — stats row
     ══════════════════════════════════════════════════════════════════ */
  .gap-section { text-align: center; }
  .gap-stats {
    display: flex; justify-content: center; gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 16px; overflow: hidden;
    margin-top: 3rem; max-width: 800px; margin-left: auto; margin-right: auto;
  }
  .gap-stat {
    flex: 1; background: var(--surface);
    padding: 2rem 1.5rem; text-align: center;
  }
  .gap-stat-num {
    font-size: 2.5rem; font-weight: 900; color: var(--muted);
    letter-spacing: -.04em; line-height: 1; margin-bottom: .5rem;
  }
  .gap-stat-label {
    font-size: .72rem; font-weight: 600; text-transform: uppercase;
    letter-spacing: .06em; color: var(--muted); line-height: 1.45;
  }
  .gap-stat-accent .gap-stat-num { color: var(--accent); }
  .gap-stat-accent .gap-stat-label { color: var(--text2); }

  /* ══════════════════════════════════════════════════════════════════
     TOOL CARDS
     ══════════════════════════════════════════════════════════════════ */
  .tool-card {
    display: block; background: var(--surface);
    padding: 2.25rem 2rem; position: relative;
    transition: background .25s; text-decoration: none;
  }
  .tool-card:hover { background: var(--surface2); }
  .tool-card-featured { border-top: 2px solid var(--accent); }
  .tool-card-badge {
    display: inline-block; font-size: .65rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: .08em; padding: .2rem .6rem; border-radius: 3px;
    background: rgba(217,119,87,0.1); color: var(--accent);
    border: 1px solid rgba(217,119,87,0.2); margin-bottom: 1.25rem;
  }
  .tool-card-badge-proto {
    background: rgba(237,161,0,0.1); color: #b87d00;
    border-color: rgba(237,161,0,0.25);
  }
  .tool-card-icon { font-size: 1.75rem; margin-bottom: .75rem; line-height: 1; }
  .tool-card-title { font-size: 1.2rem; font-weight: 700; color: var(--text); margin-bottom: .5rem; }
  .tool-card-desc { font-size: .85rem; color: var(--muted); line-height: 1.65; margin-bottom: 1.25rem; }
  .tool-card-link { font-size: .82rem; font-weight: 600; color: var(--accent); }

  /* ══════════════════════════════════════════════════════════════════
     PROTOTYPE → PRODUCT CALLOUT
     ══════════════════════════════════════════════════════════════════ */
  .proto-callout {
    display: flex; gap: 2rem; align-items: flex-start;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2.5rem;
  }
  .proto-callout-icon {
    flex-shrink: 0; color: var(--accent);
    width: 56px; height: 56px;
    display: flex; align-items: center; justify-content: center;
    background: rgba(217,119,87,0.08);
    border-radius: 12px;
  }
  .proto-callout-body { flex: 1; }
  .proto-callout-title {
    font-size: 1.2rem; font-weight: 800; color: var(--text);
    letter-spacing: -.02em; margin-bottom: .75rem;
  }
  .proto-callout-desc {
    font-size: .9rem; color: var(--text2); line-height: 1.75;
    margin-bottom: 1.5rem;
  }

  /* roadmap mini-timeline */
  .proto-roadmap {
    display: flex; align-items: center; gap: 0;
    flex-wrap: wrap;
  }
  .proto-stage {
    display: flex; align-items: center; gap: .6rem;
  }
  .proto-stage-dot {
    width: 12px; height: 12px; border-radius: 50%;
    border: 2px solid var(--muted);
    background: transparent; flex-shrink: 0;
  }
  .proto-stage-done {
    background: var(--accent); border-color: var(--accent);
    box-shadow: 0 0 8px rgba(217,119,87,0.35);
  }
  .proto-stage-next {
    border-color: var(--accent);
    background: rgba(217,119,87,0.2);
  }
  .proto-stage-text { display: flex; flex-direction: column; }
  .proto-stage-text strong {
    font-size: .72rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: .06em; color: var(--text);
  }
  .proto-stage-text span { font-size: .78rem; color: var(--muted); }
  .proto-stage-line {
    width: 40px; height: 2px;
    background: linear-gradient(90deg, var(--accent), var(--border));
    margin: 0 .75rem;
    flex-shrink: 0;
  }

  /* ══════════════════════════════════════════════════════════════════
