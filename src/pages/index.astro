<script is:inline>
(function () {
  var phaseEn  = document.getElementById('hero-phase-en');
  var phaseTib = document.getElementById('hero-phase-tib');
  var tibText  = document.getElementById('hero-tib-text');
  if (!phaseEn || !phaseTib || !tibText) return;

  var FADE = 450;

  var phases = [
    { type: 'en', duration: 5500 },
    {
      type: 'tib',
      html: 'བོད་ཡིག་ནི་བོད་ཀྱི་བླ་སྲོག་ཡིན།',
      font: 'tr-drutsa',
      effect: 'tr-text-rainbow',
      color: '',
      duration: 4400
    },
    {
      type: 'tib',
      html: 'བོད་ཡིག་སྦྱོང་བ་ནི་སེམས་ཉིད་སྦྱོང་བ་ཡིན།',
      font: 'tr-jomolhari',
      effect: 'tr-text-fire',
      color: '',
      duration: 4400
    },
    {
      type: 'tib',
      html: 'གངས་ཅན་བོད་ཀྱི་ཡི་གེ་འདི། །<br>བོད་ཀྱི་རིག་གནས་ཀུན་གྱི་གཞི། །',
      font: 'tr-riwoche',
      effect: '',
      color: 'var(--text)',
      duration: 5000
    }
  ];

  var tibFonts   = ['tr-drutsa', 'tr-jomolhari', 'tr-riwoche'];
  var tibEffects = ['tr-text-rainbow', 'tr-text-fire', 'tr-text-saffron', 'tr-glow-aurora', 'tr-outline-gold'];

  var idx  = 0;
  var busy = false;

  function applyPhase(p) {
    if (p.type === 'en') {
      phaseEn.style.opacity      = '1';
      phaseEn.style.pointerEvents = '';
      phaseTib.style.opacity     = '0';
      phaseTib.style.pointerEvents = 'none';
      phaseTib.setAttribute('aria-hidden', 'true');
    } else {
      tibFonts.forEach(function(c)   { tibText.classList.remove(c); });
      tibEffects.forEach(function(c) { tibText.classList.remove(c); });
      tibText.style.color = '';
      tibText.innerHTML = p.html;
      tibText.classList.add(p.font);
      if (p.effect) tibText.classList.add(p.effect);
      if (p.color) tibText.style.color = p.color;
      phaseEn.style.opacity      = '0';
      phaseEn.style.pointerEvents = 'none';
      phaseTib.style.opacity     = '1';
      phaseTib.style.pointerEvents = '';
      phaseTib.removeAttribute('aria-hidden');
    }
  }

  function advance() {
    if (busy) return;
    busy = true;
    var cur = phases[idx];
    if (cur.type === 'en') { phaseEn.style.opacity  = '0'; }
    else                   { phaseTib.style.opacity = '0'; }
    setTimeout(function () {
      idx = (idx + 1) % phases.length;
      applyPhase(phases[idx]);
      busy = false;
      setTimeout(advance, phases[idx].duration);
    }, FADE + 20);
  }

  phaseEn.style.opacity       = '1';
  phaseTib.style.opacity      = '0';
  phaseTib.style.pointerEvents = 'none';
  setTimeout(advance, phases[0].duration);
})();
</script>
