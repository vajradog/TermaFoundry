---
import SiteLayout from '@layouts/SiteLayout.astro';
---

<SiteLayout title="TermaOCR" description="Tibetan OCR — upload an image, draw regions around text, and get recognized Tibetan script instantly.">

  <section class="page-section ocr-page">
    <div class="section-eyebrow">Tibetan Script Recognition</div>
    <h1 class="section-heading">TermaOCR <span class="ocr-beta">BETA</span></h1>
    <p class="section-sub">Upload an image or PDF of Tibetan text, draw boxes around the areas you want recognized, and get editable Unicode text back instantly.</p>

    <!-- Mode Selector -->
    <div class="ocr-modes">
      <button class="ocr-mode-btn active" data-mode="normal" id="mode-normal">New</button>
      <button class="ocr-mode-btn" data-mode="batch" id="mode-batch">Batch OCR</button>
    </div>

    <!-- Drop Zone -->
    <div class="ocr-drop-zone" id="drop-zone">
      <div class="ocr-drop-icon">&#128220;</div>
      <p>Drag & drop an image here, or click to browse</p>
      <p class="ocr-formats">PNG, JPG, TIFF, BMP, WEBP, PDF</p>
      <input type="file" id="file-input" hidden accept=".png,.jpg,.jpeg,.tif,.tiff,.bmp,.webp,.pdf">
    </div>

    <!-- Region Editor -->
    <div id="region-editor" class="ocr-region-editor">
      <div class="ocr-region-toolbar">
        <span class="ocr-region-info" id="region-info">Draw boxes around text areas to OCR</span>
        <div class="ocr-region-actions">
          <button class="btn btn-ghost btn-sm" id="btn-undo-region">Undo</button>
          <button class="btn btn-ghost btn-sm" id="btn-clear-regions">Clear</button>
          <button class="btn btn-ghost btn-sm" id="btn-save-template" style="display:none">Save Template</button>
          <button class="btn btn-primary btn-sm" id="btn-process-regions">Process Regions</button>
        </div>
      </div>
      <div class="ocr-canvas-wrapper" id="canvas-wrapper">
        <canvas id="region-canvas"></canvas>
      </div>
      <div class="ocr-region-list" id="region-list"></div>
    </div>

    <!-- Template Save Dialog -->
    <div class="ocr-dialog-overlay" id="template-dialog">
      <div class="ocr-dialog">
        <h3>Save Template</h3>
        <p class="ocr-dialog-desc">Name this region layout for reuse on similar pages</p>
        <input type="text" id="template-name-input" class="ocr-dialog-input" placeholder="e.g. Pecha standard" autocomplete="off">
        <div class="ocr-dialog-buttons">
          <button class="btn btn-ghost btn-sm" id="btn-template-cancel">Cancel</button>
          <button class="btn btn-primary btn-sm" id="btn-template-save">Save</button>
        </div>
      </div>
    </div>

    <!-- Batch OCR Panel -->
    <div id="batch-panel" class="ocr-batch-panel">
      <div class="ocr-batch-section">
        <h3>1. Choose a Template</h3>
        <p class="ocr-batch-hint" id="batch-no-templates">No templates saved yet. Upload an image in New mode and save your regions as a template first.</p>
        <div class="ocr-template-list" id="template-list"></div>
      </div>
      <div class="ocr-batch-section" id="batch-upload-section" style="display:none">
        <h3>2. Upload Pages</h3>
        <div class="ocr-drop-zone ocr-batch-drop" id="batch-drop-zone">
          <div class="ocr-drop-icon">&#128218;</div>
          <p>Drop multiple images here, or click to browse</p>
          <p class="ocr-formats">All pages will use the same template regions</p>
          <input type="file" id="batch-file-input" hidden multiple accept=".png,.jpg,.jpeg,.tif,.tiff,.bmp,.webp">
        </div>
        <div class="ocr-batch-file-list" id="batch-file-list"></div>
      </div>
      <div class="ocr-batch-section" id="batch-process-section" style="display:none">
        <button class="btn btn-primary" id="btn-batch-process" style="width:100%">Process All Pages</button>
      </div>
      <div class="ocr-batch-section" id="batch-progress-section" style="display:none">
        <div class="ocr-progress-bar"><div class="ocr-progress-fill" id="batch-progress-fill"></div></div>
        <p class="ocr-progress-text" id="batch-progress-text">Processing...</p>
      </div>
      <div class="ocr-batch-section" id="batch-results-section" style="display:none">
        <h3>Results</h3>
        <div id="batch-results"></div>
        <div class="ocr-btn-row">
          <button class="btn btn-primary btn-sm" id="btn-batch-copy-all">Copy All</button>
          <button class="btn btn-ghost btn-sm" id="btn-batch-download-all">Download All (.txt)</button>
          <button class="btn btn-ghost btn-sm" id="btn-batch-clear">Clear</button>
        </div>
      </div>
    </div>

    <!-- Error -->
    <div id="error-msg" class="ocr-error"></div>

    <!-- Status -->
    <div id="status" class="ocr-status">
      <span class="ocr-spinner"></span>
      <span id="status-text">Processing...</span>
    </div>

    <!-- Result -->
    <div id="result-panel" class="ocr-result-panel">
      <div class="ocr-result-header">
        <h3>Recognised Text</h3>
        <span class="ocr-result-meta" id="result-meta"></span>
      </div>
      <div class="ocr-result-text" id="result-text"></div>
      <div class="ocr-btn-row">
        <button class="btn btn-primary btn-sm" id="btn-copy">Copy to Clipboard</button>
        <button class="btn btn-ghost btn-sm" id="btn-download">Download .txt</button>
        <button class="btn btn-ghost btn-sm" id="btn-clear">Clear</button>
      </div>
    </div>

    <!-- How to Use -->
    <div class="ocr-how-to">
      <h3>How It Works</h3>
      <div class="ocr-steps">
        <div class="ocr-step">
          <span class="ocr-step-num">1</span>
          <div>
            <strong>Upload</strong>
            <p>Drop an image or PDF of Tibetan text. PDFs are OCR'd directly — no setup needed. For images, you'll draw boxes around the text you want recognized.</p>
          </div>
        </div>
        <div class="ocr-step">
          <span class="ocr-step-num">2</span>
          <div>
            <strong>Select regions</strong>
            <p>Draw tight boxes around the Tibetan text — the closer you crop to the text, the better the results. Avoid illustrations and margins.</p>
          </div>
        </div>
        <div class="ocr-step">
          <span class="ocr-step-num">3</span>
          <div>
            <strong>Process</strong>
            <p>Hit <strong>Process Regions</strong> and get editable Unicode text back. Copy, download, or save your region layout as a template for batch processing similar pages.</p>
          </div>
        </div>
      </div>
      <button class="btn btn-outline btn-sm" id="btn-try-sample" style="margin-top:1.5rem">Try with a sample pecha image</button>
    </div>

    <!-- Roadmap statement -->
    <div class="ocr-roadmap">
      <p class="ocr-roadmap-lead">TermaOCR is actively developing. Tibetan is a low-resource language with limited training data available — a challenge that makes each improvement hard-won and meaningful.</p>
      <p class="ocr-roadmap-body">Our system currently handles <strong>Uchen</strong> <span lang="bo">(དབུ་ཅན་)</span> printed text, <strong>Drutsa</strong> <span lang="bo">(བྲུ་ཚ་)</span>, <strong>Betsug</strong> <span lang="bo">(དཔེ་ཚུགས་)</span>, and <strong>Umey</strong> <span lang="bo">(དབུ་མེད་)</span> handwritten scripts with growing accuracy, and we are working to expand support for:</p>
      <ul class="ocr-roadmap-list">
        <li><strong>Khyug Yig</strong> <span lang="bo">(འཁྱུག་ཡིག་)</span> — fast cursive handwriting</li>
        <li><strong>Tsugthung</strong> <span lang="bo">(ཚུགས་ཐུང་)</span> — shorthand script</li>
        <li><strong>Complex vertical stacking</strong> — multi-layered consonant clusters</li>
        <li><strong>Historical calligraphic styles</strong> — woodblock and manuscript traditions</li>
        <li><strong>Advanced page segmentation</strong> — mixed layouts, illustrations, and marginalia</li>
      </ul>
      <p class="ocr-roadmap-cta">With continued support, TermaOCR can become the definitive open tool for digitizing Tibet's vast literary heritage. Your contribution directly advances the preservation of an endangered written tradition.</p>
    </div>
  </section>

  <!-- Toast -->
  <div class="ocr-toast" id="toast"></div>

</SiteLayout>

<style>
  /* ── OCR page scoped styles ── */
  .ocr-page .section-eyebrow,
  .ocr-page .section-heading,
  .ocr-page .section-sub {
    text-align: center;
  }
  .ocr-page .section-sub {
    margin-left: auto;
    margin-right: auto;
  }
  .ocr-beta {
    font-size: .5em; font-weight: 700; vertical-align: super;
    padding: .15em .5em; border-radius: 4px;
    background: rgba(56,189,248,0.12); color: var(--accent);
    border: 1px solid rgba(56,189,248,0.2);
    letter-spacing: .06em;
  }

  /* Mode buttons */
  .ocr-modes {
    display: flex; gap: .5rem; margin-bottom: 2rem;
  }
  .ocr-mode-btn {
    padding: .55rem 1.4rem; border-radius: 8px;
    font-size: .88rem; font-weight: 600; cursor: pointer;
    background: var(--surface); color: var(--text2);
    border: 1px solid var(--border2); transition: all .15s;
  }
  .ocr-mode-btn:hover { background: var(--surface2); color: var(--text); }
  .ocr-mode-btn.active {
    background: rgba(56,189,248,0.1); color: var(--accent);
    border-color: rgba(56,189,248,0.3);
  }

  /* Drop zone */
  .ocr-drop-zone {
    border: 2px dashed var(--border2); border-radius: 16px;
    padding: 3rem 2rem; text-align: center; cursor: pointer;
    transition: all .2s; background: var(--surface);
  }
  .ocr-drop-zone:hover, .ocr-drop-zone.drag-over {
    border-color: var(--accent); background: rgba(56,189,248,0.04);
  }
  .ocr-drop-icon { font-size: 2.5rem; margin-bottom: .75rem; }
  .ocr-drop-zone p { color: var(--text2); font-size: .9rem; }
  .ocr-formats { font-size: .78rem !important; color: var(--muted) !important; margin-top: .25rem; }

  /* Region editor */
  .ocr-region-editor {
    display: none; margin-bottom: 2rem;
  }
  .ocr-region-editor.visible { display: block; }

  .ocr-region-toolbar {
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: .75rem;
    padding: .75rem 1rem; margin-bottom: .75rem;
    background: var(--surface); border-radius: 10px;
    border: 1px solid var(--border);
  }
  .ocr-region-info { font-size: .85rem; color: var(--text2); }
  .ocr-region-actions { display: flex; gap: .4rem; flex-wrap: wrap; }

  .ocr-canvas-wrapper {
    background: var(--surface); border-radius: 10px; overflow: hidden;
    border: 1px solid var(--border); margin-bottom: .75rem;
  }
  #region-canvas { display: block; cursor: crosshair; }

  .ocr-region-list { display: flex; flex-wrap: wrap; gap: .4rem; }
  .ocr-region-list:empty { display: none; }

  /* Region tags */
  :global(.ocr-region-tag) {
    display: inline-block; padding: .2rem .6rem; border-radius: 6px;
    font-size: .78rem; font-weight: 600;
    background: rgba(56,189,248,0.1); color: var(--accent);
    border: 1px solid rgba(56,189,248,0.2);
  }

  /* Button sizes */
  .btn-sm { padding: .4rem .9rem; font-size: .82rem; }

  /* Dialog */
  .ocr-dialog-overlay {
    display: none; position: fixed; inset: 0; z-index: 300;
    background: rgba(0,0,0,0.6); backdrop-filter: blur(4px);
    align-items: center; justify-content: center;
  }
  .ocr-dialog-overlay.visible { display: flex; }
  .ocr-dialog {
    background: var(--surface); border: 1px solid var(--border2);
    border-radius: 16px; padding: 2rem; width: 90%; max-width: 400px;
  }
  .ocr-dialog h3 { font-size: 1.1rem; font-weight: 700; color: var(--text); margin-bottom: .5rem; }
  .ocr-dialog-desc { font-size: .85rem; color: var(--muted); margin-bottom: 1.25rem; }
  .ocr-dialog-input {
    width: 100%; padding: .6rem .85rem; border-radius: 8px;
    background: var(--bg); color: var(--text); font-size: .9rem;
    border: 1px solid var(--border2); outline: none; margin-bottom: 1rem;
    transition: border-color .15s;
  }
  .ocr-dialog-input:focus { border-color: var(--accent); }
  .ocr-dialog-input.error { animation: shake .4s ease-in-out; border-color: var(--red); }
  .ocr-dialog-buttons { display: flex; gap: .5rem; justify-content: flex-end; }

  /* Batch panel */
  .ocr-batch-panel { display: none; }
  .ocr-batch-panel.visible { display: block; }
  .ocr-batch-section { margin-bottom: 1.5rem; }
  .ocr-batch-section h3 { font-size: 1rem; font-weight: 700; color: var(--text); margin-bottom: .75rem; }
  .ocr-batch-hint { font-size: .85rem; color: var(--muted); }
  .ocr-batch-drop { padding: 2rem 1.5rem; }

  /* Template cards */
  :global(.ocr-template-card) {
    display: flex; align-items: center; justify-content: space-between;
    padding: .75rem 1rem; border-radius: 10px; cursor: pointer;
    background: var(--surface); border: 1px solid var(--border2);
    transition: all .15s; margin-bottom: .4rem;
  }
  :global(.ocr-template-card:hover) { background: var(--surface2); }
  :global(.ocr-template-card.selected) {
    border-color: rgba(56,189,248,0.4);
    background: rgba(56,189,248,0.06);
  }
  :global(.ocr-template-name) { font-size: .9rem; font-weight: 600; color: var(--text); }
  :global(.ocr-template-meta) { font-size: .78rem; color: var(--muted); }

  /* Batch file list */
  :global(.ocr-batch-file-item) {
    display: flex; align-items: center; justify-content: space-between;
    padding: .5rem .75rem; border-radius: 8px;
    background: var(--surface); border: 1px solid var(--border);
    margin-top: .4rem; font-size: .85rem;
  }
  :global(.ocr-batch-file-name) { color: var(--text2); }
  :global(.ocr-batch-file-remove) {
    background: none; border: none; color: var(--muted); cursor: pointer;
    font-size: 1.1rem; padding: 0 .25rem; transition: color .15s;
  }
  :global(.ocr-batch-file-remove:hover) { color: var(--red); }

  /* Progress bar */
  .ocr-progress-bar {
    height: 6px; background: var(--surface); border-radius: 3px;
    overflow: hidden; margin-bottom: .5rem;
  }
  .ocr-progress-fill {
    height: 100%; background: var(--accent); border-radius: 3px;
    width: 0; transition: width .3s;
  }
  .ocr-progress-text { font-size: .82rem; color: var(--text2); }

  /* Batch results */
  :global(.ocr-batch-result-item) {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 10px; padding: 1rem; margin-bottom: .75rem;
  }
  :global(.ocr-batch-result-item.has-error) { border-color: rgba(239,68,68,0.3); }
  :global(.ocr-batch-result-header) {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: .5rem;
  }
  :global(.ocr-batch-result-filename) { font-size: .85rem; font-weight: 600; color: var(--text); }
  :global(.ocr-batch-result-meta) { font-size: .78rem; color: var(--muted); }
  :global(.ocr-batch-result-text) {
    font-size: .88rem; color: var(--text2); line-height: 1.7;
    white-space: pre-wrap; word-break: break-word;
    font-family: 'Jomolhari', 'Noto Serif Tibetan', serif;
  }

  /* Error */
  .ocr-error {
    display: none; padding: 1.25rem 1.5rem; border-radius: 12px;
    background: rgba(239,68,68,0.06); border: 1px solid rgba(239,68,68,0.18);
    color: var(--text2); font-size: .88rem; line-height: 1.6;
    margin-top: 1.25rem; margin-bottom: 1rem;
    text-align: center;
  }
  .ocr-error.visible { display: block; }

  /* Status spinner */
  .ocr-status {
    display: none; align-items: center; gap: .75rem;
    padding: 1rem; margin-bottom: 1rem;
    font-size: .9rem; color: var(--text2);
  }
  .ocr-status.visible { display: flex; }
  .ocr-spinner {
    width: 20px; height: 20px; border-radius: 50%;
    border: 2px solid var(--border2); border-top-color: var(--accent);
    animation: ocr-spin .6s linear infinite;
  }
  @keyframes ocr-spin { to { transform: rotate(360deg); } }

  /* Result panel */
  .ocr-result-panel { display: none; margin-bottom: 2rem; }
  .ocr-result-panel.visible { display: block; }
  .ocr-result-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: .75rem;
  }
  .ocr-result-header h3 { font-size: 1rem; font-weight: 700; color: var(--text); }
  .ocr-result-meta { font-size: .78rem; color: var(--muted); }
  .ocr-result-text {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 10px; padding: 1.25rem;
    font-size: 1.35rem; color: var(--text); line-height: 2;
    white-space: pre-wrap; word-break: break-word;
    font-family: 'Jomolhari', 'Noto Serif Tibetan', serif;
    margin-bottom: 1rem; max-height: 500px; overflow-y: auto;
  }

  /* Button row */
  .ocr-btn-row { display: flex; gap: .5rem; flex-wrap: wrap; }

  /* How it works */
  .ocr-how-to {
    margin-top: 3rem; padding-top: 2rem;
    border-top: 1px solid var(--border);
  }
  .ocr-how-to h3 { font-size: 1rem; font-weight: 700; color: var(--text); margin-bottom: 1.5rem; }

  .ocr-steps {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px;
    background: var(--border); border: 1px solid var(--border);
    border-radius: 12px; overflow: hidden;
  }
  .ocr-step {
    display: flex; gap: 1rem; padding: 1.5rem;
    background: var(--surface);
  }
  .ocr-step-num {
    flex-shrink: 0; width: 28px; height: 28px;
    display: flex; align-items: center; justify-content: center;
    border-radius: 50%; font-size: .78rem; font-weight: 700;
    background: rgba(56,189,248,0.1); color: var(--accent);
    border: 1px solid rgba(56,189,248,0.2);
  }
  .ocr-step strong { display: block; color: var(--text); margin-bottom: .35rem; font-size: .9rem; }
  .ocr-step p { font-size: .82rem; color: var(--muted); line-height: 1.6; }

  /* Roadmap statement */
  .ocr-roadmap {
    margin-top: 3rem; padding: 2rem 2.25rem;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 14px;
  }
  .ocr-roadmap-lead {
    font-size: .92rem; color: var(--text); line-height: 1.7;
    margin-bottom: 1rem;
  }
  .ocr-roadmap-body {
    font-size: .85rem; color: var(--text2); line-height: 1.7;
    margin-bottom: 1rem;
  }
  .ocr-roadmap-body strong { color: var(--text); }
  .ocr-roadmap-body [lang="bo"],
  .ocr-roadmap-list [lang="bo"] {
    font-family: 'Jomolhari', 'Noto Serif Tibetan', serif;
    font-size: .82em; color: var(--muted);
  }
  .ocr-roadmap-list {
    list-style: none; padding: 0; margin: 0 0 1.25rem 0;
    display: flex; flex-direction: column; gap: .5rem;
  }
  .ocr-roadmap-list li {
    font-size: .85rem; color: var(--text2); line-height: 1.6;
    padding-left: 1.25rem; position: relative;
  }
  .ocr-roadmap-list li::before {
    content: ''; position: absolute; left: 0; top: .55em;
    width: 6px; height: 6px; border-radius: 50%;
    background: rgba(56,189,248,0.4);
  }
  .ocr-roadmap-list li strong { color: var(--text); }
  .ocr-roadmap-cta {
    font-size: .85rem; color: var(--muted); line-height: 1.7;
    padding-top: 1rem; border-top: 1px solid var(--border);
    font-style: italic;
  }

  /* Toast */
  .ocr-toast {
    position: fixed; bottom: 2rem; left: 50%; transform: translateX(-50%) translateY(1rem);
    padding: .6rem 1.25rem; border-radius: 8px;
    background: var(--surface2); color: var(--text); font-size: .85rem;
    border: 1px solid var(--border2);
    opacity: 0; pointer-events: none; transition: all .25s; z-index: 400;
  }
  .ocr-toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-6px); }
    75% { transform: translateX(6px); }
  }

  @media (max-width: 700px) {
    .ocr-steps { grid-template-columns: 1fr; }
    .ocr-region-toolbar { flex-direction: column; align-items: flex-start; }
  }
</style>

<script>
  const OCR_API = 'https://api.termafoundry.com/ocr';
  const REQUEST_TIMEOUT_MS = 90000;
  const MIXED_CONTENT_RISK = false;

  const dropZone = document.getElementById('drop-zone');
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const statusEl = document.getElementById('status');
  const statusText = document.getElementById('status-text');
  const errorMsg = document.getElementById('error-msg');
  const resultPanel = document.getElementById('result-panel');
  const resultText = document.getElementById('result-text');
  const resultMeta = document.getElementById('result-meta');
  const toast = document.getElementById('toast');
  const regionEditor = document.getElementById('region-editor');
  const regionCanvas = document.getElementById('region-canvas') as HTMLCanvasElement;
  const canvasWrapper = document.getElementById('canvas-wrapper');
  const regionInfo = document.getElementById('region-info');
  const regionList = document.getElementById('region-list');
  const batchPanel = document.getElementById('batch-panel');

  let lastResult: any = null;
  let currentMode = 'normal';
  let currentFile: File | null = null;
  let loadedImage: HTMLImageElement | null = null;
  let regions: Array<{x:number, y:number, w:number, h:number, label:string}> = [];
  let isDrawing = false;
  let drawStart: {x:number, y:number} | null = null;
  const regionLabels = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';

  let selectedTemplate: string | null = null;
  let batchFiles: File[] = [];
  let batchResults: Array<{filename:string, text:string, lines?:number, error?:string}> = [];
  const _templates: Record<string, typeof regions> = {};

  // ── Mode switching ──
  document.querySelectorAll('.ocr-mode-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.ocr-mode-btn').forEach(b => b.classList.remove('active'));
      (btn as HTMLElement).classList.add('active');
      currentMode = (btn as HTMLElement).dataset.mode!;
      regionEditor!.classList.remove('visible');
      batchPanel!.classList.remove('visible');
      dropZone!.style.display = '';
      resultPanel!.classList.remove('visible');
      if (currentMode === 'normal') {
        currentFile = null; loadedImage = null; regions = []; lastResult = null;
        fileInput.value = ''; hideError();
      } else if (currentMode === 'batch') {
        dropZone!.style.display = 'none';
        batchPanel!.classList.add('visible');
        loadTemplateList();
      }
    });
  });

  // ── Drop zone ──
  dropZone!.addEventListener('click', () => fileInput.click());
  dropZone!.addEventListener('dragover', (e) => { e.preventDefault(); dropZone!.classList.add('drag-over'); });
  dropZone!.addEventListener('dragleave', () => dropZone!.classList.remove('drag-over'));
  dropZone!.addEventListener('drop', (e) => {
    e.preventDefault(); dropZone!.classList.remove('drag-over');
    if (e.dataTransfer?.files.length) handleFile(e.dataTransfer.files[0]);
  });
  fileInput.addEventListener('change', () => { if (fileInput.files?.length) handleFile(fileInput.files[0]); });

  function handleFile(file: File) {
    currentFile = file; lastResult = null; regions = [];
    resultPanel!.classList.remove('visible'); hideError();

    // PDFs go straight to OCR — no region editor needed
    if (file.type === 'application/pdf' || file.name.toLowerCase().endsWith('.pdf')) {
      processPDF(file);
    } else {
      loadImageForRegions(file);
    }
  }

  async function processPDF(file: File) {
    regionEditor!.classList.remove('visible');
    dropZone!.style.display = 'none';
    statusEl!.classList.add('visible');
    statusText!.textContent = `Processing ${file.name}...`;
    try {
      const base64 = await fileToBase64(file);
      const data = await submitOCR(base64, 'normal', [], file.name);
      lastResult = { ...data, filename: file.name };
      resultText!.textContent = data.text || '(no text recognised)';
      resultMeta!.textContent = `${data.line_count || 0} line${(data.line_count || 0) !== 1 ? 's' : ''} — ${file.name}`;
      resultPanel!.classList.add('visible');
    } catch (err: any) {
      showError(err.message);
      dropZone!.style.display = '';
    } finally {
      statusEl!.classList.remove('visible');
    }
  }

  function loadImageForRegions(file: File) {
    const reader = new FileReader();
    reader.onload = (e) => {
      const img = new Image();
      img.onload = () => { loadedImage = img; showRegionEditor(); };
      img.src = e.target!.result as string;
    };
    reader.readAsDataURL(file);
  }

  function showRegionEditor() {
    regionEditor!.classList.add('visible');
    dropZone!.style.display = 'none';
    const maxW = canvasWrapper!.clientWidth || 800;
    const scale = Math.min(maxW / loadedImage!.naturalWidth, 1);
    const dispW = Math.floor(loadedImage!.naturalWidth * scale);
    const dispH = Math.floor(loadedImage!.naturalHeight * scale);
    regionCanvas.width = dispW;
    regionCanvas.height = dispH;
    regionCanvas.style.width = dispW + 'px';
    regionCanvas.style.height = dispH + 'px';
    drawCanvas();
    updateRegionList();
  }

  function drawCanvas() {
    const ctx = regionCanvas.getContext('2d')!;
    const w = regionCanvas.width, h = regionCanvas.height;
    ctx.drawImage(loadedImage!, 0, 0, w, h);
    regions.forEach((r) => {
      const rx = r.x * w, ry = r.y * h, rw = r.w * w, rh = r.h * h;
      ctx.fillStyle = 'rgba(56,189,248,0.12)';
      ctx.fillRect(rx, ry, rw, rh);
      ctx.strokeStyle = '#38bdf8';
      ctx.lineWidth = 2;
      ctx.strokeRect(rx, ry, rw, rh);
      ctx.fillStyle = '#38bdf8';
      ctx.font = 'bold 16px Inter, sans-serif';
      ctx.fillText(r.label, rx + 6, ry + 20);
    });
  }

  // ── Canvas mouse events ──
  regionCanvas.addEventListener('mousedown', (e) => {
    const rect = regionCanvas.getBoundingClientRect();
    drawStart = { x: e.clientX - rect.left, y: e.clientY - rect.top };
    isDrawing = true;
  });
  regionCanvas.addEventListener('mousemove', (e) => {
    if (!isDrawing || !drawStart) return;
    const rect = regionCanvas.getBoundingClientRect();
    drawCanvas();
    const ctx = regionCanvas.getContext('2d')!;
    ctx.strokeStyle = '#22c55e'; ctx.lineWidth = 2; ctx.setLineDash([6, 3]);
    ctx.strokeRect(drawStart.x, drawStart.y, e.clientX - rect.left - drawStart.x, e.clientY - rect.top - drawStart.y);
    ctx.setLineDash([]);
  });
  regionCanvas.addEventListener('mouseup', (e) => {
    if (!isDrawing || !drawStart) return;
    isDrawing = false;
    const rect = regionCanvas.getBoundingClientRect();
    const endX = e.clientX - rect.left, endY = e.clientY - rect.top;
    const w = regionCanvas.width, h = regionCanvas.height;
    let nx = Math.min(drawStart.x, endX) / w, ny = Math.min(drawStart.y, endY) / h;
    let nw = Math.abs(endX - drawStart.x) / w, nh = Math.abs(endY - drawStart.y) / h;
    if (nw < 0.02 || nh < 0.02) { drawCanvas(); return; }
    nx = Math.max(0, Math.min(1 - nw, nx));
    ny = Math.max(0, Math.min(1 - nh, ny));
    regions.push({ x: nx, y: ny, w: nw, h: nh, label: regionLabels[regions.length % 26] });
    drawCanvas(); updateRegionList(); drawStart = null;
  });

  // Touch support
  regionCanvas.addEventListener('touchstart', (e) => {
    e.preventDefault();
    const t = e.touches[0], rect = regionCanvas.getBoundingClientRect();
    drawStart = { x: t.clientX - rect.left, y: t.clientY - rect.top };
    isDrawing = true;
  });
  regionCanvas.addEventListener('touchmove', (e) => {
    e.preventDefault();
    if (!isDrawing || !drawStart) return;
    const t = e.touches[0], rect = regionCanvas.getBoundingClientRect();
    drawCanvas();
    const ctx = regionCanvas.getContext('2d')!;
    ctx.strokeStyle = '#22c55e'; ctx.lineWidth = 2; ctx.setLineDash([6, 3]);
    ctx.strokeRect(drawStart.x, drawStart.y, t.clientX - rect.left - drawStart.x, t.clientY - rect.top - drawStart.y);
    ctx.setLineDash([]);
  });
  regionCanvas.addEventListener('touchend', (e) => {
    if (!isDrawing || !drawStart) return;
    isDrawing = false;
    const t = e.changedTouches[0], rect = regionCanvas.getBoundingClientRect();
    const endX = t.clientX - rect.left, endY = t.clientY - rect.top;
    const w = regionCanvas.width, h = regionCanvas.height;
    let nx = Math.min(drawStart.x, endX) / w, ny = Math.min(drawStart.y, endY) / h;
    let nw = Math.abs(endX - drawStart.x) / w, nh = Math.abs(endY - drawStart.y) / h;
    if (nw < 0.02 || nh < 0.02) { drawCanvas(); return; }
    nx = Math.max(0, Math.min(1 - nw, nx));
    ny = Math.max(0, Math.min(1 - nh, ny));
    regions.push({ x: nx, y: ny, w: nw, h: nh, label: regionLabels[regions.length % 26] });
    drawCanvas(); updateRegionList(); drawStart = null;
  });

  function updateRegionList() {
    const btnSave = document.getElementById('btn-save-template') as HTMLButtonElement;
    if (regions.length === 0) {
      regionList!.innerHTML = '';
      regionInfo!.textContent = 'Draw boxes around text areas to OCR';
      btnSave.style.display = 'none';
      return;
    }
    regionInfo!.textContent = `${regions.length} region${regions.length > 1 ? 's' : ''} selected`;
    regionList!.innerHTML = regions.map(r => `<span class="ocr-region-tag">Region ${r.label}</span>`).join('');
    btnSave.style.display = '';
  }

  // ── Region toolbar ──
  document.getElementById('btn-undo-region')!.addEventListener('click', () => { regions.pop(); drawCanvas(); updateRegionList(); });
  document.getElementById('btn-clear-regions')!.addEventListener('click', () => { regions = []; drawCanvas(); updateRegionList(); });
  document.getElementById('btn-process-regions')!.addEventListener('click', () => {
    if (regions.length === 0) { showError('Draw at least one region before processing.'); return; }
    if (!currentFile) return;
    processFile(currentFile);
  });

  // ── OCR API call (direct to Hetzner, synchronous) ──
  async function submitOCR(base64: string, mode: string, regs: typeof regions, filename: string) {
    statusText!.textContent = `Processing ${filename}...`;
    let resp: Response;
    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), REQUEST_TIMEOUT_MS);
    try {
      resp = await fetch(OCR_API, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        signal: controller.signal,
        body: JSON.stringify({ image: base64, mode, regions: regs }),
      });
    } catch (err: any) {
      if (err?.name === 'AbortError') throw new Error('REQUEST_TIMEOUT');
      if (MIXED_CONTENT_RISK) throw new Error('MIXED_CONTENT_BLOCKED');
      throw new Error('REQUEST_FAILED');
    } finally {
      clearTimeout(timeoutId);
    }

    const contentType = resp.headers.get('content-type') || '';
    let data: any = null;
    let textBody = '';

    if (contentType.includes('application/json')) {
      try {
        data = await resp.json();
      } catch {
        data = null;
      }
    } else {
      try {
        textBody = await resp.text();
      } catch {
        textBody = '';
      }
    }

    if (!resp.ok) {
      if (resp.status === 413) throw new Error('HTTP_413');
      if (resp.status === 429) throw new Error('HTTP_429');
      if (resp.status === 503 || resp.status === 504) throw new Error('HTTP_5XX_OVERLOADED');

      const serverMsg =
        (data && typeof data.error === 'string' && data.error.trim()) ||
        (typeof textBody === 'string' && textBody.trim()) ||
        `HTTP_${resp.status}`;
      throw new Error(serverMsg);
    }

    if (data?.error) throw new Error(data.error);

    if (!data || typeof data !== 'object') {
      throw new Error('Invalid OCR response from server.');
    }

    return data;
  }

  async function processFile(file: File) {
    hideError();
    resultPanel!.classList.remove('visible');
    statusEl!.classList.add('visible');
    statusText!.textContent = `Uploading ${file.name}...`;

    try {
      const base64 = await fileToBase64(file);
      const mode = regions.length > 0 ? 'regions' : 'normal';
      const data = await submitOCR(base64, mode, regions, file.name);

      lastResult = { ...data, filename: file.name };
      resultText!.textContent = data.text || '(no text recognised)';
      resultMeta!.textContent = `${data.line_count || 0} line${(data.line_count || 0) !== 1 ? 's' : ''} — ${file.name}`;
      resultPanel!.classList.add('visible');
    } catch (err: any) {
      showError(err.message);
    } finally {
      statusEl!.classList.remove('visible');
    }
  }

  function resizeImage(file: File, maxDim = 2000): Promise<string | null> {
    return new Promise((resolve, reject) => {
      if (file.type === 'application/pdf') { resolve(null); return; }
      const reader = new FileReader();
      reader.onerror = reject;
      reader.onload = () => {
        const img = new Image();
        img.onerror = reject;
        img.onload = () => {
          if (img.width <= maxDim && img.height <= maxDim && file.size < 2 * 1024 * 1024) {
            resolve(null); return;
          }
          const scale = Math.min(maxDim / img.width, maxDim / img.height, 1);
          const w = Math.round(img.width * scale);
          const h = Math.round(img.height * scale);
          const c = document.createElement('canvas');
          c.width = w; c.height = h;
          c.getContext('2d')!.drawImage(img, 0, 0, w, h);
          resolve(c.toDataURL('image/jpeg', 0.85).split(',')[1]);
        };
        img.src = reader.result as string;
      };
      reader.readAsDataURL(file);
    });
  }

  async function fileToBase64(file: File): Promise<string> {
    const resized = await resizeImage(file);
    if (resized) return resized;
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = () => resolve((reader.result as string).split(',')[1]);
      reader.onerror = reject;
      reader.readAsDataURL(file);
    });
  }

  // ── Result buttons ──
  document.getElementById('btn-copy')!.addEventListener('click', () => {
    if (!lastResult) return;
    navigator.clipboard.writeText(lastResult.text).then(() => showToast('Copied to clipboard!'));
  });
  document.getElementById('btn-download')!.addEventListener('click', () => {
    if (!lastResult) return;
    const blob = new Blob([lastResult.text], { type: 'text/plain;charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a'); a.href = url;
    a.download = (lastResult.filename || 'ocr').replace(/\.[^.]+$/, '') + '_ocr.txt';
    a.click(); URL.revokeObjectURL(url);
  });
  document.getElementById('btn-clear')!.addEventListener('click', () => {
    resultPanel!.classList.remove('visible');
    lastResult = null; currentFile = null; loadedImage = null; regions = [];
    fileInput.value = '';
    regionEditor!.classList.remove('visible');
    dropZone!.style.display = '';
  });

  // ── Save Template ──
  const templateDialog = document.getElementById('template-dialog')!;
  const templateNameInput = document.getElementById('template-name-input') as HTMLInputElement;

  document.getElementById('btn-save-template')!.addEventListener('click', () => {
    if (regions.length === 0) return;
    templateNameInput.value = '';
    templateDialog.classList.add('visible');
    templateNameInput.focus();
  });
  document.getElementById('btn-template-cancel')!.addEventListener('click', () => templateDialog.classList.remove('visible'));
  templateNameInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') document.getElementById('btn-template-save')!.click();
    if (e.key === 'Escape') templateDialog.classList.remove('visible');
  });
  document.getElementById('btn-template-save')!.addEventListener('click', () => {
    const name = templateNameInput.value.trim();
    if (!name) { templateNameInput.classList.add('error'); setTimeout(() => templateNameInput.classList.remove('error'), 600); return; }
    _templates[name] = JSON.parse(JSON.stringify(regions));
    templateDialog.classList.remove('visible');
    showToast(`Template "${name}" saved (${regions.length} regions)`);
  });

  // ── Batch OCR ──
  function loadTemplateList() {
    const listEl = document.getElementById('template-list')!;
    const noEl = document.getElementById('batch-no-templates')!;
    const names = Object.keys(_templates);
    if (names.length === 0) {
      noEl.style.display = ''; listEl.innerHTML = '';
      document.getElementById('batch-upload-section')!.style.display = 'none';
      return;
    }
    noEl.style.display = 'none';
    listEl.innerHTML = names.map(n =>
      `<button class="ocr-template-card ${selectedTemplate === n ? 'selected' : ''}" data-name="${n}">
        <span class="ocr-template-name">${n}</span>
        <span class="ocr-template-meta">${_templates[n].length} regions</span>
      </button>`
    ).join('');
    listEl.querySelectorAll('.ocr-template-card').forEach(card => {
      card.addEventListener('click', () => {
        selectedTemplate = (card as HTMLElement).dataset.name!;
        listEl.querySelectorAll('.ocr-template-card').forEach(c => c.classList.remove('selected'));
        card.classList.add('selected');
        document.getElementById('batch-upload-section')!.style.display = '';
      });
    });
  }

  const batchDropZone = document.getElementById('batch-drop-zone')!;
  const batchFileInput = document.getElementById('batch-file-input') as HTMLInputElement;
  batchDropZone.addEventListener('click', () => batchFileInput.click());
  batchDropZone.addEventListener('dragover', (e) => { e.preventDefault(); batchDropZone.classList.add('drag-over'); });
  batchDropZone.addEventListener('dragleave', () => batchDropZone.classList.remove('drag-over'));
  batchDropZone.addEventListener('drop', (e) => {
    e.preventDefault(); batchDropZone.classList.remove('drag-over');
    if (e.dataTransfer?.files.length) addBatchFiles(e.dataTransfer.files);
  });
  batchFileInput.addEventListener('change', () => { if (batchFileInput.files?.length) addBatchFiles(batchFileInput.files); });

  function addBatchFiles(fileList: FileList) {
    for (const f of fileList) { if (!batchFiles.some(bf => bf.name === f.name && bf.size === f.size)) batchFiles.push(f); }
    updateBatchFileList();
  }

  function updateBatchFileList() {
    const listEl = document.getElementById('batch-file-list')!;
    if (batchFiles.length === 0) {
      listEl.innerHTML = '';
      document.getElementById('batch-process-section')!.style.display = 'none';
      return;
    }
    listEl.innerHTML = batchFiles.map((f, i) =>
      `<div class="ocr-batch-file-item"><span class="ocr-batch-file-name">${f.name}</span><button class="ocr-batch-file-remove" data-idx="${i}">&times;</button></div>`
    ).join('');
    listEl.querySelectorAll('.ocr-batch-file-remove').forEach(btn => {
      btn.addEventListener('click', () => { batchFiles.splice(parseInt((btn as HTMLElement).dataset.idx!), 1); updateBatchFileList(); });
    });
    document.getElementById('batch-process-section')!.style.display = '';
    document.getElementById('btn-batch-process')!.textContent = `Process ${batchFiles.length} Page${batchFiles.length !== 1 ? 's' : ''}`;
  }

  document.getElementById('btn-batch-process')!.addEventListener('click', async () => {
    if (!selectedTemplate || batchFiles.length === 0) return;
    hideError();
    const progressSection = document.getElementById('batch-progress-section')!;
    const progressFill = document.getElementById('batch-progress-fill') as HTMLElement;
    const progressText = document.getElementById('batch-progress-text')!;
    const resultsSection = document.getElementById('batch-results-section')!;
    const resultsEl = document.getElementById('batch-results')!;
    document.getElementById('batch-process-section')!.style.display = 'none';
    progressSection.style.display = ''; resultsSection.style.display = 'none';
    batchResults = [];
    const templateRegions = _templates[selectedTemplate];
    for (let i = 0; i < batchFiles.length; i++) {
      progressFill.style.width = ((i) / batchFiles.length * 100) + '%';
      progressText.textContent = `Processing ${batchFiles[i].name} (${i + 1}/${batchFiles.length})...`;
      try {
        const b64 = await fileToBase64(batchFiles[i]);
        const data = await submitOCR(b64, 'regions', templateRegions, batchFiles[i].name);
        batchResults.push({ filename: batchFiles[i].name, text: data.text || '', lines: data.line_count || 0 });
      } catch (err: any) {
        batchResults.push({ filename: batchFiles[i].name, text: '', error: err.message });
      }
    }
    progressFill.style.width = '100%';
    progressText.textContent = `Done — ${batchResults.length} pages processed`;
    resultsEl.innerHTML = batchResults.map(r =>
      `<div class="ocr-batch-result-item ${r.error ? 'has-error' : ''}">
        <div class="ocr-batch-result-header">
          <span class="ocr-batch-result-filename">${r.filename}</span>
          <span class="ocr-batch-result-meta">${r.error ? 'Error' : r.lines + ' lines'}</span>
        </div>
        <div class="ocr-batch-result-text">${r.error ? r.error : (r.text || '(no text)')}</div>
      </div>`
    ).join('');
    resultsSection.style.display = '';
    setTimeout(() => { progressSection.style.display = 'none'; }, 1500);
  });

  document.getElementById('btn-batch-copy-all')!.addEventListener('click', () => {
    const all = batchResults.filter(r => r.text).map(r => `=== ${r.filename} ===\n${r.text}`).join('\n\n');
    navigator.clipboard.writeText(all).then(() => showToast('All results copied!'));
  });
  document.getElementById('btn-batch-download-all')!.addEventListener('click', () => {
    const all = batchResults.filter(r => r.text).map(r => `=== ${r.filename} ===\n${r.text}`).join('\n\n');
    const blob = new Blob([all], { type: 'text/plain;charset=utf-8' });
    const url = URL.createObjectURL(blob); const a = document.createElement('a');
    a.href = url; a.download = `batch_ocr_${selectedTemplate}.txt`; a.click(); URL.revokeObjectURL(url);
  });
  document.getElementById('btn-batch-clear')!.addEventListener('click', () => {
    batchFiles = []; batchResults = []; selectedTemplate = null;
    ['batch-results-section','batch-progress-section','batch-upload-section','batch-process-section']
      .forEach(id => document.getElementById(id)!.style.display = 'none');
    document.getElementById('batch-file-list')!.innerHTML = '';
    batchFileInput.value = '';
    loadTemplateList();
  });

  // ── Helpers ──
  function showError(msg: string) {
    let friendly: string;
    let isTrustedHtml = true;
    if (msg === 'MIXED_CONTENT_BLOCKED') {
      friendly = 'The OCR request was blocked by the browser because the site is HTTPS but the OCR API is HTTP.<br><span style="color:var(--muted);font-size:.82rem">Switch the OCR endpoint to HTTPS (or route through a same-origin API) to fix this.</span>';
    } else if (msg === 'HTTP_413') {
      friendly = 'The server rejected this file because it is too large (HTTP 413).<br><span style="color:var(--muted);font-size:.82rem">Reduce file size or increase upload limits in your Hetzner Docker/reverse-proxy setup.</span>';
    } else if (msg === 'HTTP_429' || msg.toLowerCase().includes('rate') || msg.toLowerCase().includes('too many')) {
      friendly = 'You\'ve hit the OCR rate limit (HTTP 429).<br><span style="color:var(--muted);font-size:.82rem">TermaOCR beta allows limited requests per minute.</span>';
    } else if (msg === 'HTTP_5XX_OVERLOADED') {
      friendly = 'The OCR server is temporarily overloaded (HTTP 503/504).<br><span style="color:var(--muted);font-size:.82rem">Please retry shortly or check Docker/container resource usage on Hetzner.</span>';
    } else if (msg === 'REQUEST_TIMEOUT') {
      friendly = 'The OCR request timed out while waiting for the server response.<br><span style="color:var(--muted);font-size:.82rem">This usually means a large file, slow OCR processing, or server load.</span>';
    } else if (msg === 'REQUEST_FAILED' || msg === 'Failed to fetch') {
      friendly = 'This file may be too large to process.<br><span style="color:var(--muted);font-size:.82rem">TermaOCR is currently in beta with rate limits — for unlimited access, please contact the Terma Foundry team.</span>';
    } else {
      friendly = msg;
      isTrustedHtml = false;
    }
    if (isTrustedHtml) {
      errorMsg!.innerHTML = friendly;
    } else {
      errorMsg!.textContent = friendly;
    }
    errorMsg!.classList.add('visible');
  }
  function hideError() { errorMsg!.classList.remove('visible'); }
  function showToast(msg: string) { toast!.textContent = msg; toast!.classList.add('show'); setTimeout(() => toast!.classList.remove('show'), 2000); }

  // ── Try Sample ──
  document.getElementById('btn-try-sample')!.addEventListener('click', async () => {
    try {
      const resp = await fetch('/samples/pecha-sample.jpg');
      const blob = await resp.blob();
      handleFile(new File([blob], 'pecha-sample.jpg', { type: 'image/jpeg' }));
    } catch (err) { showError('Failed to load sample image.'); }
  });
</script>
