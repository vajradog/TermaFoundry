---
import SiteLayout from '@layouts/SiteLayout.astro';
---

<SiteLayout title="404 — Page Not Found">
  <section class="page-section" style="min-height: 60vh; display: flex; align-items: center;">
    <div class="not-found reveal">
      <div class="not-found-code">404</div>
      <h1 class="not-found-heading">Page not found.</h1>
      <p class="not-found-sub">The page you're looking for doesn't exist or may have moved.</p>
      <div class="not-found-actions">
        <a href="/" class="btn btn-primary">← Back to Home</a>
        <a href="/termaui/" class="btn btn-ghost">Explore termaUI</a>
        <a href="/fonts" class="btn btn-ghost">Font Library</a>
      </div>
      <div class="not-found-tibetan tr-jomolhari tr-text-saffron tr-guard" lang="bo">མི་རྙེད།</div>
    </div>
  </section>
</SiteLayout>

<style>
  .not-found { max-width: 560px; }
  .not-found-code {
    font-size: 7rem; font-weight: 900; letter-spacing: -.05em;
    color: var(--border2); line-height: 1; margin-bottom: 1rem;
  }
  .not-found-heading {
    font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 800;
    letter-spacing: -.035em; color: var(--text); margin-bottom: .75rem;
  }
  .not-found-sub { font-size: .97rem; color: var(--muted); line-height: 1.75; margin-bottom: 2rem; }
  .not-found-actions { display: flex; gap: .75rem; flex-wrap: wrap; margin-bottom: 2.5rem; }
  .not-found-tibetan { font-size: 2rem; opacity: .25; }
</style>
