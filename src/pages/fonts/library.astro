    color: var(--muted);
    min-width: 34px;
    text-align: right;
    flex-shrink: 0;
  }

  .size-slider {
    -webkit-appearance: none;
    appearance: none;
    width: 110px;
    height: 3px;
    background: var(--border2);
    border-radius: 2px;
    outline: none;
    cursor: pointer;
    flex-shrink: 0;
  }
  .size-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--accent);
    cursor: pointer;
    transition: background .15s;
  }
  .size-slider::-webkit-slider-thumb:hover { background: #7dd3fc; }
  .size-slider::-moz-range-thumb {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--accent);
    border: none;
    cursor: pointer;
  }

  /* ─ Keyboard map panel ───────────────────────────────────────────── */
  .kbd-map {
    border-top: 1px solid var(--border);
    background: var(--surface);
  }
  .kbd-map-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: .9rem 2rem 1rem;
  }
  .kbd-map-header {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: .65rem;
  }
  .kbd-map-title {
    font-size: .65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--accent);
    white-space: nowrap;
  }
  .kbd-map-sub {
    font-size: .7rem;
    color: var(--muted);
  }
  .kbd-map-grid {
    display: flex;
    flex-wrap: wrap;
    gap: .3rem;
    margin-bottom: .7rem;
  }
  .kbd-cell {
    display: inline-flex;
    align-items: center;
    gap: .22rem;
    padding: .18rem .5rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 5px;
    cursor: default;
    transition: border-color .1s;
  }
  .kbd-cell:hover { border-color: var(--border2); }
  .kbd-key {
    font-family: 'JetBrains Mono', monospace;
    font-size: .68rem;
    color: var(--muted);
    min-width: .75rem;
    text-align: center;
  }
  .kbd-char {
    font-family: 'Jomolhari', serif;
    font-size: 1.05rem;
    color: var(--text);
    line-height: 1.4;
  }
  .kbd-name {
    font-size: .62rem;
    color: var(--muted);
    display: none;
  }
  .kbd-map-footer {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    font-size: .74rem;
    color: var(--text2);
    line-height: 2;
  }
  .kbd-map-footer strong { color: var(--text); }

  /* ─ Responsive ───────────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .preview-input { font-size: 1.15rem; }
    .preview-toolbar { gap: .5rem; }
    .size-slider { width: 80px; }
  }
  @media (max-width: 600px) {
    .preview-bar-inner { padding: .7rem 1.25rem; }
    .preview-input-row { gap: .4rem; }
    .preview-input { font-size: 1rem; padding-left: 2.2rem; }
    .preview-cursor-icon { left: .7rem; font-size: .9rem; }
    .ime-toggle .ime-status-on { display: none; }
    .size-slider { width: 60px; }
    .kbd-map-inner { padding: .75rem 1.25rem; }
  }
</style>

<script is:inline>
(function () {
  'use strict';

  // ─── Tibetan IME key map (Monlam / Keyman phonetic QWERTY) ─────────────────
  var IME_MAP = {
    'k':'\u0F40','[':'\u0F41','g':'\u0F42',',':'\u0F44',
    'c':'\u0F45','x':'\u0F46','j':'\u0F47','.':'\u0F49',
    't':'\u0F4F',']':'\u0F50','d':'\u0F51','n':'\u0F53',
    'p':'\u0F54','f':'\u0F55','b':'\u0F56','m':'\u0F58',
    ';':'\u0F59',':':'\u0F5A','\\':'\u0F5B','v':'\u0F5D',
    'w':'\u0F5E','z':'\u0F5F',"'":'\u0F60','y':'\u0F61',
    'r':'\u0F62','l':'\u0F63','q':'\u0F64','s':'\u0F66',
    'h':'\u0F67','a':'\u0F68',
    'i':'\u0F72','u':'\u0F74','e':'\u0F7A','o':'\u0F7C',
    ' ':'\u0F0B','/':'\u0F0D','-':'\u0F0C',
    '0':'\u0F20','1':'\u0F21','2':'\u0F22','3':'\u0F23','4':'\u0F24',
    '5':'\u0F25','6':'\u0F26','7':'\u0F27','8':'\u0F28','9':'\u0F29',
    'K':'\u0F90','G':'\u0F92','C':'\u0F95','X':'\u0F96','J':'\u0F97',
    'T':'\u0F9F','D':'\u0FA1','N':'\u0FA3','P':'\u0FA4','B':'\u0FA6',
    'M':'\u0FA8','V':'\u0FAD','W':'\u0FAE','Z':'\u0FAF',
    'Y':'\u0FB1','R':'\u0FB2','L':'\u0FB3','Q':'\u0FB4',
    'S':'\u0FB6','H':'\u0FB7','A':'\u0FB8'
  };

  var PASS = {
    'Backspace':1,'Delete':1,'ArrowLeft':1,'ArrowRight':1,'ArrowUp':1,'ArrowDown':1,
    'Home':1,'End':1,'PageUp':1,'PageDown':1,'Tab':1,'Enter':1,'Escape':1,
    'F1':1,'F2':1,'F3':1,'F4':1,'F5':1,'F6':1,'F7':1,'F8':1,'F9':1,'F10':1,'F11':1,'F12':1,
    'CapsLock':1,'Shift':1,'Control':1,'Alt':1,'Meta':1,'AltGraph':1
  };

  function imeInsert(el, ch) {
    var s = el.selectionStart != null ? el.selectionStart : el.value.length;
    var e = el.selectionEnd   != null ? el.selectionEnd   : el.value.length;
    el.value = el.value.slice(0, s) + ch + el.value.slice(e);
    var pos = s + ch.length;
    el.setSelectionRange(pos, pos);
    el.dispatchEvent(new Event('input', { bubbles: true }));
  }

  function imeHandler(ev) {
    if (ev.ctrlKey || ev.metaKey || ev.altKey) return;
    if (PASS[ev.key]) return;
    var ch = IME_MAP[ev.key];
    if (ch !== undefined) { ev.preventDefault(); imeInsert(ev.target, ch); }
  }

  // ─── DOM refs ───────────────────────────────────────────────────────────────
  var previewInput = document.getElementById('preview-input');
  var sizeSlider   = document.getElementById('size-slider');
  var sizeValue    = document.getElementById('size-value');
  var imeToggle    = document.getElementById('ime-toggle');
  var kbdHelpBtn   = document.getElementById('kbd-help-btn');
  var kbdMap       = document.getElementById('kbd-map');
  var kbdMapGrid   = document.getElementById('kbd-map-grid');
  var phraseClr    = document.getElementById('phrase-clear');
  var phraseBtns   = document.querySelectorAll('.phrase-btn');
  var livePreviews = document.querySelectorAll('[data-live-preview]');

  if (!previewInput) return;

  // ─── IME: attach by default ─────────────────────────────────────────────────
  var imeActive = true;
  previewInput.addEventListener('keydown', imeHandler);

  // ─── Sync initial font size from slider value ────────────────────────────────
  updateSize(parseInt(sizeSlider.value, 10));

  // ─── Update all live preview samples ────────────────────────────────────────
  function updatePreviews(text) {
    livePreviews.forEach(function (el) {
      el.textContent = (text && text.length > 0) ? text : (el.dataset.default || '');
    });
  }

  // ─── Update font-size on main display samples only ──────────────────────────
  function updateSize(px) {
    sizeValue.textContent = px + 'px';
    document.querySelectorAll('.font-sample-long[data-live-preview]').forEach(function (el) {
      el.style.fontSize = px + 'px';
    });
  }

  // ─── Input → live preview ───────────────────────────────────────────────────
  previewInput.addEventListener('input', function () {
    updatePreviews(previewInput.value);
  });

  // ─── Size slider ────────────────────────────────────────────────────────────
  sizeSlider.addEventListener('input', function () {
    updateSize(parseInt(sizeSlider.value, 10));
  });

  // ─── IME toggle ─────────────────────────────────────────────────────────────
  imeToggle.addEventListener('click', function () {
    imeActive = !imeActive;
    if (imeActive) {
      previewInput.addEventListener('keydown', imeHandler);
      imeToggle.classList.add('active');
    } else {
      previewInput.removeEventListener('keydown', imeHandler);
      imeToggle.classList.remove('active');
    }
    previewInput.focus();
  });

  // ─── Keyboard hint panel (lazy-built on first open) ─────────────────────────
  var kbdBuilt = false;

  function buildKbdGrid() {
    if (kbdBuilt) return;
    kbdBuilt = true;
    var entries = [
      ['k','\u0F40','ka'],     ['[','\u0F41','kha'],   ['g','\u0F42','ga'],    [',','\u0F44','nga'],
      ['c','\u0F45','ca'],     ['x','\u0F46','cha'],   ['j','\u0F47','ja'],    ['.','\u0F49','nya'],
      ['t','\u0F4F','ta'],     [']','\u0F50','tha'],   ['d','\u0F51','da'],    ['n','\u0F53','na'],
      ['p','\u0F54','pa'],     ['f','\u0F55','pha'],   ['b','\u0F56','ba'],    ['m','\u0F58','ma'],
      [';','\u0F59','tsa'],    [':','\u0F5A','tsha'],  ['\\','\u0F5B','dza'],  ['v','\u0F5D','wa'],
      ['w','\u0F5E','zha'],    ['z','\u0F5F','za'],    ["'",'\u0F60',"'a"],    ['y','\u0F61','ya'],
      ['r','\u0F62','ra'],     ['l','\u0F63','la'],    ['q','\u0F64','sha'],   ['s','\u0F66','sa'],
      ['h','\u0F67','ha'],     ['a','\u0F68','a']
    ];
    var frag = document.createDocumentFragment();
    entries.forEach(function (entry) {
      var cell = document.createElement('span');
      cell.className = 'kbd-cell';
      cell.title = entry[2];
      cell.innerHTML =
        '<span class="kbd-key">' + entry[0] + '</span>' +
        '<span class="kbd-char">' + entry[1] + '</span>';
      frag.appendChild(cell);
    });
    kbdMapGrid.appendChild(frag);
  }

  kbdHelpBtn.addEventListener('click', function () {
    kbdMap.hidden = !kbdMap.hidden;
    kbdHelpBtn.classList.toggle('active', !kbdMap.hidden);
    if (!kbdMap.hidden) buildKbdGrid();
  });

  // ─── Quick phrase buttons ───────────────────────────────────────────────────
  phraseBtns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      var text = btn.dataset.text || '';
      previewInput.value = text;
      updatePreviews(text);
      previewInput.focus();
    });
  });

  phraseClr.addEventListener('click', function () {
    previewInput.value = '';
    updatePreviews('');
    previewInput.focus();
  });

  // ─── Auto-focus input after page settles ────────────────────────────────────
  setTimeout(function () { previewInput.focus(); }, 350);

})();
</script>
