---
import FontsBase from '@layouts/FontsBase.astro';

const sample = {
  long:  'བཅོམ་ལྡན་འདས་མ་ཤེས་རབ་ཀྱི་ཕ་རོལ་ཏུ་ཕྱིན་པའི་སྙིང་པོ།',
  short: 'བཀྲ་ཤིས་བདེ་ལེགས།',
  alpha: 'ཀ་ཁ་ག་ང་ཅ་ཆ་ཇ་ཉ་ཏ་ཐ་ད་ན་པ་ཕ་བ་མ་ཙ་ཚ་ཛ་ཝ་ཞ་ཟ་འ་ཡ་ར་ལ་ཤ་ས་ཧ་ཨ།',
};

const uchen = [
  {
    name: 'Jomolhari',
    cls: 'tr-jomolhari',
    author: 'Christopher J. Fynn',
    license: 'SIL OFL',
    licenseUrl: 'https://openfontlicense.org/',
    desc: 'The workhorse of Tibetan digital typography. Warm, classical Uchen manuscript strokes — the closest digital equivalent to hand-written religious texts. Suited to body text, liturgical content, and long-form reading.',
    useCase: 'Body text · Liturgical · Manuscripts · Long-form',
  },
  {
    name: 'DDC Uchen',
    cls: 'tr-ddc-uchen',
    author: 'Christopher J. Fynn / Dzongkha Development Commission',
    license: 'SIL OFL',
    licenseUrl: 'https://openfontlicense.org/',
    desc: 'The official Unicode Tibetan font developed for the government of Bhutan. Clean, authoritative Uchen strokes used by Kuensel (Bhutan\'s national newspaper). Excellent Unicode coverage for both Tibetan and Dzongkha.',
    useCase: 'Official documents · News · Bilingual publishing · Dzongkha',
  },
  {
    name: 'BabelStone Tibetan',
    cls: 'tr-babelstone',
    author: 'Andrew West / BabelStone',
    license: 'SIL OFL',
    licenseUrl: 'https://openfontlicense.org/',
    desc: 'One of the broadest-coverage Tibetan Unicode fonts available. Designed specifically to support the full Unicode Tibetan block — ideal for scholarly work, rare script forms, and texts with complex consonant stacks that defeat other fonts.',
    useCase: 'Scholarly · Wide Unicode coverage · Rare stacks · Research',
  },
  {
    name: 'BabelStone Tibetan Slim',
    cls: 'tr-babelstone-slim',
    author: 'Andrew West / BabelStone',
    license: 'SIL OFL',
    licenseUrl: 'https://openfontlicense.org/',
    desc: 'A reduced-line-height variant of BabelStone Tibetan. The Slim version trades the extreme headroom for more compact layout — better for ordinary modern Tibetan text where mantra-depth stacks are rare.',
    useCase: 'Modern text · Compact layout · Digital · Web body',
  },
  {
    name: 'Noto Serif Tibetan',
    cls: 'tr-noto',
    author: 'Google Fonts',
    license: 'SIL OFL',
    licenseUrl: 'https://openfontlicense.org/',
    desc: 'Google\'s modern Tibetan serif — screen-optimised, consistently rendered, and built to international Unicode standards. The only available Tibetan font with a full weight axis (Thin through Black). Excellent for apps, digital interfaces, and multilingual layouts.',
    useCase: 'Digital interfaces · Apps · Web · Small-size rendering',
    hasWeights: true,
  },
  {
    name: 'Tibetan Machine Uni',
    cls: 'tr-machine-uni',
    author: 'Tibetan & Himalayan Library (THDL)',
    license: 'GPL v2',
    licenseUrl: 'https://www.gnu.org/licenses/old-licenses/gpl-2.0.html',
    desc: 'Bold, high-contrast strokes built for display and headline use. Impactful and authoritative — excellent for navigation labels, headings, and poster-scale titles. Wide Unicode coverage. The traditional heavyweight of Tibetan digital typography.',
    useCase: 'Headlines · Display · Navigation · Print titles · Signage',
  },
  {
    name: 'Monlam Bodyig',
    cls: 'tr-monlam',
    author: 'Monlam AI',
    license: 'Open',
    licenseUrl: 'https://monlam.ai/',
    desc: 'Refined thin strokes with elegant proportions. A graceful literary Uchen — where the text recedes and the meaning speaks. Suited to poetry collections, literary publications, and long-form reading where a quieter aesthetic is needed.',
    useCase: 'Literary · Poetry · Elegant long-form · Publications',
  },
  {
    name: 'GangJie Uchen',
    cls: 'tr-gangjie',
    author: 'Gangjie Project',
    license: 'Open',
    licenseUrl: 'https://github.com/OpenPecha/tibetan-fonts',
    desc: 'A clean, even-stroked modern Uchen. Consistent stroke weight and neutral character make it a solid choice for interface labels, forms, and anywhere that text needs to be readable without demanding attention.',
    useCase: 'UI labels · Forms · Digital neutral · Interface text',
  },
  {
    name: 'Jamyang Monlam Uchen',
    cls: 'tr-jamyang',
    author: 'Monlam AI',
    license: 'Open',
    licenseUrl: 'https://monlam.ai/',
    desc: 'An Uchen with strong calligraphic character — noticeable contrast between thick and thin strokes gives it a sculptural quality. Works well at larger sizes where that stroke personality can be appreciated.',
    useCase: 'Headings · Large display · Calligraphic feel · Print',
  },
  {
    name: 'Panchen Tsukring',
    cls: 'tr-panchen',
    author: 'Open Pecha Project',
    license: 'Open',
    licenseUrl: 'https://github.com/OpenPecha/tibetan-fonts',
    desc: 'Traditional Uchen with extended vertical proportions — the tsukring (long-headed) style with taller ascenders. A formal, classical appearance suited to religious and ceremonial texts.',
    useCase: 'Religious texts · Formal · Ceremonial · Traditional publishing',
  },
  {
    name: 'Riwoche Dhodri',
    cls: 'tr-riwoche',
    author: 'Open Pecha Project',
    license: 'Open',
    licenseUrl: 'https://github.com/OpenPecha/tibetan-fonts',
    desc: 'A woodblock-print-inspired Uchen with the yigchen quality of traditional xylographic printing. Ink-spread character and slightly rough edges evoke centuries of block-printed scripture.',
    useCase: 'Heritage publishing · Display · Woodblock aesthetic · Titles',
  },
  {
    name: 'Sadri Yigchen',
    cls: 'tr-sadri',
    author: 'Sadri Project',
    license: 'Open',
    licenseUrl: 'https://github.com/OpenPecha/tibetan-fonts',
    desc: 'Clean, well-proportioned formal Uchen from the Sadri collection. Balanced stroke weights — solid for body text, textbooks, and educational materials where legibility at smaller sizes matters.',
    useCase: 'Education · Textbooks · Body text · Learning materials',
  },
  {
    name: 'DDC Rinzin',
    cls: 'tr-ddc-rinzin',
    author: 'Christopher J. Fynn / DDC',
    license: 'SIL OFL',
    licenseUrl: 'https://openfontlicense.org/',
    desc: 'A decorative Uchen with distinctive calligraphic character developed alongside DDC Uchen. Expressive stroke endings and refined proportions make it a standout display face for titles and artistic applications.',
    useCase: 'Display · Titles · Artistic · Invitations · Decorative',
  },
  {
    name: 'Monlam Uni OuChan1',
    cls: 'tr-monlam-ouchan1',
    author: 'Monlam AI',
    license: 'Open',
    licenseUrl: 'https://monlam.ai/',
    desc: 'The reference Uchen from Monlam AI\'s OuChan series — clean, well-proportioned strokes with strong Unicode coverage. Designed for screen legibility at body text sizes with consistent weight across the full Tibetan block.',
    useCase: 'Body text · Digital · Apps · Screen · General purpose',
  },
  {
    name: 'Monlam Uni OuChan2',
    cls: 'tr-monlam-ouchan2',
    author: 'Monlam AI',
    license: 'Open',
    licenseUrl: 'https://monlam.ai/',
    desc: 'Second variant of Monlam AI\'s OuChan Uchen series. Slightly different stroke contrast and proportions — a softer, more open feel suited to textbooks and educational content.',
    useCase: 'Education · Textbooks · Digital body · Reading',
  },
  {
    name: 'Monlam Uni OuChan3',
    cls: 'tr-monlam-ouchan3',
    author: 'Monlam AI',
    license: 'Open',
    licenseUrl: 'https://monlam.ai/',
    desc: 'Third variant in the OuChan series. A slightly bolder stroke character — sits well in paragraph text for printed materials and longer documents where a firm, confident presence is needed.',
    useCase: 'Print · Publications · Body text · Documents',
  },
  {
    name: 'Monlam Uni OuChan4',
    cls: 'tr-monlam-ouchan4',
    author: 'Monlam AI',
    license: 'Open',
    licenseUrl: 'https://monlam.ai/',
    desc: 'Fourth OuChan variant with refined proportions and clean geometry. Particularly suited to UI text, labels, and interface elements where Uchen needs to coexist with Latin or CJK typography.',
    useCase: 'UI labels · Multilingual · Interface · Digital',
  },
  {
    name: 'Monlam Uni OuChan5',
    cls: 'tr-monlam-ouchan5',
    author: 'Monlam AI',
    license: 'Open',
    licenseUrl: 'https://monlam.ai/',
    desc: 'Fifth and final OuChan variant — the most distinctive of the series. Strong character with deliberate stroke contrast. Works well at display sizes for headings and pull quotes.',
    useCase: 'Headings · Display · Pull quotes · Larger sizes',
  },
  {
    name: 'Monlam Uni PayTsik',
    cls: 'tr-monlam-paytsik',
    author: 'Monlam AI',
    license: 'Open',
    licenseUrl: 'https://monlam.ai/',
    desc: 'PayTsik (ཕྱག་རྩིག) — a formal seal/stamp-style Uchen with compact, authoritative letterforms. Traditionally used for official seals, colophons, and ceremonial inscriptions. High visual density and gravitas.',
    useCase: 'Seals · Colophons · Official · Ceremonial · Headings',
  },
  {
    name: 'Monlam Uni Tikrang',
    cls: 'tr-monlam-tikrang',
    author: 'Monlam AI',
    license: 'Open',
    licenseUrl: 'https://monlam.ai/',
    desc: 'Tikrang (ཏིག་རིང) — an ornamental Uchen with extended, flowing vertical strokes. The extra height gives it a regal, architecturally impressive quality suited to large-scale display and illuminated titles.',
    useCase: 'Ornamental · Large display · Illuminated titles · Print',
  },
  {
    name: 'Monlam Uni TikTong',
    cls: 'tr-monlam-tiktong',
    author: 'Monlam AI',
    license: 'Open',
    licenseUrl: 'https://monlam.ai/',
    desc: 'TikTong (ཏིག་ཐུང) — an ornamental Uchen with compact, squared proportions. Dense and decorative, with strong visual weight. Effective for chapter headings, short display text, and woodblock-inspired layouts.',
    useCase: 'Display · Chapter headings · Decorative · Print',
  },
  {
    name: 'Qomolangma-UchenSarchen',
    cls: 'tr-qomolangma-sarchen',
    author: 'THDL / Qomolangma Project',
    license: 'Open',
    licenseUrl: 'https://github.com/OpenPecha/tibetan-fonts',
    desc: 'Sarchen (སར་ཆེན) — "large script" Uchen from the THDL Qomolangma series. Grand proportions and generous strokes give it an imposing classical quality — the typeface of monastery inscriptions and large-format printing.',
    useCase: 'Large format · Monastery texts · Print titles · Classical',
  },
  {
    name: 'Qomolangma-Betsu',
    cls: 'tr-qomolangma-betsu',
    author: 'THDL / Qomolangma Project',
    license: 'Open',
    licenseUrl: 'https://github.com/OpenPecha/tibetan-fonts',
    desc: 'Betsu — a compact, abbreviated Uchen variant from the Qomolangma series. Shorter letterforms with slightly compressed proportions — efficient for annotations, captions, yig-chung positions, and tight-space layouts.',
    useCase: 'Annotations · Captions · Compact layouts · Yig-chung',
  },
  {
    name: 'Qomolangma-Tsutong',
    cls: 'tr-qomolangma-tsutong',
    author: 'THDL / Qomolangma Project',
    license: 'Open',
    licenseUrl: 'https://github.com/OpenPecha/tibetan-fonts',
    desc: 'Tsutong (གཙུག་ཐུང) — "short-headed" Uchen with reduced ascender height for more compact text blocks. A modern, efficient Uchen suited to digital interfaces where tight line-heights are required.',
    useCase: 'UI · Compact digital text · Labels · Modern interfaces',
  },
];

const drutsa = [
  {
    name: 'Qomolangma-Drutsa',
    cls: 'tr-drutsa',
    author: 'THDL / Qomolangma Project',
    license: 'Open',
    licenseUrl: 'https://github.com/OpenPecha/tibetan-fonts',
    desc: 'Flowing drutsa cursive — the script of correspondence, artistic works, and informal Tibetan writing. Organic, calligraphic, expressive. One of the most widely used drutsa digital fonts.',
    useCase: 'Correspondence · Artistic titles · Cursive display · Informal',
  },
  {
    name: 'GangJie Drutsa',
    cls: 'tr-gangjie-drutsa',
    author: 'Gangjie Project',
    license: 'Open',
    licenseUrl: 'https://github.com/OpenPecha/tibetan-fonts',
    desc: 'A rhythmic drutsa hand with balanced slant and consistent stroke flow. Clean and legible without losing the fluidity that makes drutsa feel alive.',
    useCase: 'Cursive display · Artistic headings · Informal writing',
  },
  {
    name: 'Khampa Dedri Drutsa',
    cls: 'tr-khampa-drutsa',
    author: 'Khampa Dedri Project',
    license: 'Open',
    licenseUrl: 'https://github.com/OpenPecha/tibetan-fonts',
    desc: 'An expressive drutsa hand from the Khampa Dedri family — bolder strokes and more pronounced flowing connections than many drutsa fonts, giving it a lively, energetic character.',
    useCase: 'Display · Artistic · Expressive headings · Posters',
  },
  {
    name: 'Sadri Drutsa',
    cls: 'tr-sadri-drutsa',
    author: 'Sadri Project',
    license: 'Open',
    licenseUrl: 'https://github.com/OpenPecha/tibetan-fonts',
    desc: 'A refined drutsa cursive from the Sadri collection. Elegant flowing forms with good legibility — a drutsa that can be used at body sizes without feeling chaotic.',
    useCase: 'Literary display · Cursive body · Artistic publications',
  },
  {
    name: 'Monlam Uni Dutsa1',
    cls: 'tr-monlam-dutsa1',
    author: 'Monlam AI',
    license: 'Open',
    licenseUrl: 'https://monlam.ai/',
    desc: 'Monlam AI\'s first drutsa variant — a clean, energetic cursive with strong Unicode coverage. Flowing connections and good legibility make it the most versatile of the Monlam Uni cursive family.',
    useCase: 'Display · Titles · Artistic · Correspondence',
  },
  {
    name: 'Monlam Uni Dutsa2',
    cls: 'tr-monlam-dutsa2',
    author: 'Monlam AI',
    license: 'Open',
    licenseUrl: 'https://monlam.ai/',
    desc: 'Second Monlam Uni drutsa variant — a bolder, more expressive cursive character with stronger stroke weight variation. Suited to poster headlines, cover titles, and anywhere cursive needs visual impact.',
    useCase: 'Posters · Bold display · Expressive titles · Large cursive',
  },
];

const modern = [
  {
    name: 'Noto Sans Tibetan',
    cls: 'tr-noto-sans',
    author: 'Google Fonts',
    license: 'SIL OFL',
    licenseUrl: 'https://openfontlicense.org/',
    desc: 'Google\'s Unicode Tibetan sans-serif — the sans companion to Noto Serif Tibetan. Clean, uniform strokes without calligraphic contrast. Excellent for UI, apps, and digital interfaces where a modern neutral feel is preferred over traditional script aesthetics.',
    useCase: 'UI · Apps · Digital interfaces · Modern · Multilingual',
  },
  {
    name: 'MiSans Tibetan',
    cls: 'tr-misans',
    author: 'Xiaomi',
    license: 'Open',
    licenseUrl: 'https://github.com/OpenPecha/tibetan-fonts',
    desc: 'A geometric modern sans-serif developed by Xiaomi for the MiSans system font family. Uniform stroke weight, high x-height, and very good screen rendering at small sizes. Brings a contemporary global-design sensibility to Tibetan typography.',
    useCase: 'System UI · Small sizes · Modern design · Digital products',
  },
  {
    name: 'Monlam Uni Sans',
    cls: 'tr-monlam-sans',
    author: 'Monlam AI',
    license: 'Open',
    licenseUrl: 'https://monlam.ai/',
    desc: 'Monlam AI\'s interpretation of a sans-serif Uchen — the classical headed letterforms translated into a stroke-uniform, sans-serif structure. A unique hybrid that bridges traditional Tibetan script and contemporary typographic conventions.',
    useCase: 'Hybrid aesthetic · Modern Tibetan · Tech · Contemporary',
  },
];

const semicursive = [
  {
    name: 'Joyig',
    cls: 'tr-joyig',
    author: 'Open Pecha Project',
    license: 'Open',
    licenseUrl: 'https://github.com/OpenPecha/tibetan-fonts',
    desc: 'Joyig (འཇོ་ཡིག) sits between Uchen and Drutsa — a semi-formal script with some of the speed of cursive but clearer letterforms. Traditionally used for personal correspondence and informal documents.',
    useCase: 'Semi-formal · Correspondence · Personal writing · Notes',
  },
  {
    name: 'Khampa Dedri Chuyig',
    cls: 'tr-chuyig',
    author: 'Khampa Dedri Project',
    license: 'Open',
    licenseUrl: 'https://github.com/OpenPecha/tibetan-fonts',
    desc: 'Chuyig (ཆུ་ཡིག) — the flowing script of official correspondence and government documents. More structured than drutsa, more personal than formal Uchen. A distinctive rhythmic quality.',
    useCase: 'Official correspondence · Government · Formal letters',
  },
  {
    name: 'Khampa Dedri Bechu',
    cls: 'tr-bechu',
    author: 'Khampa Dedri Project',
    license: 'Open',
    licenseUrl: 'https://github.com/OpenPecha/tibetan-fonts',
    desc: 'Bechu (འབེ་ཆུང) — an informal, simplified script used for everyday handwriting and quick notes. The most relaxed of the Khampa Dedri scripts; casual and approachable.',
    useCase: 'Casual · Notes · Informal writing · Personal',
  },
];

const notoWeights = [
  { label: 'Thin',       cls: 'tr-noto-thin'      },
  { label: 'Light',      cls: 'tr-noto-light'     },
  { label: 'Regular',    cls: 'tr-noto'           },
  { label: 'Medium',     cls: 'tr-noto-medium'    },
  { label: 'SemiBold',   cls: 'tr-noto-semibold'  },
  { label: 'Bold',       cls: 'tr-noto-bold'      },
  { label: 'ExtraBold',  cls: 'tr-noto-extrabold' },
  { label: 'Black',      cls: 'tr-noto-black'     },
];

const totalFonts = uchen.length + modern.length + drutsa.length + semicursive.length;
---

<FontsBase
  title="Tibetan Font Library — termaUI"
  description={`${totalFonts} open-source Tibetan fonts packaged, self-hosted, and web-optimised by Terma Foundry. One CSS class away from any project.`}
>

  <!-- HEADER -->
  <section class="lib-hero">
    <div class="lib-hero-top">
      <div>
        <div class="section-eyebrow reveal">Available Now</div>
        <h1 class="lib-hero-heading reveal">{totalFonts} Tibetan fonts, ready for the web.</h1>
        <p class="lib-hero-sub reveal">
          Open-source Tibetan fonts packaged as WOFF2, self-hosted, one CSS class to use.
        </p>
        <a href="/fonts" class="case-link reveal">The Case for New Tibetan Fonts →</a>
      </div>
      <div class="lib-hero-usage reveal">
        <code class="usage-quick-code">&lt;link rel="stylesheet" href="/dist/termaui.css"&gt;</code>
        <span class="usage-quick-sep">then</span>
        <code class="usage-quick-code">&lt;p class="<strong>tr-jomolhari</strong> tr-guard" lang="bo"&gt;…&lt;/p&gt;</code>
      </div>
    </div>
  </section>

  <!-- ═══════ PREVIEW BAR ═══════ -->
  <div class="preview-bar" id="preview-bar">
    <div class="preview-bar-inner">

      <!-- Row 1: Input + controls -->
      <div class="preview-input-row">
        <div class="preview-input-wrap">
          <span class="preview-cursor-icon" aria-hidden="true">ཀ</span>
          <input
            id="preview-input"
            type="text"
            class="preview-input tr-jomolhari tr-guard"
            placeholder="ཀ་བ་གི་ཉིན་མ།"
            autocomplete="off"
            spellcheck="false"
            lang="bo"
          >
        </div>
        <button class="ime-toggle active" id="ime-toggle" title="Toggle Tibetan keyboard input">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="M6 8h.01M10 8h.01M14 8h.01M18 8h.01M8 12h.01M12 12h.01M16 12h.01M6 16h5M15 16h3"/>
          </svg>
          <span class="ime-status-on">ཀ Tibetan</span>
          <span class="ime-status-off">A Latin</span>
        </button>
        <button class="kbd-help-btn" id="kbd-help-btn" title="Show keyboard layout map">?</button>
      </div>

      <!-- No-install notice -->
      <div class="no-install-notice">No Tibetan keyboard or font installation needed — type directly in your browser using standard keys.</div>

      <!-- Row 2: Quick phrases + size slider -->
      <div class="preview-toolbar">
        <div class="preview-phrases">
          <span class="toolbar-label">Try</span>
          <button class="phrase-btn" data-text="བཅོམ་ལྡན་འདས་མ་ཤེས་རབ་ཀྱི་ཕ་རོལ་ཏུ་ཕྱིན་པའི་སྙིང་པོ།">Heart Sutra</button>
          <button class="phrase-btn" data-text="བཀྲ་ཤིས་བདེ་ལེགས།">བཀྲ་ཤིས</button>
          <button class="phrase-btn" data-text="ཀ་ཁ་ག་ང་ཅ་ཆ་ཇ་ཉ་ཏ་ཐ་ད་ན་པ་ཕ་བ་མ་ཙ་ཚ་ཛ་ཝ་ཞ་ཟ་འ་ཡ་ར་ལ་ཤ་ས་ཧ་ཨ།">Alphabet</button>
          <button class="phrase-btn" data-text="ཨོཾ་མ་ཎི་པདྨེ་ཧཱུྃ།">OM maṇi</button>
          <button class="phrase-btn" data-text="ཀུན་མཁྱེན་ཐུགས་རྗེ་ཆེན་པོ།">Omniscient</button>
          <button class="phrase-clear" id="phrase-clear" title="Clear preview text">✕ Clear</button>
        </div>
        <div class="preview-size-wrap">
          <span class="size-px" id="size-value">28px</span>
          <input type="range" id="size-slider" class="size-slider" min="16" max="72" value="28" step="2">
        </div>
      </div>

    </div>

    <!-- Keyboard map panel (lazy-rendered, hidden by default) -->
    <div class="kbd-map" id="kbd-map" hidden>
      <div class="kbd-map-inner">
        <div class="kbd-map-header">
          <span class="kbd-map-title">Keyboard Layout — Monlam / Keyman Phonetic</span>
          <span class="kbd-map-sub">Shift + key = subjoined consonant for stacking (e.g. R = ྲ ra-ta)</span>
        </div>
        <div class="kbd-map-grid" id="kbd-map-grid"></div>
        <div class="kbd-map-footer">
          <span><strong>Vowels:</strong> i&thinsp;=&thinsp;ི &ensp; u&thinsp;=&thinsp;ུ &ensp; e&thinsp;=&thinsp;ེ &ensp; o&thinsp;=&thinsp;ོ</span>
          <span><strong>Punct:</strong> Space&thinsp;=&thinsp;་ &ensp; /&thinsp;=&thinsp;། &ensp; -&thinsp;=&thinsp;༌</span>
          <span><strong>Numbers:</strong> 0–9&thinsp;=&thinsp;༠–༩</span>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══════ UCHEN ═══════ -->
  <section class="page-section">
    <div class="script-header reveal">
      <div class="script-eyebrow">Uchen Script · དབུ་ཅན</div>
      <h2 class="script-title">Formal upright script — {uchen.length} fonts</h2>
      <p class="script-desc">The "headed" script — Tibetan's equivalent of print letterforms. Used in religious texts, official publishing, education, and anywhere a formal, authoritative presence is needed.</p>
    </div>

    <div class="font-showcase">
      {uchen.map((font, i) => (
        <div class={`font-row ${i === uchen.length - 1 ? 'font-row-last' : ''}`}>
          <div class="font-sample">
            <div class={`${font.cls} tr-guard font-sample-long`} lang="bo" data-live-preview data-default={sample.long}>{sample.long}</div>
            <div class="font-sample-alpha">
