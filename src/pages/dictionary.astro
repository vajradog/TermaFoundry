---
import SiteLayout from '@layouts/SiteLayout.astro';
---

<SiteLayout
  title="Tibetan Dictionary — TermaFoundry"
  description="Search the Tibetan-English dictionary. Look up Tibetan words, Wylie transliteration, definitions, and example sentences."
>

  <section class="page-section">
    <div class="section-eyebrow" style="text-align:center">&#128218;&nbsp; Multi-Dictionary Search</div>
    <h1 class="section-heading" style="text-align:center">Tibetan Dictionary <span class="dict-version">v4.6.0</span></h1>
    <p class="dict-tagline" style="text-align:center"><span class="dict-tibetan">ཚིག་མཛོད།</span> — The most comprehensive Tibetan dictionary in existence.</p>
    <p class="section-sub" style="text-align:center;margin-left:auto;margin-right:auto;margin-bottom:1.5rem">Search 1.2+ million entries across 64 authoritative sources.</p>
  </section>

  <section class="dict-page reveal">

    <!-- Server status -->
    <div class="dict-server-status-wrap">
      <div id="dict-server-status" class="dict-server-status dict-server-checking">
        <svg class="dict-server-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="9 12 11 14 15 10"/></svg>
        <span class="dict-server-label">Checking server…</span>
      </div>
    </div>

    <!-- Search form -->
    <form class="dict-form" id="dict-form" autocomplete="off">
      <div class="dict-input-wrap">
        <svg class="dict-icon-search" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input
          id="dict-input"
          type="text"
          placeholder="Search in Tibetan or English… (e.g., སེར་ or kindness)"
          class="dict-input"
          spellcheck="false"
        />
        <button type="button" id="dict-clear" class="dict-clear" aria-label="Clear" hidden>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      <button type="submit" class="dict-submit">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        Search Dictionary
      </button>
    </form>

    <!-- Status / results -->
    <div id="dict-status" class="dict-state" hidden></div>
  </section>

  <!-- Results meta + grid (wider than search form) -->
  <div class="dict-results-area">
    <div id="dict-results-meta" class="dict-results-meta" hidden>
      <p class="dict-results-for">&#128218;&nbsp; Results for: <span id="dict-query-display" class="dict-query-hl"></span></p>
      <p class="dict-results-count">Found <strong id="dict-count-num">0</strong> results</p>
      <div class="dict-section-label">
        <span class="dict-section-dot"></span>Exact Matches (<span id="dict-exact-count">0</span>)
      </div>
    </div>
    <div id="dict-results" class="dict-results"></div>
  </div>

  <!-- ── Curation roadmap box ── -->
  <div class="dict-roadmap">
    <p class="dict-roadmap-lead">TermaDictionary aggregates the world's largest collection of Tibetan lexicographic sources — but aggregation is only the beginning. Deduplicating entries, resolving conflicts between sources, and matching headwords across 64 independent datasets is a massive, ongoing curation effort.</p>
    <p class="dict-roadmap-body">Our current system connects all sources into a single searchable index. What it still needs is a <strong>human editorial layer</strong> — expert review, conflict resolution, and a community correction mechanism. The gaps are real:</p>
    <ul class="dict-roadmap-list">
      <li><strong>No deduplication</strong> — the same headword can appear dozens of times with conflicting definitions from different sources</li>
      <li><strong>No conflict resolution</strong> — contradictory translations from different traditions are shown without priority or context</li>
      <li><strong>No community corrections</strong> — errors discovered by scholars and practitioners have no path back into the database</li>
      <li><strong>No version history</strong> — changes to entries are not tracked or attributed</li>
      <li><strong>No expert review workflow</strong> — specialist knowledge in Madhyamaka, Vajrayāna, medical, and classical Tibetan terminology is untapped</li>
    </ul>
    <p class="dict-roadmap-cta">With grant support, TermaDictionary can become a living, community-curated resource — the first Tibetan dictionary with crowdsourced corrections, expert review, and transparent version history per entry. This is what it takes to build a truly authoritative, open Tibetan lexical commons.</p>
  </div>

  <!-- ── Info sections ── -->
  <section class="dict-info">

    <div class="dict-info-grid">

      <article class="dict-info-card">
        <div class="dict-info-icon">&#127760;</div>
        <h2 class="dict-info-heading">The World's Largest Free Online Tibetan Dictionary</h2>
        <p>The Tibetan Library Dictionary brings together <strong>1,229,242 entries from 64 authoritative sources</strong> into a single, free, searchable database. Whether you're a student learning Tibetan, a scholar researching Buddhist philosophy, a translator working on sacred texts, or simply curious about Tibetan words, this dictionary provides instant access to the combined knowledge of the world's leading Tibetan lexicographic works.</p>
      </article>

      <article class="dict-info-card">
        <div class="dict-info-icon">&#128269;</div>
        <h2 class="dict-info-heading">Search Tibetan Words in Multiple Ways</h2>
        <p>Our dictionary supports three input methods: type directly in <span class="dict-tibetan-inline">Tibetan script (བོད་ཡིག)</span>, use <strong>Wylie transliteration</strong> (the standard romanization system for Tibetan), or search in <strong>English</strong> to find Tibetan translations. The search engine simultaneously queries all 64 dictionaries, returning results organized by source so you can compare definitions across multiple authoritative references.</p>
      </article>

      <article class="dict-info-card">
        <div class="dict-info-icon">&#128218;</div>
        <h2 class="dict-info-heading">Authoritative Tibetan Dictionary Sources</h2>
        <p>This dictionary combines major English-Tibetan lexicons like the <strong>Rangjung Yeshe Dictionary</strong> (73,730 entries), the historic <strong>Jäschke Dictionary</strong> from 1881 (154,112 entries), the <strong>Ives Waldo Dictionary</strong> (120,920 entries), and <strong>Jeffrey Hopkins'</strong> Buddhist terminology work (17,955 entries). It also includes the <strong>84000 Translation Project</strong> glossaries (51,594 entries), the classical <span class="dict-tibetan-inline">Tshig Mdzod Chen Mo (ཚིག་མཛོད་ཆེན་མོ)</span> (51,030 entries), the <span class="dict-tibetan-inline">Dungkar Encyclopedia (དུང་དཀར)</span> (13,310 entries), and Sanskrit-Tibetan sources like the <strong>Mahāvyutpatti</strong> and Negi Sanskrit Dictionary (79,293 entries).</p>
      </article>

      <article class="dict-info-card">
        <div class="dict-info-icon">&#129666;</div>
        <h2 class="dict-info-heading">Buddhist Terminology &amp; Specialized Vocabulary</h2>
        <p>The dictionary is particularly strong in Buddhist philosophical terminology, with dedicated sources covering <strong>Madhyamaka, Yogācāra, Abhidharma, Vinaya, and Vajrayāna</strong> traditions. The <span class="dict-tibetan-inline">Compendium of Dharma (ཆོས་རྣམ་ཀུན་བཏུས)</span> (11,512 entries) and <span class="dict-tibetan-inline">Buddhist Philosophy Dictionary (བོད་རྒྱ་ནང་དོན)</span> (8,947 entries) provide specialized definitions crucial for understanding Buddhist texts in their original language.</p>
      </article>

    </div>

    <div class="dict-info-compare">
      <div class="dict-info-compare-inner">
        <span class="dict-info-compare-icon">&#9889;</span>
        <div>
          <h3 class="dict-info-compare-heading">How This Dictionary Compares</h3>
          <p>Most online Tibetan dictionaries draw from a single source — typically Rangjung Yeshe or Monlam alone. The Tibetan Library Dictionary is unique in unifying <strong>64 different sources</strong> into one searchable interface. With over <strong>1.2 million entries</strong> spanning classical Tibetan, colloquial Tibetan, Buddhist terminology, medical terminology, and modern vocabulary, no other publicly accessible Tibetan dictionary comes close in scope or depth.</p>
        </div>
      </div>
    </div>

  </section>

</SiteLayout>

<style is:global>
  @font-face {
    font-family: 'Noto Serif Tibetan';
    src: url('/fonts/noto-serif-tibetan-regular.woff2') format('woff2');
    font-weight: 400;
    font-display: swap;
  }
  @font-face {
    font-family: 'Noto Serif Tibetan';
    src: url('/fonts/noto-serif-tibetan-bold.woff2') format('woff2');
    font-weight: 700;
    font-display: swap;
  }

  .dict-page {
    max-width: 580px;
    margin: 0 auto;
    padding: 0 1.5rem 2rem;
  }
  .dict-version {
    font-size: .5em; font-weight: 700; vertical-align: super;
    padding: .15em .5em; border-radius: 4px;
    background: rgba(56,189,248,0.12); color: var(--accent);
    border: 1px solid rgba(56,189,248,0.2);
    letter-spacing: .06em;
  }
  .dict-tagline {
    color: #94a3b8;
    font-size: 1rem;
    margin: 0.25rem 0 0.5rem;
  }
  .dict-tibetan {
    font-family: 'Noto Serif Tibetan', serif;
    font-size: 1.1em;
    color: #cbd5e1;
  }

  /* ── Server status ── */
  .dict-server-status-wrap {
    display: flex;
    justify-content: center;
    margin-bottom: 20px;
  }
  .dict-server-status {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    transition: color 0.3s;
  }
  .dict-server-checking { color: #64748b; }
  .dict-server-online   { color: #22c55e; }
  .dict-server-offline  { color: #f87171; }
  .dict-server-icon { flex-shrink: 0; }
  .dict-server-online .dict-server-icon {
    animation: dict-pulse-opacity 1.8s ease-in-out infinite;
  }
  @keyframes dict-pulse-opacity {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.5; }
  }

  /* ── Search bar ── */
  .dict-form {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 32px;
  }
  .dict-input-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }
  .dict-icon-search {
    position: absolute;
    left: 16px;
    color: #64748b;
    pointer-events: none;
    flex-shrink: 0;
  }
  .dict-input {
    width: 100%;
    padding: 15px 44px 15px 46px;
    border-radius: 10px;
    border: 1.5px solid rgba(148,163,184,0.2);
    background: rgba(15,23,42,0.7);
    color: #e2e8f0;
    font-size: 1rem;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    font-family: 'Inter', system-ui, sans-serif, 'Noto Serif Tibetan', 'Jomolhari';
    box-sizing: border-box;
  }
  .dict-input:focus {
    border-color: rgba(245,158,11,0.5);
    box-shadow: 0 0 0 3px rgba(245,158,11,0.08);
  }
  .dict-input::placeholder { color: #475569; }
  .dict-clear {
    position: absolute;
    right: 12px;
    background: none;
    border: none;
    cursor: pointer;
    color: #64748b;
    display: flex;
    align-items: center;
    padding: 4px;
    border-radius: 4px;
    transition: color 0.15s;
  }
  .dict-clear:hover { color: #e2e8f0; }
  .dict-submit {
    width: 100%;
    padding: 15px;
    border-radius: 10px;
    border: none;
    background: #f59e0b;
    color: #0f172a;
    font-weight: 700;
    font-size: 1rem;
    cursor: pointer;
    transition: background 0.2s, transform 0.1s;
    letter-spacing: 0.02em;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }
  .dict-submit:hover { background: #fbbf24; }
  .dict-submit:active { transform: scale(0.98); }

  /* ── Status ── */
  .dict-state {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 16px 0;
    color: #64748b;
    font-size: 0.93rem;
  }
  .dict-state.error { color: #f87171; }

  /* ── Results count ── */
  .dict-count {
    font-size: 0.8rem;
    color: #475569;
    margin-bottom: 14px;
    letter-spacing: 0.02em;
  }

  /* ── Results area ── */
  .dict-results-area {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
  }
  .dict-results-meta {
    text-align: center;
    margin-bottom: 2rem;
  }
  .dict-results-for {
    font-size: 0.95rem;
    color: #64748b;
    margin: 0 0 4px;
  }
  .dict-query-hl {
    color: #f87171;
    font-weight: 700;
  }
  .dict-results-count {
    font-size: 0.9rem;
    color: #64748b;
    margin: 0 0 16px;
  }
  .dict-results-count strong { color: #94a3b8; }
  .dict-section-label {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 0.8rem;
    font-weight: 600;
    color: #0d9488;
    border-top: 1px solid rgba(13,148,136,0.25);
    border-bottom: 1px solid rgba(13,148,136,0.25);
    padding: 6px 18px;
    letter-spacing: 0.04em;
  }
  .dict-section-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #0d9488;
    flex-shrink: 0;
  }

  /* ── Entry grid ── */
  .dict-results {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
    margin-top: 20px;
  }
  @media (max-width: 860px) { .dict-results { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 540px) { .dict-results { grid-template-columns: 1fr; } }

  /* ── Entry card ── */
  .dict-entry {
    background: #0f1a2b;
    border: 1px solid rgba(148,163,184,0.1);
    border-top: 3px solid var(--entry-color, #475569);
    border-radius: 10px;
    padding: 14px 16px 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: border-color 0.2s, box-shadow 0.15s;
  }
  .dict-entry:hover {
    box-shadow: 0 4px 20px rgba(0,0,0,0.3);
    border-color: var(--entry-color, #475569);
  }
  .dict-entry-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 8px;
    flex-wrap: wrap;
  }
  .dict-source-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }
  .dict-source-pill {
    font-size: 0.68rem;
    font-weight: 600;
    padding: 2px 7px;
    border-radius: 4px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    color: var(--entry-color, #94a3b8);
    white-space: nowrap;
  }
  .dict-more-pill {
    font-size: 0.68rem;
    color: #64748b;
    padding: 2px 6px;
    border-radius: 4px;
    border: 1px solid rgba(100,116,139,0.2);
    background: transparent;
    white-space: nowrap;
  }
  .dict-match {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 0.72rem;
    font-weight: 700;
    color: #22c55e;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .dict-match-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #22c55e;
    flex-shrink: 0;
  }
  .dict-headword {
    font-family: 'Noto Serif Tibetan', 'Jomolhari', serif;
    font-size: 1.5rem;
    line-height: 1.6;
    color: #f1f5f9;
    display: block;
  }
  .dict-definition {
    font-size: 0.88rem;
    color: #94a3b8;
    line-height: 1.6;
    font-family: 'Inter', system-ui, sans-serif;
  }
  .dict-wylie {
    display: inline-block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    color: var(--entry-color, #f59e0b);
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    padding: 1px 6px;
    border-radius: 4px;
    margin-top: 2px;
  }
  .dict-examples {
    margin-top: 4px;
    padding-top: 8px;
    border-top: 1px solid rgba(148,163,184,0.07);
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .dict-ex-bo {
    font-family: 'Noto Serif Tibetan', serif;
    font-size: 0.9rem;
    color: #e2e8f0;
    margin: 0;
  }
  .dict-ex-tr { font-size: 0.78rem; color: #64748b; font-style: italic; margin: 0; }

  @keyframes spin { to { transform: rotate(360deg); } }
  .spinning { animation: spin 0.8s linear infinite; display: inline-block; }

  /* ── Curation roadmap box ── */
  .dict-roadmap {
    max-width: 820px;
    margin: 0 auto 1rem;
    padding: 2rem 2.25rem;
    background: rgba(15,23,42,0.7);
    border: 1px solid rgba(148,163,184,0.12);
    border-radius: 14px;
  }
  .dict-roadmap-lead {
    font-size: .92rem; color: #e2e8f0; line-height: 1.7;
    margin-bottom: 1rem;
  }
  .dict-roadmap-body {
    font-size: .85rem; color: #94a3b8; line-height: 1.7;
    margin-bottom: 1rem;
  }
  .dict-roadmap-body strong { color: #e2e8f0; }
  .dict-roadmap-list {
    list-style: none; padding: 0; margin: 0 0 1.25rem 0;
    display: flex; flex-direction: column; gap: .5rem;
  }
  .dict-roadmap-list li {
    font-size: .85rem; color: #94a3b8; line-height: 1.6;
    padding-left: 1.25rem; position: relative;
  }
  .dict-roadmap-list li::before {
    content: ''; position: absolute; left: 0; top: .55em;
    width: 6px; height: 6px; border-radius: 50%;
    background: rgba(56,189,248,0.4);
  }
  .dict-roadmap-list li strong { color: #e2e8f0; }
  .dict-roadmap-cta {
    font-size: .85rem; color: #475569; line-height: 1.7;
    padding-top: 1rem; border-top: 1px solid rgba(148,163,184,0.1);
    font-style: italic;
  }

  /* ── Info sections ── */
  .dict-info {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 1.5rem 6rem;
  }
  .dict-info-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    margin-bottom: 1.25rem;
  }
  @media (max-width: 680px) {
    .dict-info-grid { grid-template-columns: 1fr; }
  }
  .dict-info-card {
    background: rgba(15,23,42,0.6);
    border: 1px solid rgba(148,163,184,0.1);
    border-radius: 14px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    transition: border-color 0.2s;
  }
  .dict-info-card:hover {
    border-color: rgba(148,163,184,0.22);
  }
  .dict-info-icon {
    font-size: 1.5rem;
    line-height: 1;
  }
  .dict-info-heading {
    font-size: 1.05rem;
    font-weight: 700;
    color: #e2e8f0;
    margin: 0;
    line-height: 1.3;
  }
  .dict-info-card p {
    color: #64748b;
    font-size: 0.9rem;
    line-height: 1.7;
    margin: 0;
  }
  .dict-info-card p strong {
    color: #94a3b8;
    font-weight: 600;
  }
  .dict-tibetan-inline {
    font-family: 'Noto Serif Tibetan', serif;
    color: #cbd5e1;
  }
  .dict-info-compare {
    border: 1px solid rgba(245,158,11,0.2);
    border-radius: 14px;
    background: rgba(245,158,11,0.04);
    padding: 1.75rem;
  }
  .dict-info-compare-inner {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }
  .dict-info-compare-icon {
    font-size: 1.5rem;
    line-height: 1;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }
  .dict-info-compare-heading {
    font-size: 1.05rem;
    font-weight: 700;
    color: #e2e8f0;
    margin: 0 0 0.5rem;
  }
  .dict-info-compare p {
    color: #64748b;
    font-size: 0.9rem;
    line-height: 1.7;
    margin: 0;
  }
  .dict-info-compare p strong {
    color: #f59e0b;
    font-weight: 600;
  }
</style>

<script>
  const DICT_API = 'https://api.termafoundry.com/dictionary';

  // ── Dictionary source colours ──
  const SOURCE_COLORS = {
    'Hopkins2015':'#7c3aed','Hopkins':'#7c3aed',
    'JimValby':'#0891b2',
    '84000Dict':'#0d9488','84000':'#0d9488',
    'Berzin':'#d97706',
    'IvesWaldo':'#2563eb','Ives Waldo':'#2563eb',
    'RangjungYeshe':'#dc2626','Rangjung Yeshe':'#dc2626',
    'Jäschke':'#16a34a','Jaschke':'#16a34a',
    'Monlam':'#9333ea',
    'Negi':'#ea580c',
    'CommonTerms':'#0284c7','Common Terms':'#0284c7',
    'TshigMdzodChenMo':'#b45309','Tshig Mdzod':'#b45309',
    'Dungkar':'#0f766e',
    'Mahavyutpatti':'#7e22ce',
  };
  function sourceColor(name) {
    if (SOURCE_COLORS[name]) return SOURCE_COLORS[name];
    let h = 0;
    for (let i = 0; i < name.length; i++) h = (h * 31 + name.charCodeAt(i)) & 0xffffff;
    return `hsl(${h % 360}, 55%, 55%)`;
  }

  // ── Server status ping ──
  (async () => {
    const el    = document.getElementById('dict-server-status') as HTMLElement;
    const label = el.querySelector('.dict-server-label') as HTMLElement;
    try {
      const res = await fetch(`${DICT_API}?health=1`, { signal: AbortSignal.timeout(5000) });
      if (res.ok) {
        el.className = 'dict-server-status dict-server-online';
        label.textContent = 'Server Online';
      } else {
        throw new Error('non-ok');
      }
    } catch {
      el.className = 'dict-server-status dict-server-offline';
      label.textContent = 'Server Offline';
    }
  })();

  const form     = document.getElementById('dict-form') as HTMLFormElement;
  const input    = document.getElementById('dict-input') as HTMLInputElement;
  const clearBtn = document.getElementById('dict-clear') as HTMLButtonElement;
  const status   = document.getElementById('dict-status') as HTMLElement;
  const results  = document.getElementById('dict-results') as HTMLElement;

  let debounceTimer: ReturnType<typeof setTimeout> | undefined;
  let abortController: AbortController | undefined;

  function normalizeResults(data) {
    if (Array.isArray(data)) return data;
    if (data.results) return data.results;
    if (data.entries) return data.entries;
    if (data.data)    return data.data;
    if (data.word || data.tibetan) return [data];
    return [];
  }

  function getDefs(entry) {
    if (entry.definition) return [entry.definition];
    if (typeof entry.definitions === 'string') return [entry.definitions];
    if (Array.isArray(entry.definitions)) return entry.definitions;
    if (Array.isArray(entry.translations))
      return entry.translations.map(t => typeof t === 'string' ? t : t.text).filter(Boolean);
    return [];
  }

  function getSources(entry) {
    if (Array.isArray(entry.sources)) return entry.sources;
    if (entry.source) return [entry.source];
    return [];
  }

  function getMatchPct(entry) {
    const s = entry.score ?? entry.match_score ?? entry.relevance;
    if (s == null) return null;
    return Math.round((s <= 1 ? s * 100 : s));
  }

  function renderEntry(entry) {
    const head    = entry.tibetan || entry.word || '';
    const defs    = getDefs(entry);
    const sources = getSources(entry);
    const pct     = getMatchPct(entry);
    const examples = entry.examples || [];

    // Primary color from first source
    const color = sources.length ? sourceColor(sources[0]) : '#475569';

    // Source pills — show up to 3, then "+N more"
    const MAX_PILLS = 3;
    const shown  = sources.slice(0, MAX_PILLS);
    const extra  = sources.length - MAX_PILLS;
    const pills  = shown.map(s =>
      `<span class="dict-source-pill" style="color:${sourceColor(s)};border-color:${sourceColor(s)}22">${s}</span>`
    ).join('');
    const morePill = extra > 0 ? `<span class="dict-more-pill">+${extra} more</span>` : '';

    const matchHtml = pct != null
      ? `<div class="dict-match"><span class="dict-match-dot"></span>${pct}%</div>` : '';

    const defsHtml = defs.length
      ? `<div class="dict-definition">${defs.slice(0, 3).join('; ')}</div>` : '';

    const exHtml = examples.length
      ? `<div class="dict-examples">${examples.map(ex =>
          `${ex.tibetan ? `<p class="dict-ex-bo" lang="bo">${ex.tibetan}</p>` : ''}
           ${ex.translation ? `<p class="dict-ex-tr">${ex.translation}</p>` : ''}`
        ).join('')}</div>` : '';

    const wylieHtml = entry.wylie
      ? `<span class="dict-wylie">${entry.wylie}</span>` : '';

    return `<div class="dict-entry" style="--entry-color:${color}">
      <div class="dict-entry-top">
        <div class="dict-source-pills">${pills}${morePill}</div>
        ${matchHtml}
      </div>
      ${head ? `<span class="dict-headword" lang="bo">${head}</span>` : ''}
      ${wylieHtml}
      ${defsHtml}
      ${exHtml}
    </div>`;
  }

  function showStatus(msg: string, isError = false) {
    status.innerHTML = msg;
    status.className = 'dict-state' + (isError ? ' error' : '');
    status.hidden = false;
    (document.getElementById('dict-results-meta') as HTMLElement).hidden = true;
    results.innerHTML = '';
  }

  function hideStatus() {
    status.hidden = true;
  }

  async function search(query) {
    if (!query.trim()) {
      hideStatus();
      results.innerHTML = '';
      return;
    }

    if (abortController) abortController.abort();
    abortController = new AbortController();

    showStatus('<span class="spinning">⟳</span> Searching…');

    try {
      const res = await fetch(
        `${DICT_API}?query=${encodeURIComponent(query.trim())}`,
        { signal: abortController.signal }
      );

      if (!res.ok) {
        const err = await res.json().catch(() => ({}));
        throw new Error(err.error || `HTTP ${res.status}`);
      }

      const data = await res.json();
      const entries = normalizeResults(data);

      hideStatus();

      if (entries.length === 0) {
        showStatus(`No results found for <strong>${query}</strong>`);
        return;
      }

      // Populate results meta
      const meta = document.getElementById('dict-results-meta') as HTMLElement;
      (document.getElementById('dict-query-display') as HTMLElement).textContent = query;
      (document.getElementById('dict-count-num') as HTMLElement).textContent = String(entries.length);
      const exactCount = entries.filter((e: any) => {
        const p = e.score ?? e.match_score ?? e.relevance;
        return p == null || (p <= 1 ? p >= 0.99 : p >= 99);
      }).length;
      (document.getElementById('dict-exact-count') as HTMLElement).textContent = String(exactCount || entries.length);
      meta.hidden = false;

      results.innerHTML = entries.map(renderEntry).join('');
    } catch (err: any) {
      if (err.name === 'AbortError') return;
      showStatus(`Error: ${err.message}`, true);
    }
  }

  input.addEventListener('input', () => {
    clearBtn.hidden = !input.value;
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => search(input.value), 400);
  });

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    clearTimeout(debounceTimer);
    search(input.value);
  });

  clearBtn.addEventListener('click', () => {
    input.value = '';
    clearBtn.hidden = true;
    hideStatus();
    (document.getElementById('dict-results-meta') as HTMLElement).hidden = true;
    results.innerHTML = '';
    if (abortController) abortController.abort();
    input.focus();
  });
</script>
