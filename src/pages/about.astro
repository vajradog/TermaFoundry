  .story-text h2 { font-size: 1.35rem; font-weight: 700; color: var(--text); margin: 2rem 0 .75rem; }
  .story-text h2:first-child { margin-top: 0; }
  .story-text p { font-size: .95rem; color: var(--text2); line-height: 1.85; margin-bottom: 1rem; }
  .story-text em { color: var(--accent); font-style: normal; }
  .story-text ul { padding-left: 1.25rem; margin-bottom: 1rem; }
  .story-text li { font-size: .95rem; color: var(--text2); line-height: 1.8; margin-bottom: .3rem; }
  .story-divider { border: none; border-top: 1px solid var(--border); margin: 2.5rem 0; }

  /* Tibetan panel */
  .bo-panel { margin: 1.75rem 0 0; }
  .bo-toggle {
    display: flex; align-items: center; gap: .6rem;
    width: 100%;
    padding: .65rem 1rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    cursor: pointer;
    text-align: left;
    transition: background .15s, border-color .15s;
    color: var(--text2);
  }
  .bo-toggle:hover { background: var(--surface2); border-color: var(--accent); }
  .bo-toggle[aria-expanded="true"] {
    border-radius: 10px 10px 0 0;
    border-bottom-color: transparent;
    background: var(--surface2);
  }
  .bo-toggle-script { font-size: 1rem; color: var(--accent); line-height: 1.8; }
  .bo-toggle-label { font-size: .9rem; color: var(--text2); flex: 1; line-height: 1.8; }
  .bo-toggle-chevron {
    font-size: 1rem; color: var(--muted);
    transition: transform .25s;
    display: inline-block;
  }
  .bo-toggle[aria-expanded="true"] .bo-toggle-chevron { transform: rotate(90deg); }
  .bo-body {
    border: 1px solid var(--border);
    border-top: none;
    border-radius: 0 0 10px 10px;
    background: var(--surface);
    overflow: hidden;
  }
  .bo-toolbar {
    display: flex;
    align-items: center;
    gap: .75rem;
    padding: .6rem 1rem;
    border-bottom: 1px solid var(--border);
    background: var(--surface2);
  }
  .bo-font-label { font-size: .7rem; color: var(--muted); text-transform: uppercase; letter-spacing: .08em; }
  .bo-font-select {
    font-size: .78rem;
    background: var(--bg);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 3px 8px;
    cursor: pointer;
    outline: none;
  }
  .bo-font-select:focus { border-color: var(--accent); }
  .bo-powered { margin-left: auto; font-size: .68rem; color: var(--muted); }
  .bo-powered-link { color: var(--accent); text-decoration: none; }
  .bo-powered-link:hover { text-decoration: underline; }
  .bo-text { padding: 1.75rem 2rem 1.75rem; }
  .bo-heading { color: var(--accent); margin: 0 0 1.25rem; }
  .bo-para { color: var(--text2); margin: 0 0 2.25rem; }
  .bo-para:last-child { margin-bottom: 0; }
  /* Latin terms inline within Tibetan prose — system font, matched optical size */
  .bo-latin {
    font-family: ui-monospace, 'SFMono-Regular', 'Cascadia Code', monospace;
    font-size: .82em;
    letter-spacing: .03em;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    padding: .1em .35em;
    border-radius: 3px;
  }

  /* Drutsa stacking is taller — needs extra breathing room */
  .bo-text[data-font="tr-drutsa"] .bo-para,
  .bo-text[data-font="tr-drutsa"] .bo-heading { line-height: 3.4; }
  /* Monlam also benefits from slightly more leading */
  .bo-text[data-font="tr-monlam"] .bo-para,
  .bo-text[data-font="tr-monlam"] .bo-heading { line-height: 2.8; }

  .story-mission-card {
    position: sticky; top: 80px;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 16px; padding: 2rem; border-top: 3px solid var(--accent);
  }
  .mission-label { font-size: .68rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; color: var(--accent); margin-bottom: 1.25rem; }
  .mission-quote { font-size: 1.15rem; display: block; margin-bottom: 1rem; padding-block: .25em; line-height: 1.9; }
  .mission-en { font-size: .88rem; color: var(--text2); line-height: 1.7; margin-bottom: 1.5rem; font-style: italic; }
  .mission-pillars { display: flex; flex-direction: column; gap: .6rem; }
  .pillar { display: flex; align-items: flex-start; gap: .6rem; font-size: .82rem; color: var(--muted); line-height: 1.5; }
  .pillar-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent); margin-top: .42rem; flex-shrink: 0; }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 2rem;
  }
  .team-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .team-photo {
    width: 130px; height: 130px;
    border-radius: 50%;
    overflow: hidden;
    margin-bottom: 1.25rem;
    border: 3px solid var(--border2);
    flex-shrink: 0;
    transition: border-color .2s;
  }
  .team-card:hover .team-photo { border-color: var(--accent); }
  .team-photo img {
    width: 100%; height: 100%;
    object-fit: cover; object-position: center 20%;
    display: block;
  }
  .team-photo--placeholder {
    display: flex; align-items: center; justify-content: center;
    background: var(--surface2);
    border-color: var(--border);
  }
  .team-initial {
    font-size: 2.5rem; font-weight: 700;
    color: var(--muted);
    line-height: 1;
  }
  .team-name { font-size: 1.05rem; font-weight: 700; color: var(--text); margin-bottom: .2rem; }
  .team-role { font-size: .68rem; font-weight: 700; text-transform: uppercase; letter-spacing: .07em; color: var(--accent); margin-bottom: .5rem; }
  .team-tagline { font-size: .84rem; color: var(--text2); line-height: 1.6; margin-bottom: .5rem; }
  .team-toggle {
    background: none; border: none; cursor: pointer;
    font-family: inherit; font-size: .78rem; font-weight: 600;
    color: var(--accent); padding: 0;
    display: inline-flex; align-items: center; gap: .3rem;
    transition: color .15s;
  }
  .team-toggle:hover { color: var(--text); }
  .team-toggle-arrow {
    font-size: .85rem; transition: transform .2s;
  }
  .team-toggle[aria-expanded="true"] .team-toggle-arrow { transform: rotate(45deg); }
  .team-bio-full {
    overflow: hidden;
    max-height: 0;
    transition: max-height .35s ease, margin .25s ease;
    margin-top: 0;
  }
  .team-bio-full.open {
    max-height: 500px;
    margin-top: .75rem;
  }
  .team-bio { font-size: .82rem; color: var(--muted); line-height: 1.75; text-align: left; }

  /* Extended team */
  .team-extended {
    display: flex;
    gap: 2rem;
    align-items: center;
    background: var(--surface);
    border: 1px solid var(--border);
