    .team-grid { grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
  }
  @media (max-width: 600px) {
    .team-grid { grid-template-columns: 1fr; }
    .team-extended { flex-direction: column; text-align: center; }
    .team-photo--wide { width: 100%; height: 160px; }
  }
  @media (min-width: 901px) and (max-width: 1100px) {
    .ecosystem-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<script>
  const toggle = document.getElementById('bo-toggle');
  const body   = document.getElementById('bo-body');
  const select = document.getElementById('bo-font-select');
  const paras  = document.querySelectorAll('#bo-text .bo-para, #bo-text .bo-heading');

  const FONTS = ['tr-jomolhari','tr-noto','tr-machine-uni','tr-drutsa','tr-monlam'];

  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!open));
    if (open) { body?.setAttribute('hidden', ''); }
    else       { body?.removeAttribute('hidden'); }
  });

  select?.addEventListener('change', () => {
    const chosen = (select as HTMLSelectElement).value;
    paras.forEach(el => {
      FONTS.forEach(f => el.classList.remove(f));
      el.classList.add(chosen);
    });
    document.getElementById('bo-text')?.setAttribute('data-font', chosen);
  });

  // Team bio toggles
  document.querySelectorAll('.team-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      const bioFull = btn.nextElementSibling as HTMLElement;
      if (bioFull) {
        if (expanded) {
          bioFull.classList.remove('open');
          bioFull.setAttribute('hidden', '');
        } else {
          bioFull.removeAttribute('hidden');
          // Force reflow before adding class for transition
          bioFull.offsetHeight;
          bioFull.classList.add('open');
        }
      }
    });
  });
</script>
