---
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";
import Layout from "@layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import Link from "@components/ui/link.astro";
---

<Layout title="Contact">
  <Container>
    <Sectionhead>
      <Fragment slot="title">Get Involved</Fragment>
      <Fragment slot="desc">Help us create tools that make Tibetan script accessible and vibrant.
     </Fragment>
    </Sectionhead>

    <div class="grid md:grid-cols-1 gap-10 mx-auto max-w-4xl mt-16">
      <div>
        <h2 class="font-medium text-2xl text-gray-800">Terma Type Foundry is based in New Paltz, New York

          <br><br>
        <h2 class="font-medium text-2xl text-gray-800">Donate:
        <span class="text-lg leading-relaxed text-slate-500 mt-3">
          Your support ensures the fonts are freely available for all.  <span class="mt-6 flex flex-col sm:flex-row gap-3">
            <Link
              href="#"
              href="https://www.gofundme.com/f/termafonts"
              target="_blank"
              class="flex gap-1 items-center justify-center"
              rel="noopener">
              <Icon class="text-white w-5 h-5" name="bx:bxs-donate-heart" />
      
               Support the Project
            </Link></span>
        </span></h2>
        <br>
        <h2 class="font-medium text-2xl text-gray-800">Partner with Us:
        <span class="text-lg leading-relaxed text-slate-500 mt-3">
          Collaborate on educational initiatives, design projects, or research: termastudios@gmail.com
        </span></h2>  <br>
        <h2 class="font-medium text-2xl text-gray-800">Spread the Word:
        <span class="text-lg leading-relaxed text-slate-500 mt-3">
          Share our mission to revitalize Tibetan literacy.
        </span></h2>
        <div class="mt-5">
        
        </div>
      </div>
      <div>
      </div>
    </div>
  </Container>
</Layout>
