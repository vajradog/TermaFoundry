---
import SiteLayout from '@layouts/SiteLayout.astro';
---

<SiteLayout title="Contact Terma Foundry — Partner & Get Involved" description="Get involved with Terma Foundry's mission to build open tools for Tibetan script. Collaborate on projects or share the work with your community.">

  <!-- HEADER -->
  <section class="page-section" style="padding-bottom:2rem;">
    <div class="section-eyebrow reveal">Contact</div>
    <h1 class="section-heading reveal">Get Involved.</h1>
    <p class="section-sub reveal">Help us create tools that make Tibetan script accessible, vibrant, and ready for the 21st century. Every bit of support makes a difference.</p>
  </section>

  <!-- CARDS -->
  <section class="page-section" style="padding-top:0;">
    <div class="cards-grid cards-grid-2 reveal">

      <div class="card contact-card">
        <div class="contact-icon">◈</div>
        <div class="card-eyebrow">Partner With Us</div>
        <div class="card-title">Collaborate</div>
        <div class="card-desc">Are you an educator, institution, or design studio working with Tibetan script? We welcome collaborations on educational initiatives, research, and design projects.</div>
        <a href="mailto:termastudios@gmail.com" class="btn btn-outline contact-btn">termastudios@gmail.com</a>
      </div>

      <div class="card contact-card">
        <div class="contact-icon">◎</div>
        <div class="card-eyebrow">Spread the Word</div>
        <div class="card-title">Share Our Mission</div>
        <div class="card-desc">Help us reach more educators, designers, and Tibetan learners around the world. Share our work, use our fonts, and tell others about the power of beautiful Tibetan typography.</div>
        <a href="https://termafoundry.com" class="btn btn-outline contact-btn">Share termafoundry.com</a>
      </div>

    </div>

    <!-- Location + email info -->
    <div class="contact-info reveal">
      <div class="info-row">
        <span class="info-label">Location</span>
        <span class="info-value">New Paltz, New York, USA</span>
      </div>
      <div class="info-row">
        <span class="info-label">Email</span>
        <a href="mailto:termastudios@gmail.com" class="info-value info-link">termastudios@gmail.com</a>
      </div>
    </div>

  </section>

</SiteLayout>

<style>
  .contact-card {
    display: flex;
    flex-direction: column;
    gap: .6rem;
  }

  .contact-icon {
    font-size: 1.75rem;
    color: var(--accent);
    margin-bottom: .25rem;
    line-height: 1;
  }

  .contact-btn {
    margin-top: auto;
    padding-top: 1.25rem;
    align-self: flex-start;
  }

  .contact-info {
    margin-top: 3rem;
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }

  .info-row {
    display: flex;
    align-items: center;
    gap: 2rem;
    padding: 1rem 1.75rem;
    border-bottom: 1px solid var(--border);
  }
  .info-row:last-child { border-bottom: none; }

  .info-label {
    font-size: .7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--muted);
    min-width: 90px;
    flex-shrink: 0;
  }

  .info-value {
    font-size: .9rem;
    color: var(--text2);
  }

  .info-link {
    color: var(--accent);
    text-decoration: none;
    transition: opacity .2s;
  }
  .info-link:hover { opacity: .75; }
</style>
