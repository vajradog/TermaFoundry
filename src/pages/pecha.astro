---
import SiteLayout from '@layouts/SiteLayout.astro';
---

<SiteLayout title="PechaForge — Free Tibetan Pecha Manuscript Creator Online" description="Create authentic Tibetan pecha manuscripts in your browser. PechaForge formats Tibetan text into traditional three-column pecha pages with yig mgo, Tibetan folios, and PDF export. Free, no account.">

  <section class="pf-page">

    <!-- ═══ TOOLBAR ═══════════════════════════════════════════════════════ -->
    <div class="pf-toolbar reveal">
      <div class="pf-toolbar-row">
        <h1 class="pf-title">PechaForge</h1>
        <div class="pf-toolbar-actions">
          <button class="pf-btn pf-btn-primary" id="btn-generate">Generate Preview</button>
          <button class="pf-btn" id="btn-print" title="Export as PDF via browser print">Export PDF</button>
          <button class="pf-btn" id="btn-print-duplex" title="Export double-sided PDF for cutting into pecha leaves">Double-Sided</button>
          <button class="pf-btn-icon" id="btn-save" title="Save project as .json file">Save</button>
          <button class="pf-btn-icon" id="btn-load" title="Load project from .json file">Load</button>
          <input type="file" id="file-load" accept=".json" class="pf-hidden">
        </div>
      </div>

      <!-- Settings row -->
      <div class="pf-settings">
        <div class="pf-setting">
          <label for="set-font">Font</label>
          <select id="set-font">
            <optgroup label="Uchen — Formal">
              <option value="Jomolhari" selected>Jomolhari</option>
              <option value="Noto Serif Tibetan">Noto Serif Tibetan</option>
              <option value="Tibetan Machine Uni">Tibetan Machine Uni</option>
              <option value="DDC Uchen">DDC Uchen</option>
              <option value="DDC Rinzin">DDC Rinzin</option>
              <option value="Monlam Bodyig">Monlam Bodyig</option>
              <option value="BabelStone Tibetan">BabelStone Tibetan</option>
              <option value="BabelStone Tibetan Slim">BabelStone Slim</option>
              <option value="GangJie Uchen">GangJie Uchen</option>
              <option value="Jamyang Monlam Uchen">Jamyang Monlam</option>
              <option value="Panchen Tsukring">Panchen Tsukring</option>
              <option value="Riwoche Dhodri">Riwoche Dhodri</option>
              <option value="Sadri Yigchen">Sadri Yigchen</option>
            </optgroup>
            <optgroup label="Qomolangma">
              <option value="Qomolangma-UchenSarchen">Qomolangma Sarchen</option>
              <option value="Qomolangma-Betsu">Qomolangma Betsu</option>
              <option value="Qomolangma-Tsutong">Qomolangma Tsutong</option>
            </optgroup>
            <optgroup label="Monlam Uni">
              <option value="Monlam Uni OuChan1">Monlam OuChan 1</option>
              <option value="Monlam Uni OuChan2">Monlam OuChan 2</option>
              <option value="Monlam Uni OuChan3">Monlam OuChan 3</option>
              <option value="Monlam Uni OuChan4">Monlam OuChan 4</option>
              <option value="Monlam Uni OuChan5">Monlam OuChan 5</option>
              <option value="Monlam Uni PayTsik">Monlam PayTsik</option>
              <option value="Monlam Uni Tikrang">Monlam Tikrang</option>
              <option value="Monlam Uni TikTong">Monlam TikTong</option>
            </optgroup>
            <optgroup label="Sans-Serif">
              <option value="Noto Sans Tibetan">Noto Sans Tibetan</option>
              <option value="MiSans Tibetan">MiSans Tibetan</option>
              <option value="Monlam Uni Sans">Monlam Sans</option>
            </optgroup>
            <optgroup label="Drutsa — Cursive">
              <option value="Qomolangma-Drutsa">Qomolangma Drutsa</option>
              <option value="GangJie Drutsa">GangJie Drutsa</option>
              <option value="Khampa Dedri Drutsa">Khampa Drutsa</option>
              <option value="Sadri Drutsa">Sadri Drutsa</option>
              <option value="Monlam Uni Dutsa1">Monlam Dutsa 1</option>
              <option value="Monlam Uni Dutsa2">Monlam Dutsa 2</option>
            </optgroup>
            <optgroup label="Semi-Cursive">
              <option value="Joyig">Joyig</option>
              <option value="Khampa Dedri Chuyig">Khampa Chuyig</option>
              <option value="Khampa Dedri Bechu">Khampa Bechu</option>
            </optgroup>
          </select>
        </div>
        <div class="pf-setting">
          <label for="set-theme">Theme</label>
          <select id="set-theme">
            <option value="light" selected>Light (Parchment)</option>
            <option value="dark">Dark (Gold on Indigo)</option>
            <option value="bw">Black &amp; White</option>
            <option value="maroon">Maroon (Monastic)</option>
          </select>
        </div>
        <div class="pf-setting">
          <label for="set-title">Title Text</label>
          <input type="text" id="set-title" placeholder="ཤེས་རབ།" lang="bo" class="pf-title-input">
        </div>
        <div class="pf-setting">
          <label for="set-folio-start">Start Folio</label>
          <input type="number" id="set-folio-start" value="1" min="1" max="999">
        </div>
        <div class="pf-setting">
          <label for="set-lines">Lines / Page</label>
          <input type="number" id="set-lines" value="7" min="2" max="12">
        </div>
        <div class="pf-setting pf-setting-toggle">
          <label for="set-yigmgo">Yig mgo</label>
          <button id="set-yigmgo" class="pf-toggle active" title="Add ༄༅། opening mark to first page">ON</button>
        </div>
        <div class="pf-setting pf-setting-toggle">
          <label for="set-ime">IME</label>
          <button id="set-ime" class="pf-toggle active" title="Toggle Tibetan IME keyboard">ON</button>
        </div>
      </div>
    </div>

    <!-- ═══ INPUT SECTION ═════════════════════════════════════════════════ -->
    <div class="pf-input-section reveal" id="input-section">
      <div class="pf-input-header">
        <span class="pf-input-label">Paste or type Tibetan text</span>
        <span class="pf-charcount" id="charcount">0 chars</span>
        <button class="pf-btn-sm" id="btn-toggle-input">Hide Input</button>
      </div>
      <textarea
        id="pf-textarea"
        class="pf-textarea"
        placeholder="Paste Tibetan text here, or type using the IME..."
        lang="bo"
        autocomplete="off"
        autocorrect="off"
        autocapitalize="off"
        spellcheck="false"
      ></textarea>
    </div>

    <!-- ═══ PREVIEW SECTION ═══════════════════════════════════════════════ -->
    <div class="pf-preview" id="preview-section">
      <div class="pf-preview-header" id="preview-header" style="display:none;">
        <span class="pf-preview-label" id="preview-label">0 pages</span>
      </div>
      <div class="pf-pages" id="pf-pages">
        <!-- Pecha pages rendered here by JS -->
      </div>
    </div>

  </section>
</SiteLayout>


<!-- ═══════════════════════════════════════════════════════════════════════
     SCRIPT
     ═══════════════════════════════════════════════════════════════════════ -->
<script>
  // ─── IME keymap (from terma-ime.js) ─────────────────────────────────────
  const IME_MAP = {
    'k':'\u0F40','[':'\u0F41','g':'\u0F42',',':'\u0F44',
    'c':'\u0F45','x':'\u0F46','j':'\u0F47','.':'\u0F49',
    't':'\u0F4F',']':'\u0F50','d':'\u0F51','n':'\u0F53',
    'p':'\u0F54','f':'\u0F55','b':'\u0F56','m':'\u0F58',
    ';':'\u0F59',':':'\u0F5A','\\':'\u0F5B','v':'\u0F5D',
    'w':'\u0F5E','z':'\u0F5F',"'":'\u0F60','y':'\u0F61',
    'r':'\u0F62','l':'\u0F63','q':'\u0F64','s':'\u0F66',
    'h':'\u0F67','a':'\u0F68',
    'i':'\u0F72','u':'\u0F74','e':'\u0F7A','o':'\u0F7C',
    ' ':'\u0F0B','/':'\u0F0D','-':'\u0F0C',
    '0':'\u0F20','1':'\u0F21','2':'\u0F22','3':'\u0F23',
    '4':'\u0F24','5':'\u0F25','6':'\u0F26','7':'\u0F27',
    '8':'\u0F28','9':'\u0F29',
    'K':'\u0F90','G':'\u0F92','C':'\u0F95','X':'\u0F96',
    'J':'\u0F97','T':'\u0F9F','D':'\u0FA1','N':'\u0FA3',
    'P':'\u0FA4','B':'\u0FA6','M':'\u0FA8','V':'\u0FAD',
    'W':'\u0FAE','Z':'\u0FAF','Y':'\u0FB1','R':'\u0FB2',
    'L':'\u0FB3','Q':'\u0FB4','S':'\u0FB6','H':'\u0FB7','A':'\u0FB8',
  };

  const IME_PASS = new Set([
    'Backspace','Delete','ArrowLeft','ArrowRight','ArrowUp','ArrowDown',
    'Home','End','PageUp','PageDown','Tab','Enter','Escape',
    'F1','F2','F3','F4','F5','F6','F7','F8','F9','F10','F11','F12',
    'CapsLock','Shift','Control','Alt','Meta','AltGraph',
  ]);

  // ─── State ──────────────────────────────────────────────────────────────
  const state = {
    text: '',
    font: 'Jomolhari',
    theme: 'light',
    titleText: '',
    folioStart: 1,
    linesPerPage: 7,
    imeEnabled: true,
    yigmgo: true,
    pages: [],
  };

  let autosaveTimer = null;
  const LS_KEY = 'pechaforge-draft';

  // ─── DOM refs ───────────────────────────────────────────────────────────
  const textarea      = document.getElementById('pf-textarea');
  const pagesContainer = document.getElementById('pf-pages');
  const previewHeader = document.getElementById('preview-header');
  const previewLabel  = document.getElementById('preview-label');
  const charcount     = document.getElementById('charcount');
  const inputSection  = document.getElementById('input-section');
  const fileLoad      = document.getElementById('file-load');

  const selFont       = document.getElementById('set-font');
  const selTheme      = document.getElementById('set-theme');
  const inpTitle      = document.getElementById('set-title');
  const inpFolio      = document.getElementById('set-folio-start');
  const inpLines      = document.getElementById('set-lines');
  const btnIme        = document.getElementById('set-ime');
  const btnYigmgo     = document.getElementById('set-yigmgo');

  // ─── Helpers ────────────────────────────────────────────────────────────

  /** Convert Arabic integer to Tibetan numeral string. */
  function toTibetanNumeral(n) {
    return String(n).replace(/[0-9]/g, function (d) {
      return String.fromCharCode(0x0F20 + Number(d));
    });
  }

  /** Update character counter display. */
  function updateCharCount() {
    const len = [...textarea.value].length;
    charcount.textContent = len + ' char' + (len !== 1 ? 's' : '');
  }

  // ─── Pagination ─────────────────────────────────────────────────────────

  /**
   * Split text into pecha pages.
   * Lines are split on \n, grouped into chunks of linesPerPage.
   */
  function paginate(text, linesPerPage, folioStart) {
    if (!text.trim()) return [];

    let lines = text.split('\n');

    // Trim trailing empty lines
    while (lines.length > 0 && lines[lines.length - 1].trim() === '') {
      lines.pop();
    }
    if (lines.length === 0) return [];

    const pages = [];
    for (let i = 0; i < lines.length; i += linesPerPage) {
      const chunk = lines.slice(i, i + linesPerPage);
      pages.push({
        lines: chunk,
        folioNum: folioStart + pages.length,
        isFirst: pages.length === 0,
      });
    }
    return pages;
  }

  // ─── Tibetan line-breaking (from terma.js) ──────────────────────────────

  /** Insert ZWS after tsheg for line-break opportunities, protect shad pairs. */
  function prepareTibetan(el) {
    const TSHEG = '\u0F0B';
    const TSHEG_NB = '\u0F0C';
    const SHAD = '\u0F0D';
    const ZWS = '\u200B';
    const WJ = '\u2060';

    const walker = document.createTreeWalker(el, NodeFilter.SHOW_TEXT);
    const nodes = [];
    while (walker.nextNode()) nodes.push(walker.currentNode);

    for (let i = nodes.length - 1; i >= 0; i--) {
      let t = nodes[i].textContent;
      // Protect tsheg+shad from splitting
      t = t.replaceAll(TSHEG + SHAD, TSHEG_NB + SHAD);
      // Protect double shad
      t = t.replaceAll(SHAD + ' ' + SHAD, SHAD + WJ + ' ' + WJ + SHAD);
      // Insert ZWS after tsheg for line-break opportunities
      t = t.replace(new RegExp(TSHEG + '(?!' + ZWS + ')', 'g'), TSHEG + ZWS);
      if (t !== nodes[i].textContent) nodes[i].textContent = t;
    }
  }

  // ─── Render Preview ─────────────────────────────────────────────────────

  /** Build a single pecha page element (body or title). */
  function buildPechaPage(opts) {
    var themeClass = '';
    if (state.theme === 'dark') themeClass = ' tr-pecha-dark';
    else if (state.theme === 'bw') themeClass = ' pf-theme-bw';
    else if (state.theme === 'maroon') themeClass = ' pf-theme-maroon';
    var fontStyle = "font-family: '" + state.font + "', 'Noto Serif Tibetan', serif;";

    var el = document.createElement('div');
    el.className = 'tr-pecha' + themeClass + ' pf-page-item';
    if (opts.isTitlePage) el.classList.add('pf-title-page');
    el.setAttribute('lang', 'bo');
    el.style.cssText = fontStyle;

    // Title column (left margin)
    var titleCol = document.createElement('div');
    titleCol.className = 'tr-pecha-title';
    if (state.titleText && !opts.isTitlePage) {
      var titleSpan = document.createElement('span');
      titleSpan.className = 'pf-side-title';
      titleSpan.textContent = state.titleText;
      titleCol.appendChild(titleSpan);
    }

    // Body column
    var bodyCol = document.createElement('div');
    bodyCol.className = 'tr-pecha-body';

    if (opts.isTitlePage) {
      // Title page: large centered title text
      bodyCol.classList.add('pf-title-body');
      bodyCol.textContent = state.titleText || '';
    } else {
      if (opts.isFirstBody && state.yigmgo) {
        bodyCol.classList.add('tr-yig-mgo');
      }
      bodyCol.textContent = opts.lines.join('\n');
    }

    // Folio column (right margin)
    var folioCol = document.createElement('div');
    folioCol.className = 'tr-pecha-folio';
    if (!opts.isTitlePage) {
      folioCol.textContent = toTibetanNumeral(opts.folioNum);
    }

    el.appendChild(titleCol);
    el.appendChild(bodyCol);
    el.appendChild(folioCol);
    return el;
  }

  function renderPreview() {
    var pages = paginate(state.text, state.linesPerPage, state.folioStart);
    state.pages = pages;
    pagesContainer.innerHTML = '';

    if (pages.length === 0 && !state.titleText) {
      previewHeader.style.display = 'none';
      return;
    }

    // Preload the selected font so browser downloads it before painting
    if (document.fonts && document.fonts.load) {
      document.fonts.load("1em '" + state.font + "'", "\u0F40");
    }

    // Count: title page + body pages
    var totalPages = pages.length + (state.titleText ? 1 : 0);
    previewHeader.style.display = 'flex';
    previewLabel.textContent = totalPages + ' page' + (totalPages !== 1 ? 's' : '');

    // Collect all page elements
    var allPages = [];

    // 1. Title page (if title text is set)
    if (state.titleText) {
      allPages.push(buildPechaPage({ isTitlePage: true }));
    }

    // 2. Body pages
    pages.forEach(function (page, idx) {
      allPages.push(buildPechaPage({
        isTitlePage: false,
        isFirstBody: idx === 0,
        lines: page.lines,
        folioNum: page.folioNum,
      }));
    });

    // Group into sheets of 3 for print layout
    for (var i = 0; i < allPages.length; i += 3) {
      var sheet = document.createElement('div');
      sheet.className = 'pf-print-sheet';
      for (var j = i; j < Math.min(i + 3, allPages.length); j++) {
        sheet.appendChild(allPages[j]);
      }
      pagesContainer.appendChild(sheet);
    }

    // Apply Tibetan line-breaking to all body pages
    pagesContainer.querySelectorAll('.tr-pecha-body').forEach(function (body) {
      if (!body.closest('.pf-title-page')) prepareTibetan(body);
    });
  }

  // ─── IME Handler ────────────────────────────────────────────────────────

  function imeHandler(ev) {
    if (!state.imeEnabled) return;
    if (ev.ctrlKey || ev.metaKey || ev.altKey) return;
    if (IME_PASS.has(ev.key)) return;
    const mapped = IME_MAP[ev.key];
    if (mapped === undefined) return;

    ev.preventDefault();
    const el = ev.target;
    const s = el.selectionStart != null ? el.selectionStart : el.value.length;
    const e = el.selectionEnd != null ? el.selectionEnd : el.value.length;
    el.value = el.value.slice(0, s) + mapped + el.value.slice(e);
    const pos = s + mapped.length;
    el.setSelectionRange(pos, pos);
    el.dispatchEvent(new Event('input', { bubbles: true }));
  }

  // ─── Save / Load / localStorage ─────────────────────────────────────────

  function getProjectData() {
    return {
      version: 1,
      text: state.text,
      font: state.font,
      theme: state.theme,
      titleText: state.titleText,
      folioStart: state.folioStart,
      linesPerPage: state.linesPerPage,
      yigmgo: state.yigmgo,
    };
  }

  function loadProjectData(data) {
    if (!data || data.version !== 1) return false;

    state.text         = data.text || '';
    state.font         = data.font || 'Jomolhari';
    state.theme        = data.theme || 'light';
    state.titleText    = data.titleText || '';
    state.folioStart   = data.folioStart || 1;
    state.linesPerPage = data.linesPerPage || 7;
    state.yigmgo       = data.yigmgo !== false;

    // Sync DOM controls
    textarea.value      = state.text;
    selFont.value       = state.font;
    selTheme.value      = state.theme;
    inpTitle.value      = state.titleText;
    inpFolio.value      = String(state.folioStart);
    inpLines.value      = String(state.linesPerPage);
    btnYigmgo.textContent = state.yigmgo ? 'ON' : 'OFF';
    btnYigmgo.classList.toggle('active', state.yigmgo);

    updateCharCount();
    if (state.text.trim()) renderPreview();
    return true;
  }

  function saveProject() {
    const data = getProjectData();
    const json = JSON.stringify(data, null, 2);
    const blob = new Blob([json], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'pechaforge-project.json';
    a.click();
    URL.revokeObjectURL(url);
  }

  function loadProject(file) {
    const reader = new FileReader();
    reader.onload = function (e) {
      try {
        const data = JSON.parse(e.target.result);
        if (!loadProjectData(data)) {
          alert('Invalid PechaForge project file.');
        }
      } catch (_) {
        alert('Could not parse project file.');
      }
    };
    reader.readAsText(file);
  }

  function scheduleAutosave() {
    clearTimeout(autosaveTimer);
    autosaveTimer = setTimeout(function () {
      try {
        localStorage.setItem(LS_KEY, JSON.stringify(getProjectData()));
      } catch (_) { /* quota exceeded — silent */ }
    }, 1000);
  }

  const SEED_TITLE = '༄༅། །གསོལ་འདེབས་ལེའུ་བདུན་མ་བསྡུས་པ་བཞུགས་སོ། །';
  const SEED_TEXT = `ཨེ་མ་ཧོ༔
ཐོག་མའི་སངས་རྒྱས་ཆོས་སྐུ་ཀུན་ཏུ་བཟང་༔
རྒྱལ་བ་རབ་འབྱམས་དཀྱིལ་འཁོར་ལོངས་སྤྱོད་རྫོགས༔
གང་ལ་གང་འདུལ་གར་བསྒྱུར་སྤྲུལ་པའི་སྐུ༔
སྐུ་གསུམ་དབྱེར་མེད་ཨོ་རྒྱན་རིན་པོ་ཆེ༔
གསོལ་བ་འདེབས་སོ་ཐུགས་རྗེས་སྤྱན་གྱིས་གཟིགས༔
བྱིན་གྱིས་རློབས་ཤིག་ཐར་པའི་ལམ་སྣ་དྲོངས༔
སྣང་བ་མཐའ་ཡས་སངས་རྒྱས་འོད་དཔག་མེད༔
འཇིག་རྟེན་དབང་ཕྱུག་བྱམས་མགོན་སྤྱན་རས་གཟིགས༔
དཀྱིལ་འཁོར་གཙོ་བོ་ཁྲག་འཐུང་ཧེ་རུ་ཀ༔
ཀུན་གྱི་བདག་ཉིད་ཨོ་རྒྱན་རིན་པོ་ཆེ༔
གསོལ་བ་འདེབས་སོ་ཐུགས་རྗེས་སྤྱན་གྱིས་གཟིགས༔
བྱིན་གྱིས་རློབས་ཤིག་ཐར་པའི་ལམ་སྣ་དྲོངས༔
དྷ་ན་ཀོ་ཤ་པདྨའི་སྦུབས་སུ་འཁྲུངས༔
ཨོ་རྒྱན་ཆོས་ཀྱི་རྒྱལ་པོའི་རྒྱལ་སྲིད་མཛད༔
མངལ་གྱི་མ་གོས་དྲི་མེད་སྤྲུལ་པའི་སྐུ༔
སྲིད་གསུམ་མཚུངས་མེད་ཨོ་རྒྱན་རིན་པོ་ཆེ༔
