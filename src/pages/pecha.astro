  function loadAutosave() {
    try {
      const raw = localStorage.getItem(LS_KEY);
      if (raw) {
        const data = JSON.parse(raw);
        loadProjectData(data);
        return;
      }
    } catch (_) { /* corrupted — ignore */ }
    // No saved state — load seed text
    state.text      = SEED_TEXT;
    state.titleText = SEED_TITLE;
    textarea.value  = SEED_TEXT;
    inpTitle.value  = SEED_TITLE;
    updateCharCount();
    renderPreview();
  }

  // ─── Event wiring ──────────────────────────────────────────────────────

  // Textarea
  textarea.addEventListener('keydown', imeHandler);
  textarea.addEventListener('input', function () {
    state.text = textarea.value;
    updateCharCount();
    scheduleAutosave();
  });

  // Title input also gets IME
  inpTitle.addEventListener('keydown', imeHandler);

  // Settings → state + re-render
  selFont.addEventListener('change', function (e) {
    state.font = e.target.value;
    var ff = "'PechaLatin', '" + state.font + "', 'Noto Serif Tibetan', serif";
    // Update textarea + title input font to match
    textarea.style.fontFamily = ff;
    inpTitle.style.fontFamily = ff;
    scheduleAutosave();
    if (state.pages.length) renderPreview();
  });

  selTheme.addEventListener('change', function (e) {
    state.theme = e.target.value;
    scheduleAutosave();
    if (state.pages.length) renderPreview();
  });

  inpTitle.addEventListener('input', function (e) {
    state.titleText = e.target.value;
    scheduleAutosave();
    if (state.pages.length) renderPreview();
  });

  inpFolio.addEventListener('change', function (e) {
    state.folioStart = parseInt(e.target.value) || 1;
    scheduleAutosave();
    if (state.pages.length) renderPreview();
  });

  inpLines.addEventListener('change', function (e) {
    state.linesPerPage = Math.min(parseInt(e.target.value) || 4, 4);
    scheduleAutosave();
    if (state.pages.length) renderPreview();
  });

  // IME toggle
  btnIme.addEventListener('click', function () {
    state.imeEnabled = !state.imeEnabled;
    btnIme.textContent = state.imeEnabled ? 'ON' : 'OFF';
    btnIme.classList.toggle('active', state.imeEnabled);
  });

  // Yig mgo toggle
  btnYigmgo.addEventListener('click', function () {
    state.yigmgo = !state.yigmgo;
    btnYigmgo.textContent = state.yigmgo ? 'ON' : 'OFF';
    btnYigmgo.classList.toggle('active', state.yigmgo);
    scheduleAutosave();
    if (state.pages.length) renderPreview();
  });

  // Action buttons
  document.getElementById('btn-generate').addEventListener('click', function () {
    state.text = textarea.value;
    renderPreview();
  });

  document.getElementById('btn-print').addEventListener('click', function () {
    if (!state.pages.length) {
      state.text = textarea.value;
      renderPreview();
    }
    if (state.pages.length) window.print();
  });

  document.getElementById('btn-print-duplex').addEventListener('click', function () {
    state.text = textarea.value;
    // Ensure visual-overflow pages are current
    if (!state.pages.length && (state.text.trim() || state.titleText)) {
      renderPreview();
    }
    if (state.pages.length === 0 && !state.titleText) return;

    // Build ALL pages in order: cover first, then body pages
    var allDuplexPages = [];
    if (state.titleText) {
      allDuplexPages.push(buildPechaPage({ isTitlePage: true }));
    }
    state.pages.forEach(function (page) {
      allDuplexPages.push(buildPechaPage({
        isTitlePage: false,
        isFirstBody: page.isFirst,
        lines: page.lines,
        folioNum: page.folioNum,
      }));
    });

    // Pad to a multiple of 6 with invisible blank pages so strips pair cleanly
    while (allDuplexPages.length % 6 !== 0) {
      var blank = buildPechaPage({ isTitlePage: false, isFirstBody: false, lines: [''], folioNum: 0 });
      blank.style.visibility = 'hidden';
      allDuplexPages.push(blank);
    }

    // Save current preview and replace with duplex layout
    var savedHTML = pagesContainer.innerHTML;
    pagesContainer.innerHTML = '';

    // Group pages into sheets of 6:
    //   Front sheet: positions 0, 2, 4 → strips 1, 2, 3 of front side
    //   Back sheet:  positions 1, 3, 5 → strips 1, 2, 3 of back side (SAME order)
    //
    // After cutting into 3 strips:
    //   Strip 1: front=allPages[0] / back=allPages[1]
    //   Strip 2: front=allPages[2] / back=allPages[3]
    //   Strip 3: front=allPages[4] / back=allPages[5]
    //
    // Printer must use "flip on long edge" (landscape, bind along top).
    // Top of front aligns with top of back — no reversal needed.
    for (var i = 0; i < allDuplexPages.length; i += 6) {
      var chunk = allDuplexPages.slice(i, i + 6);

      // Front sheet: pages at even positions (0, 2, 4) — top to bottom
      var frontSheet = document.createElement('div');
      frontSheet.className = 'pf-print-sheet';
      frontSheet.appendChild(chunk[0]);
      if (chunk[2]) frontSheet.appendChild(chunk[2]);
      if (chunk[4]) frontSheet.appendChild(chunk[4]);
      pagesContainer.appendChild(frontSheet);

      // Back sheet: pages at odd positions (1, 3, 5) — same top-to-bottom order
      var backSheet = document.createElement('div');
      backSheet.className = 'pf-print-sheet';
      backSheet.appendChild(chunk[1]);
      if (chunk[3]) backSheet.appendChild(chunk[3]);
      if (chunk[5]) backSheet.appendChild(chunk[5]);
      pagesContainer.appendChild(backSheet);
    }

    // Add duplex class to body for print styling
    document.body.classList.add('pf-duplex-mode');
    window.print();
    document.body.classList.remove('pf-duplex-mode');

    // Restore normal preview
    pagesContainer.innerHTML = savedHTML;
  });

  document.getElementById('btn-save').addEventListener('click', saveProject);

  document.getElementById('btn-load').addEventListener('click', function () {
    fileLoad.click();
  });

  fileLoad.addEventListener('change', function (e) {
    if (e.target.files[0]) loadProject(e.target.files[0]);
    e.target.value = '';
  });

  // Toggle input visibility
  document.getElementById('btn-toggle-input').addEventListener('click', function () {
    const ta = inputSection.querySelector('.pf-textarea');
    ta.classList.toggle('pf-hidden');
    this.textContent = ta.classList.contains('pf-hidden') ? 'Show Input' : 'Hide Input';
  });

  // ─── Init ───────────────────────────────────────────────────────────────
  loadAutosave();
</script>


