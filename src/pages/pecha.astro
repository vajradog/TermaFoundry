<style is:global>

  /* ─── Latin font fallback for pecha pages ─────────────────────────────
     Tibetan fonts (Jomolhari, etc.) contain ugly Latin glyphs.
     This @font-face maps a clean serif to 'PechaLatin' for Latin-only
     unicode range, so English text renders cleanly while Tibetan
     characters still use the selected Tibetan font. ──────────────────── */
  @font-face {
    font-family: 'PechaLatin';
    src: local('Georgia'), local('Noto Serif'), local('Times New Roman'), local('serif');
    unicode-range: U+0000-007F, U+0080-00FF, U+0100-024F, U+2000-206F, U+2070-209F, U+20A0-20CF, U+2100-214F;
    font-display: swap;
  }

  /* ─── Page shell ──────────────────────────────────────────────────────── */
  /* ─── Beta badge ──────────────────────────────────────────────────────── */
  .pf-beta {
    font-size: .5em; font-weight: 700; vertical-align: super;
    padding: .15em .5em; border-radius: 4px;
    background: rgba(56,189,248,0.12); color: var(--accent);
    border: 1px solid rgba(56,189,248,0.2);
    letter-spacing: .06em;
  }

  .pf-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 1rem 2rem 3rem;
  }

  /* ─── Toolbar ─────────────────────────────────────────────────────────── */
  .pf-toolbar {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1rem 1.25rem;
    margin-bottom: 1rem;
  }
  .pf-toolbar-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: .75rem;
    margin-bottom: .75rem;
  }
  .pf-title {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--text);
    letter-spacing: -.02em;
  }
  .pf-toolbar-actions {
    display: flex;
    gap: .5rem;
    align-items: center;
    flex-wrap: wrap;
  }

  /* ─── Settings ────────────────────────────────────────────────────────── */
  .pf-settings {
    display: flex;
    flex-wrap: wrap;
    gap: .75rem;
    align-items: flex-end;
  }
  .pf-setting {
    display: flex;
    flex-direction: column;
