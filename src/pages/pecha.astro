གསོལ་བ་འདེབས་སོ་ཐུགས་རྗེས་སྤྱན་གྱིས་གཟིགས༔
བྱིན་གྱིས་རློབས་ཤིག་ཐར་པའི་ལམ་སྣ་དྲོངས༔
འདི་ནས་བཟུང་སྟེ་ཐར་པ་མ་ཐོབ་བར༔
རེ་སའི་སྐྱབས་གནས་གཞན་ན་མ་མཆིས་པས༔
ཡེངས་མེད་ཐུགས་རྗེའི་སྤྱན་གྱིས་བདག་ལ་གཟིགས༔
མཆོག་དང་ཐུན་མོང་དངོས་གྲུབ་བདག་ལ་སྩོལ༔
ཀ་དག་རིག་པའི་ངོ་བོ་མཐོང་ནས་ཀྱང་༔
མྱུར་དུ་ཁྱེད་རང་ལྟ་བུར་བྱིན་གྱིས་རློབས༔`;

  function loadAutosave() {
    try {
      const raw = localStorage.getItem(LS_KEY);
      if (raw) {
        const data = JSON.parse(raw);
        loadProjectData(data);
        return;
      }
    } catch (_) { /* corrupted — ignore */ }
    // No saved state — load seed text
    state.text      = SEED_TEXT;
    state.titleText = SEED_TITLE;
    textarea.value  = SEED_TEXT;
    inpTitle.value  = SEED_TITLE;
    updateCharCount();
    renderPreview();
  }

  // ─── Event wiring ──────────────────────────────────────────────────────

  // Textarea
  textarea.addEventListener('keydown', imeHandler);
  textarea.addEventListener('input', function () {
    state.text = textarea.value;
    updateCharCount();
    scheduleAutosave();
  });

  // Title input also gets IME
  inpTitle.addEventListener('keydown', imeHandler);

  // Settings → state + re-render
  selFont.addEventListener('change', function (e) {
    state.font = e.target.value;
    // Update title input font to match
    inpTitle.style.fontFamily = "'" + state.font + "', 'Noto Serif Tibetan', serif";
    scheduleAutosave();
    if (state.pages.length) renderPreview();
  });

  selTheme.addEventListener('change', function (e) {
    state.theme = e.target.value;
    scheduleAutosave();
    if (state.pages.length) renderPreview();
  });

  inpTitle.addEventListener('input', function (e) {
    state.titleText = e.target.value;
    scheduleAutosave();
    if (state.pages.length) renderPreview();
  });

  inpFolio.addEventListener('change', function (e) {
    state.folioStart = parseInt(e.target.value) || 1;
    scheduleAutosave();
    if (state.pages.length) renderPreview();
  });

  inpLines.addEventListener('change', function (e) {
    state.linesPerPage = parseInt(e.target.value) || 7;
    scheduleAutosave();
    if (state.pages.length) renderPreview();
  });

  // IME toggle
  btnIme.addEventListener('click', function () {
    state.imeEnabled = !state.imeEnabled;
    btnIme.textContent = state.imeEnabled ? 'ON' : 'OFF';
    btnIme.classList.toggle('active', state.imeEnabled);
  });

  // Yig mgo toggle
  btnYigmgo.addEventListener('click', function () {
    state.yigmgo = !state.yigmgo;
    btnYigmgo.textContent = state.yigmgo ? 'ON' : 'OFF';
    btnYigmgo.classList.toggle('active', state.yigmgo);
    scheduleAutosave();
    if (state.pages.length) renderPreview();
  });

  // Action buttons
  document.getElementById('btn-generate').addEventListener('click', function () {
    state.text = textarea.value;
    renderPreview();
  });

  document.getElementById('btn-print').addEventListener('click', function () {
    if (!state.pages.length) {
      state.text = textarea.value;
      renderPreview();
    }
    if (state.pages.length) window.print();
  });

  document.getElementById('btn-print-duplex').addEventListener('click', function () {
    state.text = textarea.value;
    var pages = paginate(state.text, state.linesPerPage, state.folioStart);
    if (pages.length === 0 && !state.titleText) return;

    // Build all body page elements
    var bodyPages = pages.map(function (page, idx) {
      return buildPechaPage({
        isTitlePage: false,
        isFirstBody: idx === 0,
        lines: page.lines,
        folioNum: page.folioNum,
      });
    });

    // Save current preview and replace with duplex layout
    var savedHTML = pagesContainer.innerHTML;
    pagesContainer.innerHTML = '';

    // Sheet 1 (front): Title/cover page with instructions
    var coverSheet = document.createElement('div');
    coverSheet.className = 'pf-print-sheet pf-duplex-cover';
    if (state.titleText) {
      coverSheet.appendChild(buildPechaPage({ isTitlePage: true }));
    }
    var instr = document.createElement('div');
    instr.className = 'pf-duplex-instructions';
    instr.innerHTML =
      '<strong>Double-Sided Printing Instructions</strong><br>' +
      'Print with duplex enabled (flip on long edge).<br>' +
      'After printing, cut each sheet into 3 horizontal strips.<br>' +
      'Each strip becomes a double-sided pecha leaf.';
    coverSheet.appendChild(instr);
    pagesContainer.appendChild(coverSheet);

    // Sheet 2 (back of cover): blank
    var blankSheet = document.createElement('div');
    blankSheet.className = 'pf-print-sheet pf-duplex-blank';
    pagesContainer.appendChild(blankSheet);

    // Arrange body pages for duplex: groups of 6
    // Front sheet: pages 0, 2, 4 (odd pecha pages: 1, 3, 5)
    // Back sheet:  pages 1, 3, 5 (even pecha pages: 2, 4, 6)
    for (var i = 0; i < bodyPages.length; i += 6) {
      var chunk = bodyPages.slice(i, Math.min(i + 6, bodyPages.length));

      // Front sheet (odd pages: positions 0, 2, 4)
      var frontSheet = document.createElement('div');
      frontSheet.className = 'pf-print-sheet';
      for (var f = 0; f < chunk.length; f += 2) {
        frontSheet.appendChild(chunk[f]);
      }
      pagesContainer.appendChild(frontSheet);

      // Back sheet (even pages in REVERSE order for long-edge flip)
      // Front: 1,3,5 top→bottom. When flipped on long edge, top↔bottom.
      // So back must be: 6,4,2 (top→bottom) to align 1↔2, 3↔4, 5↔6.
      var backPages = [];
      for (var b = 1; b < chunk.length; b += 2) {
        backPages.push(chunk[b]);
      }
      backPages.reverse();
      var backSheet = document.createElement('div');
      backSheet.className = 'pf-print-sheet';
      for (var bp = 0; bp < backPages.length; bp++) {
        backSheet.appendChild(backPages[bp]);
      }
      if (backSheet.children.length > 0) {
        pagesContainer.appendChild(backSheet);
      }
    }

    // Apply Tibetan line-breaking
    pagesContainer.querySelectorAll('.tr-pecha-body').forEach(function (body) {
      if (!body.closest('.pf-title-page')) prepareTibetan(body);
    });

    // Add duplex class to body for print styling
    document.body.classList.add('pf-duplex-mode');
    window.print();
    document.body.classList.remove('pf-duplex-mode');

    // Restore normal preview
    pagesContainer.innerHTML = savedHTML;
  });

  document.getElementById('btn-save').addEventListener('click', saveProject);

  document.getElementById('btn-load').addEventListener('click', function () {
    fileLoad.click();
  });

  fileLoad.addEventListener('change', function (e) {
    if (e.target.files[0]) loadProject(e.target.files[0]);
    e.target.value = '';
  });

  // Toggle input visibility
  document.getElementById('btn-toggle-input').addEventListener('click', function () {
    const ta = inputSection.querySelector('.pf-textarea');
    ta.classList.toggle('pf-hidden');
    this.textContent = ta.classList.contains('pf-hidden') ? 'Show Input' : 'Hide Input';
  });

  // ─── Init ───────────────────────────────────────────────────────────────
  loadAutosave();
</script>


