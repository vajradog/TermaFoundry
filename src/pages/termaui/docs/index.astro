      </div>
      <div class="code-block">
        <div class="code-block-header">
          <span class="code-block-title">HTML</span>
          <button class="copy-btn">Copy</button>
        </div>
        <pre><code><span class="tag">&lt;p</span> <span class="attr">class</span>=<span class="str">"tr-jomolhari tr-guard <span class="hl">tr-text-rainbow</span>"</span> <span class="attr">lang</span>=<span class="str">"bo"</span><span class="tag">&gt;</span>
