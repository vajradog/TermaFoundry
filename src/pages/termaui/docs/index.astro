        <pre><code><span class="tag">&lt;p</span> <span class="attr">class</span>=<span class="str">"tr-jomolhari tr-guard <span class="hl">tr-text-center</span>"</span> <span class="attr">lang</span>=<span class="str">"bo"</span><span class="tag">&gt;</span>
  བཀྲ་ཤིས་བདེ་ལེགས།
<span class="tag">&lt;/p&gt;</span></code></pre>
