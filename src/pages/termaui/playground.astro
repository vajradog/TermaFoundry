};

let activeStartTab = 'html';
function switchStartTab(tab, btn) {
  activeStartTab = tab;
  document.querySelectorAll('#startTabs .pg-tab').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('startCode').textContent = START_SNIPPETS[tab];
}

// ─── Serialize editor ──────────────────────────────────────
function serializeForCode() {
  const clone = editor.cloneNode(true);
  [clone, ...clone.querySelectorAll('[data-terma-prepared],[data-terma-normalized]')]
    .forEach(el => {
      el.removeAttribute('data-terma-prepared');
      el.removeAttribute('data-terma-normalized');
    });
  const tw = document.createTreeWalker(clone, NodeFilter.SHOW_TEXT);
  const textNodes = [];
  let n;
  while ((n = tw.nextNode())) textNodes.push(n);
  textNodes.forEach(n => {
    n.textContent = n.textContent
      .replace(/\u200B/g, '')
      .replace(/\u2060/g, '')
      .replace(/\u0F0C/g, '\u0F0B');
  });
  const hasMixed = clone.querySelector('span') !== null;
  return hasMixed
    ? { isHTML: true,  content: clone.innerHTML.trim() }
    : { isHTML: false, content: clone.textContent.trim() };
}

// ─── Code generation ───────────────────────────────────────
let activeCodeTab = 'html';

function getActiveClasses() {
  return [...editor.classList].filter(c =>
    FONT_CLASSES.includes(c) || SIZE_CLASSES.includes(c) ||
    EFFECT_CLASSES.includes(c) || c === 'tr-guard' || c === 'tr-ligatures' ||
    c === 'tr-stack-safe' || c === 'tr-baseline' || c === 'tr-scale-match'
  );
}

function buildCode(tab) {
  const classes = getActiveClasses().join(' ');
  const { content } = serializeForCode();
  const inner = '\n  ' + content.replace(/\n/g, '\n  ') + '\n';
  if (tab === 'html')   return `<p class="${classes}" lang="bo">${inner}</p>`;
  if (tab === 'react')  return `<p className="${classes}" lang="bo">${inner}</p>`;
  if (tab === 'vue')    return `<p class="${classes}" lang="bo">${inner}</p>`;
  if (tab === 'astro2') return `<p class="${classes}" lang="bo">${inner}</p>`;
}

function updateCode() {
  document.getElementById('codeOutput').textContent = buildCode(activeCodeTab);
}
function switchCodeTab(tab, btn) {
  activeCodeTab = tab;
  document.querySelectorAll('#codeTabs .pg-tab').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');
  updateCode();
}

// ─── Editor input ──────────────────────────────────────────
let prepareTimer = null;
function onEditorInput() {
  updateCode();
  clearTimeout(prepareTimer);
  prepareTimer = setTimeout(() => {
    delete editor.dataset.termaPrepared;
    terma.prepare(editor);
  }, 400);
}

// ─── IME handler ───────────────────────────────────────────
editor.addEventListener('keydown', (ev) => {
  if (!imeActive) return;
  if (ev.ctrlKey || ev.metaKey || ev.altKey) return;
  if (IME_PASSTHROUGH.has(ev.key)) return;
  const ch = IME_MAP[ev.key];
  if (ch === undefined) return;
  ev.preventDefault();
  document.execCommand('insertText', false, ch);
});
function toggleIME(btn) {
  imeActive = btn.classList.toggle('active');
  editor.dataset.imeHint = imeActive ? 'on' : '';
}

// ─── Selection save ────────────────────────────────────────
let savedRange = null;
editor.addEventListener('mouseup', () => {
  const sel = window.getSelection();
  if (sel && !sel.isCollapsed && editor.contains(sel.anchorNode)) {
    savedRange = sel.getRangeAt(0).cloneRange();
  } else { savedRange = null; }
});
editor.addEventListener('keyup', () => {
  const sel = window.getSelection();
  if (sel && !sel.isCollapsed && editor.contains(sel.anchorNode)) {
    savedRange = sel.getRangeAt(0).cloneRange();
  } else { savedRange = null; }
});

// ─── Toolbar apply ─────────────────────────────────────────
function applyFromToolbar(type, value) {
  const sel = window.getSelection();
  const liveHasSel = sel && !sel.isCollapsed && editor.contains(sel.anchorNode);
  const rangeToUse = liveHasSel ? sel.getRangeAt(0) : savedRange;

  if (rangeToUse && !rangeToUse.collapsed) {
    sel.removeAllRanges();
    sel.addRange(rangeToUse);
    const span = document.createElement('span');
    span.classList.add(value);
    try {
      rangeToUse.surroundContents(span);
    } catch (e) {
      const fragment = rangeToUse.extractContents();
      span.appendChild(fragment);
      rangeToUse.insertNode(span);
    }
    sel.removeAllRanges();
    savedRange = null;
    delete editor.dataset.termaPrepared;
    terma.prepare(editor);
  } else {
    const pool = type === 'font' ? FONT_CLASSES : SIZE_CLASSES;
    pool.forEach(c => editor.classList.remove(c));
    if (value) editor.classList.add(value);
  }
  updateCode();
}

function clearAllSpans() {
  [...editor.querySelectorAll('span')].forEach(span => {
    const p = span.parentNode;
    while (span.firstChild) p.insertBefore(span.firstChild, span);
    p.removeChild(span);
  });
  editor.normalize();
  delete editor.dataset.termaPrepared;
  updateCode();
}

// ─── Effects ───────────────────────────────────────────────
function toggleEffect(chip) {
  const cls = chip.dataset.class;
  const isActive = chip.classList.contains('active');
  EFFECT_CLASSES.forEach(c => editor.classList.remove(c));
  document.querySelectorAll('.pg-effect-chip').forEach(c => c.classList.remove('active'));
  if (!isActive) { editor.classList.add(cls); chip.classList.add('active'); }
  updateCode();
}
function clearEffects() {
  EFFECT_CLASSES.forEach(c => editor.classList.remove(c));
  document.querySelectorAll('.pg-effect-chip').forEach(c => c.classList.remove('active'));
  updateCode();
}
function toggleStackSafe(btn) {
  const on = btn.classList.toggle('active');
  if (on) editor.classList.add('tr-stack-safe');
  else editor.classList.remove('tr-stack-safe');
  updateCode();
}
function toggleMixed(btn) {
  const on = btn.classList.toggle('active');
  if (on) { editor.classList.add('tr-baseline', 'tr-scale-match'); }
  else { editor.classList.remove('tr-baseline', 'tr-scale-match'); }
  updateCode();
}

// ─── Editor actions ────────────────────────────────────────
function resetEditor() {
  editor.innerHTML = '';
  clearEffects();
  editor.classList.remove('tr-stack-safe','tr-baseline','tr-scale-match');
  ['stackSafeBtn','mixedBtn'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.classList.remove('active');
  });
  delete editor.dataset.termaPrepared;
  terma.prepare(editor);
  updateCode();
}

// ─── Copy button ───────────────────────────────────────────
function copyCode(btn, targetId) {
  const text = document.getElementById(targetId).textContent;
  navigator.clipboard.writeText(text).then(() => {
    btn.textContent = 'Copied!';
    btn.classList.add('copied');
    setTimeout(() => { btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 1800);
  });
}

// ─── Selection scope label ─────────────────────────────────
document.addEventListener('selectionchange', () => {
  const sel = window.getSelection();
  const hasSel = sel && !sel.isCollapsed && editor.contains(sel.anchorNode);
  const scope = document.getElementById('toolbarScope');
  if (!scope) return;
  if (hasSel) {
    const len = sel.toString().length;
    scope.textContent = `${len} char${len !== 1 ? 's' : ''} selected`;
    scope.className = 'pg-tb-scope active';
  } else if (savedRange && !savedRange.collapsed) {
    const len = savedRange.toString().length;
    scope.textContent = `${len} char${len !== 1 ? 's' : ''} selected`;
    scope.className = 'pg-tb-scope active';
  } else {
    scope.textContent = 'whole block';
    scope.className = 'pg-tb-scope';
  }
});

// ─── Tests ─────────────────────────────────────────────────
function runAllTests() {
  const clone = editor.cloneNode(true);
  delete clone.dataset.termaPrepared;
  terma.prepare(clone);
  document.getElementById('tsample1').textContent = editor.textContent.trim().slice(0, 60);
  const hasZWS = clone.textContent.includes('\u0F0B\u200B');
  setTestResult('tresult1', hasZWS,
    'PASS — ZWS inserted after tsheg (line-breaking enabled)',
    'SKIP — no tsheg found (add Tibetan text in the playground first)');

  [
    { id: 2, el: 'tsample2', check: '\u0F0C\u0F0D', pass: 'PASS — ་། → ༌། (tsheg before shad protected)',      fail: 'FAIL — tsheg before shad not converted' },
    { id: 3, el: 'tsample3', check: '\u0F0C\u0F0E', pass: 'PASS — ་༎ → ༌༎ (nyis-shad protected)',             fail: 'FAIL — tsheg before nyis-shad not converted' },
    { id: 4, el: 'tsample4', check: '\u0F0C\u0F14', pass: 'PASS — ་༔ → ༌༔ (gter-ma protected)',               fail: 'FAIL — tsheg before gter-ma not converted' },
    { id: 5, el: 'tsample5', check: '\u0F0D\u2060', pass: 'PASS — double-shad (། །) protected with word-joiners', fail: 'FAIL — double-shad not protected' },
  ].forEach(({ id, el, check, pass, fail }) => {
    const node = document.getElementById(el);
    delete node.dataset.termaPrepared;
    terma.prepare(node);
    setTestResult('tresult' + id, node.textContent.includes(check), pass, fail);
  });

  const prepared = editor.dataset.termaPrepared === 'true';
  document.getElementById('tsample6').textContent = editor.textContent.trim().slice(0, 60);
  setTestResult('tresult6', prepared,
    'PASS — terma.prepare() has been run on editor content',
    'NOTE — type or paste in the playground to trigger terma.prepare() automatically');
}

function setTestResult(id, pass, passMsg, failMsg) {
  const el = document.getElementById(id);
  el.textContent = pass ? passMsg : failMsg;
  el.className = 'pg-test-result ' + (pass ? 'pass' : 'fail');
}

// ─── Boot ──────────────────────────────────────────────────
window.addEventListener('DOMContentLoaded', () => {
  checkCSS();
  checkJS();
  checkFonts();
  document.getElementById('startCode').textContent = START_SNIPPETS.html;
  terma.prepare(editor);
  updateCode();
});
</script>


