// ─── Status checks ─────────────────────────────────────────
function setDot(id, ok, msg) {
  const dot = document.getElementById('dot' + id);
  if (dot) { dot.style.background = ok ? '#4caf50' : '#f44336'; }
  const lbl = document.getElementById('lbl' + id);
  if (lbl) lbl.textContent = msg;
}
function checkCSS() {
  const el = document.createElement('div');
  el.className = 'tr-jomolhari';
  el.style.cssText = 'position:absolute;visibility:hidden';
  document.body.appendChild(el);
  const ok = getComputedStyle(el).fontFamily.toLowerCase().includes('jomolhari');
  document.body.removeChild(el);
  setDot('CSS', ok, ok ? 'termaui.css loaded ✓' : 'termaui.css NOT loaded ✗');
}
function checkJS() {
  const ok = typeof terma !== 'undefined';
  setDot('JS', ok, ok ? 'terma.js loaded ✓' : 'terma.js NOT loaded ✗');
}
async function checkFonts() {
  await document.fonts.ready;
  const all = [...document.fonts];
  const loaded = all.filter(f => f.status === 'loaded').length;
  setDot('Fonts', loaded > 0, loaded + '/' + all.length + ' fonts loaded');
}

// ─── Quick-start snippets ──────────────────────────────────
const START_SNIPPETS = {
