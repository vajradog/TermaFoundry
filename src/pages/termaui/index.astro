  // Code for each layout
  const L = (n, h) => `<span class="ln">${String(n).padStart(2)}</span>  ${h}`;
  const T = s => `<span class="t">${s}</span>`;
  const A = s => `<span class="a">${s}</span>`;
  const S = s => `<span class="s">${s}</span>`;
  const HL = s => `<span class="s hl">${s}</span>`;

  const codeBlocks = [
    // Plain — no classes, just raw HTML
    [
      L(1,  `${T('&lt;!-- No framework, just HTML --&gt;')}`),
      L(2,  ``),
      L(3,  `${T('&lt;p')} ${A('lang')}=${S('"bo"')}${T('&gt;')}`),
      L(4,  `  དངོས་གྲུབ་མཆོག་བརྙེས་ཡ་མཚན་ཆེན་པོ་ཡིས། །`),
      L(5,  `  འཇིག་རྟེན་མ་འགྱུར་པདྨའི་རྒྱལ་པོ་ལས། །`),
      L(6,  `  དེ་བཞིན་གཤེགས་པའི་མན་ངག་གསང་ཆེན་རྣམས། །`),
      L(7,  `  ཀློང་ནས་བཀྲོལ་མཛད་དེ་ལ་ཕྱག་འཚལ་ལོ། །`),
      L(8,  `${T('&lt;/p&gt;')}`),
    ].join('\n'),
    // + Font — add two classes, everything changes
    [
      L(1,  `${T('&lt;!-- Add two classes. That\'s it. --&gt;')}`),
      L(2,  ``),
      L(3,  `${T('&lt;p')} ${A('class')}=${HL('"tr-jomolhari tr-guard"')}`),
      L(4,  `   ${A('lang')}=${S('"bo"')}${T('&gt;')}`),
      L(5,  `  དངོས་གྲུབ་མཆོག་བརྙེས་ཡ་མཚན་ཆེན་པོ་ཡིས། །`),
      L(6,  `  འཇིག་རྟེན་མ་འགྱུར་པདྨའི་རྒྱལ་པོ་ལས། །`),
      L(7,  `  དེ་བཞིན་གཤེགས་པའི་མན་ངག་གསང་ཆེན་རྣམས། །`),
      L(8,  `  ཀློང་ནས་བཀྲོལ་མཛད་དེ་ལ་ཕྱག་འཚལ་ལོ། །`),
      L(9,  `${T('&lt;/p&gt;')}`),
    ].join('\n'),
    // + Effect — one more class for saffron gradient
    [
      L(1,  `${T('&lt;!-- One more class for the effect --&gt;')}`),
      L(2,  ``),
      L(3,  `${T('&lt;p')} ${A('class')}=${S('"tr-jomolhari')} ${HL('"tr-text-saffron"')}`),
      L(4,  `   ${S('"tr-guard"')} ${A('lang')}=${S('"bo"')}${T('&gt;')}`),
      L(5,  `  དངོས་གྲུབ་མཆོག་བརྙེས་ཡ་མཚན་ཆེན་པོ་ཡིས། །`),
      L(6,  `  འཇིག་རྟེན་མ་འགྱུར་པདྨའི་རྒྱལ་པོ་ལས། །`),
      L(7,  `  དེ་བཞིན་གཤེགས་པའི་མན་ངག་གསང་ཆེན་རྣམས། །`),
      L(8,  `  ཀློང་ནས་བཀྲོལ་མཛད་དེ་ལ་ཕྱག་འཚལ་ལོ། །`),
      L(9,  `${T('&lt;/p&gt;')}`),
    ].join('\n'),
    // In Context — bilingual real component
    [
      L(1,  `${T('&lt;article&gt;')}`),
      L(2,  `  ${T('&lt;h3')} ${A('lang')}=${S('"bo"')}${T('&gt;')}པདྨའི་རྒྱལ་པོའི་བསྟོད་པ།${T('&lt;/h3&gt;')}`),
      L(3,  `  ${T('&lt;p')} ${A('class')}=${HL('"tr-jomolhari tr-text-saffron tr-guard"')}`),
      L(4,  `     ${A('lang')}=${S('"bo"')}${T('&gt;')}`),
      L(5,  `    དངོས་གྲུབ་མཆོག་བརྙེས་ཡ་མཚན་ཆེན་པོ་ཡིས། །`),
      L(6,  `  ${T('&lt;/p&gt;')}`),
      L(7,  `  ${T('&lt;p&gt;')}A homage to`),
      L(8,  `    ${T('&lt;span')} ${A('class')}=${HL('"tr-jomolhari tr-scale-up"')}`),
      L(9,  `      ${HL('"tr-baseline"')} ${A('lang')}=${S('"bo"')}${T('&gt;')}`),
      L(10, `      པདྨའི་རྒྱལ་པོ`),
      L(11, `    ${T('&lt;/span&gt;')} — the Lotus King.`),
      L(12, `  ${T('&lt;/p&gt;')}`),
      L(13, `${T('&lt;/article&gt;')}`),
    ].join('\n'),
  ];

  const cardEl = document.getElementById('demo-card');
  const codeEl = document.getElementById('editor-code');
  const tabs = document.querySelectorAll('.editor-tab');

  let current = 0;
  let timer;

  function setStep(i) {
    current = i;
    tabs.forEach((t, j) => t.classList.toggle('active', j === i));

    // Crossfade card
    cardEl.style.opacity = '0';
    cardEl.style.transform = 'scale(0.97)';
    setTimeout(() => {
      cardEl.className = 'demo-card';
      cardEl.innerHTML = cardLayouts[i]();
      cardEl.style.opacity = '1';
      cardEl.style.transform = 'scale(1)';
    }, 250);

    // Crossfade code
    codeEl.style.opacity = '0';
    setTimeout(() => {
      codeEl.innerHTML = codeBlocks[i];
      codeEl.style.opacity = '1';
    }, 150);
  }

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      setStep(parseInt(tab.dataset.step));
      clearInterval(timer);
      timer = setInterval(() => setStep((current + 1) % 4), 5000);
    });
  });

  setStep(0);
  timer = setInterval(() => setStep((current + 1) % 4), 5000);
</script>

