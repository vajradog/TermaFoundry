    { file: 'monlam-uni-sans',        label: 'Monlam Sans',            cat: 'sans' },
    { file: 'monlam-uni-tikrang',     label: 'Monlam Tikrang',         cat: 'experimental' },
    { file: 'monlam-uni-tiktong',     label: 'Monlam Tiktong',         cat: 'experimental' },
    { file: 'noto-sans-tibetan',      label: 'Noto Sans Tibetan',      cat: 'sans' },
    { file: 'noto-serif-tibetan-regular', label: 'Noto Serif Regular',  cat: 'uchen' },
    { file: 'noto-serif-tibetan-bold',    label: 'Noto Serif Bold',     cat: 'uchen' },
