  /* Problem codepoints — known rendering hazards */
  const PROBLEM_CODEPOINTS = new Set([
    0x0F0B, // tsheg — line-break issues
    0x0F7E, // anusvara — stacking issues
    0x0F39, // tsa-phru
    0x0F35, // ngas bzung nyi zla
    0x0F37, // ngas bzung sgor rtags
    0x0F71, // vowel sign aa — complex stacking
    0x0F73, // vowel sign ii — precomposed
    0x0F75, // vowel sign uu — precomposed
    0x0F77, // vocalic rr — deprecated
    0x0F79, // vocalic ll — deprecated
    0x0F81, // reversed ii — precomposed
    0x0F84, // halanta — virama behavior
  ]);

  function getCategory(cp) {
    if (cp >= 0x0F40 && cp <= 0x0F6C) return 'consonant';
    if (cp >= 0x0F90 && cp <= 0x0FBC) return 'subjoined';
    if ((cp >= 0x0F71 && cp <= 0x0F7D) || cp === 0x0F80 || cp === 0x0F81) return 'vowel';
    if (cp === 0x0F7E || cp === 0x0F7F || (cp >= 0x0F82 && cp <= 0x0F87) ||
        cp === 0x0F35 || cp === 0x0F37 || cp === 0x0F39 ||
        cp === 0x0FC6) return 'mark';
    if ((cp >= 0x0F04 && cp <= 0x0F14) || cp === 0x0F85 ||
        (cp >= 0x0FD0 && cp <= 0x0FDA) || cp === 0x0F34) return 'punctuation';
    if (cp >= 0x0F20 && cp <= 0x0F33) return 'digit';
    if (cp === 0x0020 || cp === 0x00A0 || cp === 0x200B || cp === 0x200D) return 'space';
    if (cp >= 0x0F00 && cp <= 0x0FFF) return 'other';
    return 'other';
  }

  function getUnicodeName(cp) {
    if (TIBETAN_NAMES[cp]) return TIBETAN_NAMES[cp];
    if (cp === 0x0020) return 'SPACE';
    if (cp === 0x000A) return 'LINE FEED';
    if (cp === 0x000D) return 'CARRIAGE RETURN';
    if (cp === 0x00A0) return 'NO-BREAK SPACE';
    if (cp === 0x200B) return 'ZERO WIDTH SPACE';
    if (cp === 0x200D) return 'ZERO WIDTH JOINER';
    if (cp === 0x0F0C) return 'TIBETAN MARK DELIMITER TSHEG BSTAR';
    if (cp >= 0x0041 && cp <= 0x005A) return 'LATIN CAPITAL LETTER ' + String.fromCodePoint(cp);
    if (cp >= 0x0061 && cp <= 0x007A) return 'LATIN SMALL LETTER ' + String.fromCodePoint(cp);
    return 'U+' + cp.toString(16).toUpperCase().padStart(4, '0');
  }

  /* ═══════════════════════════════════════════════════════
     DOM REFS
  ═══════════════════════════════════════════════════════ */
  const input      = document.getElementById('dbInput');
  const charEl     = document.getElementById('charCount');
  const byteEl     = document.getElementById('byteCount');
  const cpBody     = document.getElementById('cpBody');
  const sampleSel  = document.getElementById('sampleSelect');
  const fontGrid   = document.getElementById('fontGrid');
  const fontStatus = document.getElementById('fontLoadStatus');
  const sylBar     = document.getElementById('syllableBar');
  const stackDet   = document.getElementById('stackDetail');
  const cssFontSel = document.getElementById('cssFontSelect');
  const cssOut     = document.getElementById('cssOutput');
  const htmlOut    = document.getElementById('htmlOutput');
  const cssPreview = document.getElementById('cssPreview');

  /* ═══════════════════════════════════════════════════════
     TAB SWITCHING
  ═══════════════════════════════════════════════════════ */
  document.getElementById('dbTabs').addEventListener('click', function (e) {
    const btn = e.target.closest('.db-tab');
    if (!btn) return;
    document.querySelectorAll('.db-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.db-panel').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    const panel = document.getElementById('panel-' + btn.dataset.panel);
    if (panel) panel.classList.add('active');

    // Lazy-load fonts when Font Comparison tab is first opened
    if (btn.dataset.panel === 'fonts' && !fontsLoaded) loadAllFonts();
  });

  /* ═══════════════════════════════════════════════════════
     SAMPLE SELECTOR
  ═══════════════════════════════════════════════════════ */
  sampleSel.addEventListener('change', function () {
    if (this.value) { input.value = this.value; update(); }
    this.selectedIndex = 0;
  });

  /* ═══════════════════════════════════════════════════════
     MAIN UPDATE (fires on every input change)
  ═══════════════════════════════════════════════════════ */
  input.addEventListener('input', update);

  function update() {
    const text = input.value;
    const chars = [...text];
    const byteLen = new TextEncoder().encode(text).length;

    charEl.textContent = chars.length + ' chars';
    byteEl.textContent = byteLen + ' bytes';

    updateInspector(chars);
    if (fontsLoaded) updateFontGrid(text);
    updateSyllableBar(text);
    updateCSSGenerator(text);
  }

  /* ═══════════════════════════════════════════════════════
     PANEL 1: UNICODE INSPECTOR
  ═══════════════════════════════════════════════════════ */
  function updateInspector(chars) {
    let html = '';
    chars.forEach(function (ch, i) {
      const cp = ch.codePointAt(0);
      const hex = 'U+' + cp.toString(16).toUpperCase().padStart(4, '0');
      const name = getUnicodeName(cp);
      const cat = getCategory(cp);
      const isProblem = PROBLEM_CODEPOINTS.has(cp);
      const rowClass = isProblem ? ' class="db-problem"' : '';
      const flag = isProblem ? '<span class="db-problem-flag" title="Known rendering hazard"></span>' : '';

      html += '<tr' + rowClass + '>' +
        '<td>' + (i + 1) + '</td>' +
        '<td class="db-char-cell">' + escHtml(ch) + '</td>' +
        '<td class="db-hex">' + hex + flag + '</td>' +
        '<td>' + escHtml(name) + '</td>' +
        '<td><span class="db-cat db-cat-' + cat + '">' + cat + '</span></td>' +
        '</tr>';
    });
    cpBody.innerHTML = html;
  }

  /* ═══════════════════════════════════════════════════════
     PANEL 2: FONT COMPARISON
  ═══════════════════════════════════════════════════════ */
  async function loadAllFonts() {
    fontStatus.textContent = 'Loading 36 fonts…';
    const promises = FONTS.map(function (f) {
      const face = new FontFace('db-' + f.file, "url('/fonts/" + f.file + ".woff2') format('woff2')");
      return face.load().then(function (loaded) {
        document.fonts.add(loaded);
        return { font: f, ok: true };
      }).catch(function () {
        return { font: f, ok: false };
      });
    });
    await Promise.all(promises);
    fontsLoaded = true;
    const okCount = FONTS.length;
    fontStatus.textContent = okCount + ' fonts loaded.';
    buildFontGrid();
    updateFontGrid(input.value);
  }

  function buildFontGrid() {
    let html = '';
    FONTS.forEach(function (f) {
      html += '<div class="db-font-card" data-cat="' + f.cat + '">' +
        '<div class="db-font-card-head">' +
          '<span class="db-font-name">' + escHtml(f.label) + '</span>' +
          '<span class="db-font-indicator" id="ind-' + f.file + '"></span>' +
        '</div>' +
        '<div class="db-font-sample" id="sample-' + f.file + '" lang="bo" ' +
          'style="font-family:\'db-' + f.file + '\',serif"></div>' +
        '<button class="db-font-copy" onclick="dbCopyFontCSS(\'' + f.file + '\',\'' +
          escHtml(f.label) + '\',this)">Copy CSS</button>' +
      '</div>';
    });
    fontGrid.innerHTML = html;
  }

  function updateFontGrid(text) {
    if (!fontsLoaded) return;
    FONTS.forEach(function (f) {
      const sample = document.getElementById('sample-' + f.file);
      const ind = document.getElementById('ind-' + f.file);
      if (!sample || !ind) return;
      sample.textContent = text;
      // Detect tofu via canvas
      const hasGlyph = checkGlyph('db-' + f.file, text);
      ind.textContent = hasGlyph ? '\u2713' : '\u2717';
      ind.style.color = hasGlyph ? 'var(--db-green)' : 'var(--db-red)';
    });
  }

  function checkGlyph(fontFamily, text) {
    if (!text) return true;
    const canvas = document.createElement('canvas');
    const ctx = canvas.getContext('2d');
    // Compare rendered width of first Tibetan char vs fallback
    const testChar = [...text].find(function (ch) {
      const cp = ch.codePointAt(0);
      return cp >= 0x0F00 && cp <= 0x0FFF && cp >= 0x0F40;
    });
    if (!testChar) return true;
    ctx.font = '48px "' + fontFamily + '"';
    const w1 = ctx.measureText(testChar).width;
    ctx.font = '48px "LastResort", sans-serif';
    const w2 = ctx.measureText(testChar).width;
    // If widths are identical and very small, likely tofu
    if (w1 === 0) return false;
    return Math.abs(w1 - w2) > 0.5 || w1 > 5;
  }

  /* Font category filter */
  document.getElementById('fontFilters').addEventListener('click', function (e) {
    const btn = e.target.closest('.db-filter-btn');
    if (!btn) return;
    document.querySelectorAll('.db-filter-btn').forEach(function (b) { b.classList.remove('active'); });
    btn.classList.add('active');
    const cat = btn.dataset.cat;
    document.querySelectorAll('.db-font-card').forEach(function (card) {
      card.style.display = (cat === 'all' || card.dataset.cat === cat) ? '' : 'none';
    });
  });

  /* ═══════════════════════════════════════════════════════
     PANEL 3: STACK ANALYZER
  ═══════════════════════════════════════════════════════ */
  function splitSyllables(text) {
    // Split on tsheg (U+0F0B), shad (U+0F0D/0E), and spaces
    const syls = [];
    let cur = '';
    for (const ch of text) {
      const cp = ch.codePointAt(0);
      if (cp === 0x0F0B || cp === 0x0F0D || cp === 0x0F0E || cp === 0x0F14 ||
          cp === 0x0020 || cp === 0x0F34) {
        if (cur) { syls.push(cur); cur = ''; }
        // Include punctuation as its own "syllable" only if it's a shad
        if (cp === 0x0F0D || cp === 0x0F0E) syls.push(ch);
      } else {
        cur += ch;
      }
    }
    if (cur) syls.push(cur);
    return syls;
  }

  function updateSyllableBar(text) {
    const syls = splitSyllables(text);
    let html = '';
    syls.forEach(function (syl, i) {
      html += '<button class="db-syl-btn" data-idx="' + i + '" data-syl="' +
        escAttr(syl) + '">' + escHtml(syl) + '</button>';
    });
    sylBar.innerHTML = html;
    stackDet.innerHTML = '<div class="db-stack-placeholder">Select a syllable above to analyze its stack structure.</div>';
  }

  sylBar.addEventListener('click', function (e) {
    const btn = e.target.closest('.db-syl-btn');
    if (!btn) return;
    document.querySelectorAll('.db-syl-btn').forEach(function (b) { b.classList.remove('active'); });
    btn.classList.add('active');
    analyzeSyllable(btn.dataset.syl);
  });

  function analyzeSyllable(syl) {
    const chars = [...syl];
    const parts = { root: [], superscribed: [], subjoined: [], vowel: [], suffix: [], marks: [] };
    let foundRoot = false;

    chars.forEach(function (ch) {
      const cp = ch.codePointAt(0);
      if (cp >= 0x0F90 && cp <= 0x0FBC) {
        parts.subjoined.push(ch);
      } else if ((cp >= 0x0F71 && cp <= 0x0F7D) || cp === 0x0F80 || cp === 0x0F81) {
        parts.vowel.push(ch);
      } else if (cp === 0x0F7E || cp === 0x0F7F || (cp >= 0x0F82 && cp <= 0x0F87) ||
                 cp === 0x0F35 || cp === 0x0F37 || cp === 0x0F39 || cp === 0x0FC6) {
        parts.marks.push(ch);
      } else if (cp >= 0x0F40 && cp <= 0x0F6C) {
        if (!foundRoot) {
          parts.root.push(ch);
          foundRoot = true;
        } else {
          parts.suffix.push(ch);
        }
      } else {
        parts.root.push(ch);
      }
    });

    // Build HTML
    let html = '<div class="db-stack-grid">';

    const sections = [
      { key: 'root',         label: 'Root Consonant' },
      { key: 'subjoined',    label: 'Subjoined' },
      { key: 'vowel',        label: 'Vowel Sign' },
      { key: 'marks',        label: 'Marks' },
      { key: 'suffix',       label: 'Suffix' },
    ];

    sections.forEach(function (s) {
      if (parts[s.key].length === 0) return;
      const display = parts[s.key].join('');
      const hexes = parts[s.key].map(function (ch) {
        return 'U+' + ch.codePointAt(0).toString(16).toUpperCase().padStart(4, '0');
      }).join(' ');

      html += '<div class="db-stack-item">' +
        '<div class="db-stack-label">' + s.label + '</div>' +
        '<div class="db-stack-value">' + escHtml(display) + '</div>' +
        '<div class="db-stack-hex">' + hexes + '</div>' +
      '</div>';
    });
    html += '</div>';

    // Check for rendering hazards
    const warnings = [];
    if (parts.subjoined.length >= 3) {
      warnings.push('Deep stack with ' + parts.subjoined.length + ' subjoined consonants — many fonts cannot render this correctly.');
    }
    const hasRa = parts.subjoined.some(function (ch) { return ch.codePointAt(0) === 0x0FB2; });
    const hasYa = parts.subjoined.some(function (ch) { return ch.codePointAt(0) === 0x0FB1; });
    const hasWa = parts.subjoined.some(function (ch) { return ch.codePointAt(0) === 0x0FAD || ch.codePointAt(0) === 0x0FBA; });
    if (hasRa && hasYa) warnings.push('Contains both ra-tag and ya-tag — complex rendering.');
    if (hasWa && parts.subjoined.length > 1) warnings.push('Wa-zur combined with other subjoined letters — rendering varies across fonts.');
    if (parts.vowel.some(function (ch) { return [0x0F73,0x0F75,0x0F77,0x0F79,0x0F81].includes(ch.codePointAt(0)); })) {
      warnings.push('Contains precomposed/deprecated vowel — consider decomposed form for better compatibility.');
    }

    if (warnings.length) {
      html += '<div class="db-stack-warn">' + warnings.map(function (w) { return '&#9888; ' + escHtml(w); }).join('<br>') + '</div>';
    }

    // Canonical ordering check
    const inputOrder = chars.map(function (ch) {
      return 'U+' + ch.codePointAt(0).toString(16).toUpperCase().padStart(4, '0');
    }).join(' ');

    // Canonical: root, subjoined, vowels, marks, suffix
    const canonical = [].concat(parts.root, parts.subjoined, parts.vowel, parts.marks, parts.suffix);
    const canonOrder = canonical.map(function (ch) {
      return 'U+' + ch.codePointAt(0).toString(16).toUpperCase().padStart(4, '0');
    }).join(' ');

    const match = inputOrder === canonOrder;
    html += '<div class="db-stack-order">' +
      '<div class="db-stack-order-label">Input Order</div>' +
      '<div class="db-stack-order-val">' + inputOrder + '</div>' +
      '<div class="db-stack-order-label" style="margin-top:0.5rem">Canonical Order</div>' +
      '<div class="db-stack-order-val">' + canonOrder + '</div>' +
      '<div style="margin-top:0.4rem;font-size:0.75rem" class="' +
        (match ? 'db-order-match' : 'db-order-mismatch') + '">' +
        (match ? '\u2713 Order matches canonical' : '\u2717 Order differs from canonical — may cause rendering issues') +
      '</div>' +
    '</div>';

    stackDet.innerHTML = html;
  }

  /* ═══════════════════════════════════════════════════════
     PANEL 4: CSS GENERATOR
  ═══════════════════════════════════════════════════════ */
  // Populate font dropdown
  (function () {
    let opts = '';
    FONTS.forEach(function (f) {
      opts += '<option value="' + f.file + '">' + escHtml(f.label) + '</option>';
    });
    cssFontSel.innerHTML = opts;
  })();

  cssFontSel.addEventListener('change', function () { updateCSSGenerator(input.value); });

  function updateCSSGenerator(text) {
    const f = FONTS.find(function (x) { return x.file === cssFontSel.value; }) || FONTS[0];

    const css = "@font-face {\n" +
      "  font-family: '" + f.label + "';\n" +
      "  src: url('/fonts/" + f.file + ".woff2') format('woff2');\n" +
      "}\n\n" +
      ".tibetan-text {\n" +
      "  font-family: '" + f.label + "', serif;\n" +
      "  font-size: 1.5rem;\n" +
      "  line-height: 2;\n" +
      "}";

    const htmlCode = '<p class="tibetan-text" lang="bo">' + escHtml(text) + '</p>';

    cssOut.textContent = css;
    htmlOut.textContent = htmlCode;

    // Live preview
    cssPreview.textContent = text;
    cssPreview.style.fontFamily = fontsLoaded ? "'db-" + f.file + "', serif" : 'serif';
    cssPreview.style.fontSize = '1.5rem';
    cssPreview.style.lineHeight = '2';
  }

  /* ═══════════════════════════════════════════════════════
     UTILITIES
  ═══════════════════════════════════════════════════════ */
  function escHtml(s) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }
  function escAttr(s) {
    return s.replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/'/g,'&#39;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  /* Copy helpers — exposed globally */
  window.dbCopy = function (btn, targetId) {
    const el = document.getElementById(targetId);
    if (!el) return;
    navigator.clipboard.writeText(el.textContent).then(function () {
      btn.textContent = 'Copied!';
      btn.classList.add('copied');
      setTimeout(function () { btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 2000);
    });
  };

  window.dbCopyFontCSS = function (file, label, btn) {
    const css = "@font-face {\n  font-family: '" + label + "';\n  src: url('/fonts/" +
      file + ".woff2') format('woff2');\n}";
    navigator.clipboard.writeText(css).then(function () {
      const orig = btn.textContent;
      btn.textContent = 'Copied!';
      setTimeout(function () { btn.textContent = orig; }, 2000);
    });
  };

  /* ═══════════════════════════════════════════════════════
     INIT
  ═══════════════════════════════════════════════════════ */
  update();

})();
</script>
