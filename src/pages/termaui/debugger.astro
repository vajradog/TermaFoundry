---
import Base from '../../layouts/TeruiBase.astro';
---

<Base title="Unicode Debugger — termaUI" description="Paste any Tibetan string. Inspect codepoints, compare 36 fonts, analyze syllable stacks, and generate copy-paste CSS.">

<!-- ══════════════════════════════════════════════════════════
     PAGE HERO
══════════════════════════════════════════════════════════ -->
<div class="section db-hero reveal">
  <div class="section-eyebrow">◈ termaUI</div>
  <h1 class="section-heading">Unicode Debugger</h1>
  <p class="section-sub">
    Paste any Tibetan string. Inspect codepoints, compare all 36 fonts, analyze syllable stacks, and generate copy-paste CSS.
  </p>
</div>

<hr class="divider" />

<!-- ══════════════════════════════════════════════════════════
     DEBUGGER WRAPPER
══════════════════════════════════════════════════════════ -->
<div class="db">

<!-- ── STICKY INPUT BAR ─────────────────────────────────── -->
<div class="db-input-bar" id="inputBar">
  <div class="db-input-inner">
    <textarea id="dbInput" rows="2" spellcheck="false" lang="bo"
      placeholder="Paste Tibetan text here…">འགྲོ་བ་མཐའ་དག་དང་།</textarea>
    <div class="db-input-meta">
      <span id="charCount">0 chars</span>
      <span class="db-sep">|</span>
      <span id="byteCount">0 bytes</span>
      <span class="db-sep">|</span>
      <select id="sampleSelect" class="db-sample-select">
        <option value="">Sample strings…</option>
        <option value="འགྲོ་བ་མཐའ་དག་དང་།">Stacked consonants</option>
        <option value="སྐུ་གསུང་ཐུགས་རྡོ་རྗེ།">Ra-tags + subjoined</option>
        <option value="ཨོཾ་མ་ཎི་པདྨེ་ཧཱུྃ།">Om Mani (vowel combos)</option>
        <option value="ཨོཾ་ཨཱཿཧཱུྃ་བཛྲ་གུ་རུ་པདྨ་སིདྡྷི་ཧཱུྃ༔">Guru mantra (deep stacks)</option>
        <option value="བཀྲ་ཤིས་བདེ་ལེགས། །ཕྱི་ལོ་༢༠༢༦">Mixed punctuation + digits</option>
        <option value="རྒྱ་གར་སྐད་དུ།  བོད་སྐད་དུ།">Sanskrit/Tibetan prefix</option>
      </select>
    </div>
  </div>
</div>

<!-- ── TAB NAV ──────────────────────────────────────────── -->
<div class="db-tabs" id="dbTabs">
  <button class="db-tab active" data-panel="inspector">Unicode Inspector</button>
  <button class="db-tab" data-panel="fonts">Font Comparison</button>
  <button class="db-tab" data-panel="stacks">Stack Analyzer</button>
  <button class="db-tab" data-panel="css">CSS Generator</button>
</div>

<!-- ══════════════════════════════════════════════════════════
     PANEL 1: UNICODE INSPECTOR
══════════════════════════════════════════════════════════ -->
<section class="db-panel active" id="panel-inspector">
  <div class="db-stitle">Codepoint Table</div>
  <div class="db-table-wrap">
    <table class="db-table" id="cpTable">
      <thead>
        <tr>
          <th>#</th>
          <th>Char</th>
          <th>Hex</th>
          <th>Name</th>
          <th>Category</th>
        </tr>
      </thead>
      <tbody id="cpBody"></tbody>
    </table>
  </div>
</section>

<!-- ══════════════════════════════════════════════════════════
     PANEL 2: FONT COMPARISON GRID
══════════════════════════════════════════════════════════ -->
<section class="db-panel" id="panel-fonts">
  <div class="db-stitle">Font Comparison Grid</div>
  <div class="db-font-filters" id="fontFilters">
    <button class="db-filter-btn active" data-cat="all">All</button>
    <button class="db-filter-btn" data-cat="uchen">Uchen</button>
    <button class="db-filter-btn" data-cat="drutsa">Drutsa / Cursive</button>
    <button class="db-filter-btn" data-cat="sans">Sans</button>
    <button class="db-filter-btn" data-cat="experimental">Experimental</button>
  </div>
  <div class="db-font-status" id="fontLoadStatus">Fonts not loaded yet — switch to this tab to load all 36 fonts.</div>
  <div class="db-font-grid" id="fontGrid"></div>
</section>

<!-- ══════════════════════════════════════════════════════════
     PANEL 3: STACK ANALYZER
══════════════════════════════════════════════════════════ -->
<section class="db-panel" id="panel-stacks">
  <div class="db-stitle">Syllable Stack Analyzer</div>
  <p class="db-intro">Click a syllable below to see its structural breakdown.</p>
  <div class="db-syllable-bar" id="syllableBar" lang="bo"></div>
  <div class="db-stack-detail" id="stackDetail">
    <div class="db-stack-placeholder">Select a syllable above to analyze its stack structure.</div>
  </div>
</section>

<!-- ══════════════════════════════════════════════════════════
     PANEL 4: CSS GENERATOR
══════════════════════════════════════════════════════════ -->
<section class="db-panel" id="panel-css">
  <div class="db-stitle">CSS + HTML Generator</div>
  <div class="db-css-controls">
    <label class="db-css-label">Font</label>
    <select id="cssFontSelect" class="db-css-select"></select>
  </div>
  <div class="db-css-block">
    <div class="db-css-heading">CSS</div>
    <div class="db-code-wrap">
      <button class="db-copy-btn" onclick="dbCopy(this,'cssOutput')">Copy</button>
      <pre id="cssOutput"></pre>
    </div>
  </div>
  <div class="db-css-block" style="margin-top:1rem">
    <div class="db-css-heading">HTML</div>
    <div class="db-code-wrap">
      <button class="db-copy-btn" onclick="dbCopy(this,'htmlOutput')">Copy</button>
      <pre id="htmlOutput"></pre>
    </div>
  </div>
  <div class="db-css-preview-label">Preview</div>
  <div class="db-css-preview" id="cssPreview" lang="bo"></div>
</section>

</div><!-- .db -->
</Base>

<!-- ══════════════════════════════════════════════════════════
     STYLES
══════════════════════════════════════════════════════════ -->
<style is:global>

/* ══ Hero ═════════════════════════════════════════════════ */
.db-hero { padding-bottom: 3rem; }

/* ══ Debugger wrapper ════════════════════════════════════ */
.db {
  --db-surface:  #16161b;
  --db-surface2: #1e1e25;
  --db-border:   #2a2a34;
  --db-text:     #e2e2e8;
  --db-muted:    #777;
  --db-gold:     #c9a84c;
  --db-blue:     #5a8fdf;
  --db-green:    #4caf50;
  --db-red:      #f44336;
  --db-amber:    #f59e0b;
  --db-pill:     #22222c;
  --db-code:     #13131a;
  max-width: 1200px; margin: 0 auto; padding: 0 2rem 5rem;
}

/* ══ Sticky input bar ════════════════════════════════════ */
.db-input-bar {
  position: sticky; top: 104px; z-index: 100;
  background: rgba(22,22,27,0.97);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--db-border);
  padding: 0.75rem 0; margin-bottom: 1.5rem;
}
.db-input-inner { max-width: 100%; }
#dbInput {
  width: 100%; resize: vertical;
  background: var(--db-surface2); color: var(--db-text);
  border: 1px solid var(--db-border); border-radius: 8px;
  padding: 0.75rem 1rem; font-size: 1.35rem; line-height: 1.8;
  font-family: "Jomolhari", "Noto Serif Tibetan", serif;
  outline: none; transition: border-color 0.15s;
}
#dbInput:focus { border-color: var(--db-gold); }
.db-input-meta {
  display: flex; align-items: center; gap: 0.6rem;
  margin-top: 0.4rem; font-size: 0.75rem; color: var(--db-muted);
}
.db-sep { opacity: 0.3; }
.db-sample-select {
  background: var(--db-pill); color: var(--db-muted);
  border: 1px solid var(--db-border); border-radius: 5px;
  padding: 0.2rem 0.5rem; font-size: 0.72rem; cursor: pointer;
  margin-left: auto;
}

/* ══ Tabs ════════════════════════════════════════════════ */
.db-tabs {
  display: flex; gap: 0; border-bottom: 1px solid var(--db-border);
  margin-bottom: 1.5rem;
}
.db-tab {
  padding: 0.55rem 1.1rem; font-size: 0.8rem; cursor: pointer;
  color: var(--db-muted); border: 1px solid transparent;
  border-bottom: none; border-radius: 6px 6px 0 0;
  background: transparent; transition: color 0.15s;
  font-family: inherit; font-weight: 500;
}
.db-tab:hover { color: var(--db-text); }
.db-tab.active {
  color: var(--db-text); background: var(--db-code);
  border-color: var(--db-border); border-bottom-color: var(--db-code);
  margin-bottom: -1px;
}

/* ══ Panels ══════════════════════════════════════════════ */
.db-panel { display: none; }
.db-panel.active { display: block; }

.db-stitle {
  font-size: 0.68rem; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.12em; color: var(--db-muted);
  margin-bottom: 0.7rem; padding-bottom: 0.5rem;
  border-bottom: 1px solid var(--db-border);
}
.db-intro {
  font-size: 0.85rem; color: var(--db-muted);
  margin-bottom: 1.25rem; line-height: 1.7;
}

/* ══ Panel 1: Unicode Inspector ══════════════════════════ */
.db-table-wrap { overflow-x: auto; }
.db-table {
  width: 100%; border-collapse: collapse;
  font-size: 0.82rem;
}
.db-table th {
  text-align: left; padding: 0.5rem 0.75rem;
  font-size: 0.68rem; font-weight: 700;
  text-transform: uppercase; letter-spacing: 0.1em;
  color: var(--db-muted); border-bottom: 2px solid var(--db-border);
  background: var(--db-surface);
}
.db-table td {
  padding: 0.45rem 0.75rem; border-bottom: 1px solid var(--db-border);
  color: var(--db-text); vertical-align: middle;
}
.db-table tbody tr:hover { background: rgba(148,163,184,0.04); }
.db-char-cell {
  font-size: 1.4rem; font-family: "Jomolhari", serif;
  min-width: 2.5rem; text-align: center;
}
.db-hex { font-family: "Cascadia Code", "Fira Code", monospace; color: var(--db-blue); }
.db-cat {
  display: inline-block; font-size: 0.7rem; font-weight: 600;
  padding: 1px 7px; border-radius: 10px;
  text-transform: uppercase; letter-spacing: 0.04em;
}
.db-cat-consonant   { background: #1a2a3a; color: #7ecfff; }
.db-cat-vowel       { background: #1a3a2a; color: #7eff9e; }
.db-cat-subjoined   { background: #2a1a3a; color: #c49eff; }
.db-cat-mark        { background: #3a2a1a; color: #ffcf7e; }
.db-cat-punctuation { background: #3a1a2a; color: #ff9eb0; }
.db-cat-digit       { background: #1a3a3a; color: #7eeeee; }
.db-cat-other       { background: #2a2a2a; color: #999; }
.db-cat-space       { background: #2a2a2a; color: #999; }
tr.db-problem td { background: rgba(245,158,11,0.06); }
.db-problem-flag {
  display: inline-block; width: 8px; height: 8px;
  background: var(--db-amber); border-radius: 50%;
  margin-left: 0.4rem; vertical-align: middle;
}

/* ══ Panel 2: Font Comparison ════════════════════════════ */
.db-font-filters {
  display: flex; gap: 0.35rem; flex-wrap: wrap; margin-bottom: 1rem;
}
.db-filter-btn {
  background: var(--db-pill); border: 1px solid var(--db-border);
  color: var(--db-muted); border-radius: 20px;
  padding: 0.25rem 0.75rem; font-size: 0.72rem; cursor: pointer;
  font-family: inherit; transition: all 0.15s;
}
.db-filter-btn:hover { color: var(--db-text); border-color: var(--db-gold); }
.db-filter-btn.active { color: var(--db-text); background: #2a2a3a; border-color: var(--db-gold); }
.db-font-status {
  font-size: 0.78rem; color: var(--db-muted);
  margin-bottom: 1rem; font-style: italic;
}
.db-font-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 0.75rem;
}
.db-font-card {
  background: var(--db-surface2); border: 1px solid var(--db-border);
  border-radius: 8px; padding: 0.85rem 1rem;
  transition: border-color 0.15s;
}
.db-font-card:hover { border-color: rgba(148,163,184,0.2); }
.db-font-card-head {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 0.4rem;
}
.db-font-name {
  font-size: 0.75rem; font-weight: 600; color: var(--db-text);
}
.db-font-indicator {
  font-size: 0.85rem; flex-shrink: 0;
}
.db-font-sample {
  font-size: 28px; line-height: 1.8; color: var(--db-text);
  word-break: break-all; min-height: 2.5rem;
  padding: 0.25rem 0;
}
.db-font-copy {
  display: inline-block; margin-top: 0.35rem;
  font-size: 0.68rem; color: var(--db-muted);
  cursor: pointer; transition: color 0.15s;
  background: none; border: none; font-family: inherit;
  padding: 0;
}
.db-font-copy:hover { color: var(--db-gold); }

/* ══ Panel 3: Stack Analyzer ═════════════════════════════ */
.db-syllable-bar {
  display: flex; flex-wrap: wrap; gap: 0.5rem;
  margin-bottom: 1.5rem; min-height: 2.5rem;
}
.db-syl-btn {
  font-size: 1.5rem; font-family: "Jomolhari", serif;
  background: var(--db-surface2); border: 1px solid var(--db-border);
  color: var(--db-text); border-radius: 8px;
  padding: 0.35rem 0.85rem; cursor: pointer;
  transition: all 0.15s;
}
.db-syl-btn:hover { border-color: var(--db-gold); }
.db-syl-btn.active { border-color: var(--db-gold); background: #2a2a1a; }

.db-stack-detail {
  background: var(--db-surface2); border: 1px solid var(--db-border);
  border-radius: 8px; padding: 1.25rem;
  min-height: 120px;
}
.db-stack-placeholder { color: var(--db-muted); font-size: 0.85rem; }

.db-stack-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
  gap: 0.75rem;
}
.db-stack-item {
  background: var(--db-code); border: 1px solid var(--db-border);
  border-radius: 6px; padding: 0.65rem 0.85rem;
}
.db-stack-label {
  font-size: 0.65rem; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.08em; color: var(--db-muted);
  margin-bottom: 0.3rem;
}
.db-stack-value {
  font-size: 1.1rem; color: var(--db-text);
  font-family: "Jomolhari", serif;
}
.db-stack-hex {
  font-size: 0.7rem; color: var(--db-blue);
  font-family: "Cascadia Code", monospace;
  margin-top: 0.15rem;
}

.db-stack-warn {
  margin-top: 1rem; padding: 0.65rem 0.85rem;
  background: rgba(245,158,11,0.08); border: 1px solid rgba(245,158,11,0.2);
  border-left: 3px solid var(--db-amber);
  border-radius: 0 6px 6px 0;
  font-size: 0.8rem; color: #e0a040;
}

.db-stack-order {
  margin-top: 1rem; padding: 0.65rem 0.85rem;
  background: var(--db-code); border: 1px solid var(--db-border);
  border-radius: 6px; font-size: 0.78rem;
}
.db-stack-order-label {
  font-size: 0.65rem; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.08em; color: var(--db-muted);
  margin-bottom: 0.25rem;
}
.db-stack-order-val {
  font-family: "Cascadia Code", monospace; color: var(--db-blue);
}
.db-order-match { color: var(--db-green); }
.db-order-mismatch { color: var(--db-red); }

/* ══ Panel 4: CSS Generator ══════════════════════════════ */
.db-css-controls {
  display: flex; align-items: center; gap: 0.75rem;
  margin-bottom: 1.25rem;
}
.db-css-label {
  font-size: 0.78rem; font-weight: 600; color: var(--db-muted);
}
.db-css-select {
  background: var(--db-surface2); color: var(--db-text);
  border: 1px solid var(--db-border); border-radius: 6px;
  padding: 0.35rem 0.75rem; font-size: 0.82rem;
  min-width: 220px;
}
.db-css-block {}
.db-css-heading {
  font-size: 0.68rem; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.1em; color: var(--db-muted);
  margin-bottom: 0.4rem;
}
.db-code-wrap {
  position: relative; background: var(--db-code);
  border: 1px solid var(--db-border); border-radius: 6px;
}
.db-code-wrap pre {
  padding: 1rem 1.25rem;
  font-family: "Cascadia Code", "Fira Code", "JetBrains Mono", monospace;
  font-size: 0.78rem; line-height: 1.7;
  color: #c9d1d9; overflow-x: auto; white-space: pre;
}
.db-copy-btn {
  position: absolute; top: 0.5rem; right: 0.5rem;
  background: var(--db-pill); border: 1px solid var(--db-border);
  color: var(--db-muted); border-radius: 5px;
  padding: 0.25rem 0.6rem; font-size: 0.72rem; cursor: pointer;
  transition: color 0.15s, border-color 0.15s; font-family: inherit;
}
.db-copy-btn:hover { color: var(--db-text); border-color: var(--db-gold); }
.db-copy-btn.copied { color: var(--db-green); border-color: var(--db-green); }

.db-css-preview-label {
  font-size: 0.68rem; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.1em; color: var(--db-muted);
  margin: 1.25rem 0 0.4rem;
}
.db-css-preview {
  background: var(--db-surface2); border: 1px solid var(--db-border);
  border-radius: 8px; padding: 1rem 1.25rem;
  font-size: 1.5rem; line-height: 2; color: var(--db-text);
  min-height: 3rem;
}

/* ══ Responsive ══════════════════════════════════════════ */
@media (max-width: 768px) {
  .db { padding: 0 1.25rem 3rem; }
  .db-input-bar { top: 60px; }
  .db-tabs { overflow-x: auto; }
  .db-font-grid { grid-template-columns: 1fr; }
  #dbInput { font-size: 1.1rem; }
}
</style>

<!-- ══════════════════════════════════════════════════════════
     SCRIPT
══════════════════════════════════════════════════════════ -->
<script is:inline>
(function () {
  'use strict';

  /* ═══════════════════════════════════════════════════════
     FONT REGISTRY
