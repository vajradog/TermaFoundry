---
import { getCollection } from "astro:content";
import SiteLayout from '@layouts/SiteLayout.astro';

export async function getStaticPaths() {
  const blogEntries = await getCollection("blog");
  return blogEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": entry.data.title,
  "description": entry.data.snippet ?? entry.data.title,
  "image": entry.data.image?.src ? new URL(entry.data.image.src, Astro.site ?? 'https://termafoundry.com').href : undefined,
  "datePublished": entry.data.publishDate.toISOString(),
  "dateModified": entry.data.publishDate.toISOString(),
  "author": {
    "@type": "Person",
    "name": entry.data.author,
    "url": "https://termafoundry.com/about"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Terma Type Foundry",
    "url": "https://termafoundry.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": new URL(`/blog/${entry.slug}`, Astro.site ?? 'https://termafoundry.com').href
  }
};
---

<SiteLayout
  title={entry.data.title}
  description={entry.data.snippet ?? entry.data.title}
  ogImage={entry.data.image?.src}
  ogType="article"
  schema={articleSchema}
>

  <section class="page-section" style="padding-bottom:0;">

    <!-- Post header -->
    <div class="post-header reveal">
      <div class="post-category">{entry.data.category}</div>
      <h1 class="post-title">{entry.data.title}</h1>
      <div class="post-meta">
        <span>{entry.data.author}</span>
        <span class="meta-dot">·</span>
        <time datetime={entry.data.publishDate.toISOString()}>
          {entry.data.publishDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        {entry.data.tags && entry.data.tags.length > 0 && (
          <>
            <span class="meta-dot">·</span>
            <div class="post-tags">
              {entry.data.tags.map((tag: string) => (
                <span class="post-tag">#{tag}</span>
              ))}
            </div>
          </>
        )}
      </div>
    </div>

  </section>

  <!-- Article body -->
  <section class="page-section" style="padding-top:2rem; padding-bottom:4rem;">
    <div class="prose reveal">
      <Content />
    </div>

    <div class="back-link reveal">
      <a href="/blog" class="btn btn-outline">← Back to Blog</a>
    </div>
  </section>

</SiteLayout>

<style>
  .post-header {
    max-width: 760px;
    margin-bottom: 1.5rem;
  }

  .post-category {
    font-size: .68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--accent);
    margin-bottom: .75rem;
  }

  .post-title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -.035em;
    line-height: 1.15;
    color: var(--text);
    margin-bottom: 1rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: .5rem;
    font-size: .82rem;
    color: var(--muted);
  }
  .meta-dot { color: var(--border); }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: .35rem;
  }
  .post-tag {
    font-size: .72rem;
    color: var(--muted);
    background: var(--surface);
    padding: .1em .45em;
    border-radius: 4px;
    border: 1px solid var(--border);
  }

  .back-link {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }
</style>
