---
import SiteLayout from '@layouts/SiteLayout.astro';
---

<SiteLayout title="TermaType — Bilingual Tibetan & English Word Processor" description="The first word processor built for bilingual Tibetan and English writing. Free, open source, 100% offline.">

  <section class="tt-new-home reveal">
    <div class="tt-new-home-inner">
      <span class="tt-new-home-badge">NEW HOME</span>
      <h1>TermaType has moved</h1>
      <p>TermaType is now part of the <strong>Terma Heritage Foundation</strong>. Visit the new home for downloads, documentation, and updates.</p>
      <a href="https://termafoundation.org/programs/termatype" class="btn btn-primary btn-lg" target="_blank" rel="noopener">Visit termafoundation.org <span class="tt-arrow">&rarr;</span></a>
    </div>
  </section>

</SiteLayout>

<style is:global>
  .tt-new-home {
    max-width: 640px;
    margin: 0 auto;
    padding: 6rem 1.5rem 8rem;
  }
  .tt-new-home-inner {
    text-align: center;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 3rem 2.5rem;
    box-shadow: 0 4px 24px rgba(0,0,0,0.06);
  }
  .tt-new-home-badge {
    display: inline-block;
    font-size: .65rem;
    font-weight: 700;
    letter-spacing: .15em;
    color: var(--accent);
    background: rgba(217,119,87,0.08);
    border: 1px solid rgba(217,119,87,0.18);
    border-radius: 6px;
    padding: .25em .75em;
    margin-bottom: 1.25rem;
  }
  .tt-new-home-inner h1 {
    font-size: 2rem;
    font-weight: 900;
    color: var(--text);
    letter-spacing: -.03em;
    margin-bottom: .75rem;
  }
  .tt-new-home-inner p {
    font-size: 1rem;
    color: var(--text2);
    line-height: 1.7;
    max-width: 440px;
    margin: 0 auto 1.75rem;
  }
  .tt-new-home-inner .btn-lg {
    padding: .75rem 2rem;
    font-size: 1rem;
    font-weight: 700;
    border-radius: 10px;
  }
  .tt-arrow { transition: transform .15s; display: inline-block; }
  .tt-new-home-inner .btn:hover .tt-arrow { transform: translateX(3px); }

  .tt-new-home.reveal {
    opacity: 0; transform: translateY(20px);
    transition: opacity .5s, transform .5s;
  }
  .tt-new-home.in-view {
    opacity: 1; transform: none;
  }
</style>

<script>
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('in-view'); });
  }, { threshold: 0.05 });
  document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
</script>
