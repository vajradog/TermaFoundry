---
import SiteLayout from '@layouts/SiteLayout.astro';
---

<SiteLayout title="TermaType — A Tibetan Word Processor" description="A professional Tibetan word processor with built-in Monlam IME, bilingual dictionary, rich formatting, and export to HTML, EPUB, and PDF. Free, offline-first, no account needed.">

  <section class="tt-hero reveal">
    <span class="tt-kicker">TIBETAN WORD PROCESSOR</span>
    <h1 class="tt-title">TermaType <span class="tt-beta">BETA</span></h1>
    <p class="tt-subtitle">Write, format, and publish Tibetan text — with a built-in keyboard, live dictionary, and beautiful typography. No installation, no account.</p>
    <div class="tt-cta">
      <a href="https://vajradog.github.io/termatype/" class="btn btn-primary btn-lg" target="_blank" rel="noopener">Try the Prototype <span class="tt-arrow">→</span></a>
      <span class="tt-cta-note">Free prototype · Works in your browser · Desktop recommended</span>
    </div>
  </section>

  <!-- Screenshot / Preview -->
  <section class="tt-preview reveal">
    <div class="tt-preview-window">
      <div class="tt-preview-bar">
        <span class="tt-dot"></span><span class="tt-dot"></span><span class="tt-dot"></span>
        <span class="tt-preview-title">TermaType</span>
      </div>
      <div class="tt-preview-body">
        <div class="tt-preview-toolbar">
          <span class="tt-tb-item">Jomolhari</span>
          <span class="tt-tb-item">18px</span>
          <span class="tt-tb-sep"></span>
          <span class="tt-tb-item"><b>B</b></span>
          <span class="tt-tb-item"><i>I</i></span>
          <span class="tt-tb-item"><u>U</u></span>
          <span class="tt-tb-sep"></span>
          <span class="tt-tb-item">≡</span>
          <span class="tt-tb-item">☰</span>
        </div>
        <div class="tt-preview-page" lang="bo">
          <p class="tt-sample-text">བཀྲ་ཤིས་བདེ་ལེགས། སེམས་ཅན་ཐམས་ཅད་བདེ་བ་དང་བདེ་བའི་རྒྱུ་དང་ལྡན་པར་གྱུར་ཅིག །སེམས་ཅན་ཐམས་ཅད་སྡུག་བསྔལ་དང་སྡུག་བསྔལ་གྱི་རྒྱུ་དང་བྲལ་བར་གྱུར་ཅིག</p>
        </div>
        <div class="tt-preview-status">
          <span>IME: བོད</span>
          <span>42 words · 186 chars</span>
          <span>Jomolhari 18px</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="tt-features reveal">
    <h2 class="tt-section-title">Built for Tibetan</h2>
    <p class="tt-section-desc">Every feature designed around the unique needs of Tibetan script — vertical stacking, tsheg segmentation, and ligature rendering.</p>

    <div class="tt-feature-grid">
      <div class="tt-feature">
        <div class="tt-feature-icon">⌨</div>
        <h3>Monlam Phonetic IME</h3>
        <p>Type Tibetan with the standard Monlam keyboard layout. Ctrl+Space to toggle between Tibetan and English. Visual on-screen keyboard with real-time key highlighting.</p>
      </div>
      <div class="tt-feature">
        <div class="tt-feature-icon">📖</div>
        <h3>Live Dictionary</h3>
        <p>Search across 64 Tibetan-English dictionaries with 316,000+ entries. Click any result to insert it at your cursor. Powered by the Tibetan Library API.</p>
      </div>
      <div class="tt-feature">
        <div class="tt-feature-icon">✍</div>
        <h3>Rich Text Editing</h3>
        <p>Full formatting — headings, bold, italic, colors, alignment, lists, tables, and images. Choose from Jomolhari, Noto Serif Tibetan, Qomolangma, and more.</p>
      </div>
      <div class="tt-feature">
        <div class="tt-feature-icon">📤</div>
        <h3>Multi-Format Export</h3>
        <p>Save as .terma (native), .html (standalone page), .txt (plain text), .epub (e-book), or .pdf (print). Your documents, your formats.</p>
      </div>
      <div class="tt-feature">
        <div class="tt-feature-icon">🔒</div>
        <h3>Offline & Private</h3>
        <p>No cloud, no account, no tracking. Documents auto-save to your browser. Everything works offline except the dictionary lookup.</p>
      </div>
      <div class="tt-feature">
        <div class="tt-feature-icon">🎓</div>
        <h3>Typing Tutor</h3>
        <p>Built-in lessons from alphabet basics to full sentences. Real-time WPM and accuracy tracking. Learn the Monlam keyboard from scratch.</p>
      </div>
    </div>
  </section>

  <!-- Scripts section -->
  <section class="tt-scripts reveal">
    <h2 class="tt-section-title">Scripts & Fonts</h2>
    <p class="tt-section-desc">TermaType ships with curated Tibetan fonts covering formal, cursive, and modern styles.</p>
    <div class="tt-script-list">
      <div class="tt-script-item">
        <span class="tt-script-sample" lang="bo">བཀྲ་ཤིས་བདེ་ལེགས།</span>
        <span class="tt-script-label">Jomolhari — Uchen (formal)</span>
      </div>
      <div class="tt-script-item">
        <span class="tt-script-sample tt-font-noto" lang="bo">བཀྲ་ཤིས་བདེ་ལེགས།</span>
        <span class="tt-script-label">Noto Sans Tibetan — Sans-serif</span>
      </div>
      <div class="tt-script-item">
        <span class="tt-script-sample tt-font-drutsa" lang="bo">བཀྲ་ཤིས་བདེ་ལེགས།</span>
        <span class="tt-script-label">Qomolangma Drutsa — Cursive</span>
      </div>
    </div>
  </section>

  <!-- Roadmap & Support -->
  <section class="tt-roadmap reveal">
    <div class="tt-roadmap-inner">
      <p class="tt-roadmap-lead">TermaType is in active development. Building a professional word processor for Tibetan requires solving unique challenges — vertical consonant stacking, tsheg-based word segmentation, and mixed-script rendering that no mainstream editor handles well.</p>
      <p class="tt-roadmap-body">The current beta includes a full rich text editor, Monlam IME, live dictionary, and multi-format export. With your support, we're working to deliver:</p>
      <ul class="tt-roadmap-list">
        <li><strong>Native desktop apps</strong> — macOS, Windows, and Linux via Tauri</li>
        <li><strong>Offline dictionary</strong> — full 316K-entry dictionary without internet</li>
        <li><strong>Spell check</strong> — Tibetan-aware spell checking with Botok integration</li>
        <li><strong>Find & replace</strong> — tsheg-aware search across documents</li>
        <li><strong>Dark mode</strong> — full theme support for low-light writing</li>
        <li><strong>Mobile support</strong> — responsive editor for tablets and phones</li>
      </ul>
      <p class="tt-roadmap-cta">Your support helps fix bugs, polish the interface, and bring TermaType to every platform. Every contribution directly advances the tools available for Tibetan writers worldwide.</p>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="tt-final-cta reveal">
    <h2>Start Writing Tibetan</h2>
    <p>No download, no signup. Just open TermaType and start typing.</p>
    <a href="https://vajradog.github.io/termatype/" class="btn btn-primary btn-lg" target="_blank" rel="noopener">Try the Prototype →</a>
  </section>

</SiteLayout>

<style is:global>
  /* ─── Hero ──────────────────────────────────────────────────────────────── */
  .tt-hero {
    text-align: center;
    padding: 4rem 1.5rem 2rem;
    max-width: 720px;
    margin: 0 auto;
  }
  .tt-kicker {
    font-size: .7rem;
    font-weight: 700;
    letter-spacing: .15em;
    color: var(--accent);
    text-transform: uppercase;
    display: block;
    margin-bottom: .75rem;
  }
  .tt-title {
    font-size: 3rem;
    font-weight: 900;
    color: var(--text);
    letter-spacing: -.03em;
    line-height: 1.1;
    margin-bottom: 1rem;
  }
  .tt-beta {
    font-size: .45em;
    font-weight: 700;
    letter-spacing: .1em;
    color: var(--gold);
    background: rgba(251,191,36,0.1);
    border: 1px solid rgba(251,191,36,0.25);
    border-radius: 6px;
    padding: .2em .55em;
    vertical-align: middle;
    position: relative;
    top: -.15em;
  }
  .tt-subtitle {
    font-size: 1.1rem;
    color: var(--text2);
    line-height: 1.7;
    max-width: 560px;
    margin: 0 auto 2rem;
  }
  .tt-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .75rem;
  }
  .tt-cta .btn-lg {
    padding: .75rem 2rem;
    font-size: 1rem;
    font-weight: 700;
    border-radius: 10px;
  }
  .tt-arrow { transition: transform .15s; display: inline-block; }
  .tt-cta .btn:hover .tt-arrow { transform: translateX(3px); }
  .tt-cta-note {
    font-size: .75rem;
    color: var(--muted);
  }

  /* ─── Preview window ────────────────────────────────────────────────────── */
  .tt-preview {
    max-width: 800px;
    margin: 0 auto 4rem;
    padding: 0 1.5rem;
  }
  .tt-preview-window {
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    background: var(--surface);
    box-shadow: 0 8px 30px rgba(0,0,0,0.25);
  }
  .tt-preview-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: .5rem .85rem;
    background: rgba(15,23,42,0.6);
    border-bottom: 1px solid var(--border);
  }
  .tt-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    background: rgba(100,116,139,0.3);
  }
  .tt-dot:nth-child(1) { background: rgba(239,68,68,0.6); }
  .tt-dot:nth-child(2) { background: rgba(250,204,21,0.6); }
  .tt-dot:nth-child(3) { background: rgba(34,197,94,0.6); }
  .tt-preview-title {
    margin-left: .5rem;
    font-size: .72rem;
    color: var(--muted);
    font-weight: 600;
  }
  .tt-preview-body {
    padding: 0;
  }
  .tt-preview-toolbar {
    display: flex;
    align-items: center;
    gap: .5rem;
    padding: .5rem .85rem;
    border-bottom: 1px solid var(--border);
    background: rgba(15,23,42,0.3);
  }
  .tt-tb-item {
    font-size: .7rem;
    color: var(--muted);
    padding: .15rem .4rem;
    border-radius: 4px;
    background: rgba(100,116,139,0.08);
    border: 1px solid rgba(100,116,139,0.1);
  }
  .tt-tb-sep {
    width: 1px;
    height: 14px;
    background: var(--border);
  }
  .tt-preview-page {
    padding: 2.5rem 3rem;
    min-height: 180px;
    background: rgba(253,251,248,0.03);
  }
  .tt-sample-text {
    font-family: 'Jomolhari', 'Noto Serif Tibetan', serif;
    font-size: 1.35rem;
    line-height: 2.4;
    color: var(--text);
  }
  .tt-preview-status {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: .35rem .85rem;
    border-top: 1px solid var(--border);
    font-size: .65rem;
    color: var(--muted);
    background: rgba(15,23,42,0.3);
  }

  /* ─── Features ──────────────────────────────────────────────────────────── */
  .tt-features, .tt-scripts, .tt-roadmap, .tt-final-cta {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
  }
  .tt-section-title {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--text);
    letter-spacing: -.02em;
    margin-bottom: .5rem;
  }
  .tt-section-desc {
    font-size: .95rem;
    color: var(--text2);
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 600px;
  }
  .tt-feature-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
  }
  .tt-feature {
    background: var(--surface);
    padding: 1.75rem;
  }
  .tt-feature-icon {
    font-size: 1.5rem;
    margin-bottom: .75rem;
  }
  .tt-feature h3 {
    font-size: .9rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: .5rem;
  }
  .tt-feature p {
    font-size: .82rem;
    color: var(--muted);
    line-height: 1.65;
  }

  /* ─── Scripts & Fonts ───────────────────────────────────────────────────── */
  .tt-script-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
  }
  .tt-script-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 1.75rem;
    background: var(--surface);
  }
  .tt-script-sample {
    font-family: 'Jomolhari', 'Noto Serif Tibetan', serif;
    font-size: 1.5rem;
    color: var(--text);
  }
  .tt-font-noto {
    font-family: 'Noto Sans Tibetan', sans-serif;
  }
  .tt-font-drutsa {
    font-family: 'Qomolangma-Drutsa', 'Jomolhari', serif;
  }
  .tt-script-label {
    font-size: .82rem;
    color: var(--muted);
    text-align: right;
  }

  /* ─── Roadmap & Support ──────────────────────────────────────────────────── */
  .tt-roadmap-inner {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 2rem 2.25rem;
  }
  .tt-roadmap-lead {
    font-size: .92rem;
    color: var(--text);
    line-height: 1.7;
    margin-bottom: 1rem;
  }
  .tt-roadmap-body {
    font-size: .85rem;
    color: var(--text2);
    line-height: 1.7;
    margin-bottom: 1rem;
  }
  .tt-roadmap-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1.25rem 0;
    display: flex;
    flex-direction: column;
    gap: .5rem;
  }
  .tt-roadmap-list li {
    font-size: .85rem;
    color: var(--text2);
    line-height: 1.6;
    padding-left: 1.25rem;
    position: relative;
  }
  .tt-roadmap-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: .55em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(56,189,248,0.4);
  }
  .tt-roadmap-list li strong {
    color: var(--text);
  }
  .tt-roadmap-cta {
    font-size: .85rem;
    color: var(--muted);
    line-height: 1.7;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    font-style: italic;
  }

  /* ─── Final CTA ─────────────────────────────────────────────────────────── */
  .tt-final-cta {
    text-align: center;
    padding-bottom: 5rem;
  }
  .tt-final-cta h2 {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--text);
    margin-bottom: .5rem;
  }
  .tt-final-cta p {
    font-size: .95rem;
    color: var(--text2);
    margin-bottom: 1.5rem;
  }

  /* ─── Reveal animation ──────────────────────────────────────────────────── */
  .tt-hero.reveal, .tt-preview.reveal, .tt-features.reveal,
  .tt-scripts.reveal, .tt-roadmap.reveal, .tt-final-cta.reveal {
    opacity: 0; transform: translateY(20px);
    transition: opacity .5s, transform .5s;
  }
  .tt-hero.in-view, .tt-preview.in-view, .tt-features.in-view,
  .tt-scripts.in-view, .tt-roadmap.in-view, .tt-final-cta.in-view {
    opacity: 1; transform: none;
  }

  /* ─── Responsive ────────────────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .tt-title { font-size: 2.2rem; }
    .tt-feature-grid { grid-template-columns: 1fr; }
    .tt-preview-page { padding: 1.5rem; }
    .tt-sample-text { font-size: 1.1rem; }
    .tt-script-item { flex-direction: column; align-items: flex-start; gap: .5rem; }
    .tt-script-label { text-align: left; }
    .tt-native-inner { padding: 1.75rem; }
  }
  @media (max-width: 480px) {
    .tt-hero { padding: 2.5rem 1rem 1.5rem; }
    .tt-title { font-size: 1.8rem; }
    .tt-subtitle { font-size: .95rem; }
    .tt-preview-toolbar { overflow-x: auto; }
  }
</style>

<script>
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('in-view'); });
  }, { threshold: 0.05 });
  document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
</script>
