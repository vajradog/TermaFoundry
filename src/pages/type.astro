---
import SiteLayout from '@layouts/SiteLayout.astro';

const lessons = [
  {
    id: 'alphabet', label: 'Alphabet',
    prompts: [
      'ཀ་ཁ་ག་ང་','ཅ་ཆ་ཇ་ཉ་','ཏ་ཐ་ད་ན་','པ་ཕ་བ་མ་',
      'ཙ་ཚ་ཛ་ཝ་','ཞ་ཟ་འ་ཡ་','ར་ལ་ཤ་ས་','ཧ་ཨ་',
    ],
  },
  {
    id: 'vowels', label: 'Vowels',
    prompts: [
      'ཀི་ཀུ་ཀེ་ཀོ་','གི་གུ་གེ་གོ་','ཏི་ཏུ་ཏེ་ཏོ་',
      'པི་པུ་པེ་པོ་','མི་མུ་མེ་མོ་','རི་རུ་རེ་རོ་','སི་སུ་སེ་སོ་',
    ],
  },
  {
    id: 'stacks', label: 'Stacks',
    prompts: [
      'བྲ་གྲ་ཏྲ་དྲ་པྲ་','ཀྱ་གྱ་པྱ་བྱ་མྱ་','ཀླ་གླ་བླ་སླ་',
      'རྐ་རྒ་རྔ་རྗ་རྟ་','སྐ་སྒ་སྔ་སྙ་སྟ་',
    ],
  },
  {
    id: 'words', label: 'Words',
    prompts: [
      'བོད་','བཀྲ་ཤིས་བདེ་ལེགས་','ཐུགས་རྗེ་ཆེ་','སེམས་ཅན་',
      'སངས་རྒྱས་','ཆོས་','དགེ་འདུན་','བླ་མ་','ཡེ་ཤེས་','སྙིང་རྗེ་',
    ],
  },
  {
    id: 'sentences', label: 'Sentences',
    prompts: [
      'བཀྲ་ཤིས་བདེ་ལེགས།','ཐུགས་རྗེ་ཆེ།','ཁྱེད་རང་བདེ་མོ་ཡིན་པས།',
      'ང་བོད་པ་ཡིན།','དེ་རིང་ནམ་མཁའ་སྔོན་པོ་རེད།',
    ],
  },
];
---

<SiteLayout title="Tibetan Typing Practice — Learn the Monlam Keyboard Free" description="Learn to type Tibetan with 5 structured lessons, a visual phonetic keyboard, real-time WPM and accuracy tracking. Built-in Monlam IME — no installation required.">

  <section class="type-page">

    <!-- Top bar: title + lessons + stats all compact -->
    <div class="type-topbar reveal">
      <div class="type-title-row">
        <h1 class="type-title">Tibetan Typing</h1>
        <div class="type-stats" id="type-stats">
          <span class="ts" id="stat-wpm"><b>0</b> wpm</span>
          <span class="ts" id="stat-accuracy"><b>100</b>%</span>
          <span class="ts" id="stat-streak">🔥 <b>0</b></span>
          <span class="ts ts-progress" id="stat-progress">1/8</span>
          <button class="ts-reset" id="reset-btn" title="Reset">↻</button>
        </div>
      </div>
      <div class="lesson-pills">
        {lessons.map((lesson, i) => (
          <button class={`lesson-pill ${i === 0 ? 'active' : ''}`} data-lesson={lesson.id} data-index={i}>
            {lesson.label}
          </button>
        ))}
        <button class="lesson-pill pill-free" data-lesson="free" data-index="-1">
          Free Type ✍
        </button>
      </div>
    </div>

    <!-- Typing zone: combined target + input -->
    <div class="type-zone reveal" id="type-zone">
      <div class="type-target" id="type-target">
        <span class="type-placeholder">Click here and start typing…</span>
      </div>
      <textarea id="typing-input" class="typing-input-hidden" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false"></textarea>

      <!-- Result overlay -->
      <div class="type-result hidden" id="type-result">
        <div class="type-result-inner">
          <span class="result-emoji">🎉</span>
          <span class="result-msg">Done!</span>
          <span class="result-detail" id="result-detail"></span>
          <button class="btn btn-primary btn-sm" id="next-btn">Next →</button>
        </div>
      </div>
    </div>

    <!-- Free Type zone (hidden by default) -->
    <div class="free-zone hidden reveal" id="free-zone">
      <textarea id="free-input" class="free-input" placeholder="Start typing Tibetan here…" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false"></textarea>
      <div class="free-actions">
        <button class="free-copy-btn" id="free-copy-btn" title="Copy text">📋 Copy</button>
        <button class="free-clear-btn" id="free-clear-btn" title="Clear">✕ Clear</button>
        <span class="free-charcount" id="free-charcount">0 chars</span>
      </div>
    </div>

    <!-- Hint -->
    <div class="type-hint reveal" id="type-hint">
      <span class="hint-icon">💡</span>
      <span id="hint-text">Press <kbd>k</kbd> for ཀ (ka)</span>
    </div>

    <!-- Keyboard -->
    <div class="type-keyboard reveal" id="type-keyboard"></div>

    <!-- Collapsible reference -->
    <details class="type-ref reveal">
      <summary>Quick Reference — vowels, stacking, punctuation</summary>
      <div class="ref-grid">
        <div class="ref-col">
          <h4>Vowels</h4>
          <span><kbd>i</kbd> <b class="tib">ི</b> gigu</span>
          <span><kbd>u</kbd> <b class="tib">ུ</b> zhabo</span>
          <span><kbd>e</kbd> <b class="tib">ེ</b> drenbu</span>
          <span><kbd>o</kbd> <b class="tib">ོ</b> naro</span>
        </div>
        <div class="ref-col">
          <h4>Stacking (Shift+key)</h4>
          <span><kbd>⇧R</kbd> <b class="tib">ྲ</b> sub ra</span>
          <span><kbd>⇧Y</kbd> <b class="tib">ྱ</b> sub ya</span>
          <span><kbd>⇧L</kbd> <b class="tib">ླ</b> sub la</span>
          <span><kbd>⇧V</kbd> <b class="tib">ྭ</b> sub wa</span>
        </div>
        <div class="ref-col">
          <h4>Punctuation</h4>
          <span><kbd>Space</kbd> <b class="tib">་</b> tsheg</span>
          <span><kbd>/</kbd> <b class="tib">།</b> shad</span>
          <span><kbd>-</kbd> <b class="tib">༌</b> nb-tsheg</span>
        </div>
        <div class="ref-col">
          <h4>Common Stacks</h4>
          <span><kbd>g</kbd><kbd>⇧R</kbd> <b class="tib">གྲ</b> gra</span>
          <span><kbd>b</kbd><kbd>⇧R</kbd> <b class="tib">བྲ</b> bra</span>
          <span><kbd>s</kbd><kbd>⇧K</kbd> <b class="tib">སྐ</b> ska</span>
          <span><kbd>r</kbd><kbd>⇧G</kbd> <b class="tib">རྒ</b> rga</span>
        </div>
      </div>
    </details>

  </section>

</SiteLayout>

<script define:vars={{ lessons }}>
  window.__LESSONS__ = lessons;
</script>

<script>
  // ─── IME map ───────────────────────────────────────────────────────────────
  const MAP = {
    'k':'\u0F40','[':'\u0F41','g':'\u0F42',',':'\u0F44',
    'c':'\u0F45','x':'\u0F46','j':'\u0F47','.':'\u0F49',
    't':'\u0F4F',']':'\u0F50','d':'\u0F51','n':'\u0F53',
    'p':'\u0F54','f':'\u0F55','b':'\u0F56','m':'\u0F58',
    ';':'\u0F59',':':'\u0F5A','\\':'\u0F5B','v':'\u0F5D',
    'w':'\u0F5E','z':'\u0F5F',"'":'\u0F60','y':'\u0F61',
    'r':'\u0F62','l':'\u0F63','q':'\u0F64','s':'\u0F66',
    'h':'\u0F67','a':'\u0F68',
    'i':'\u0F72','u':'\u0F74','e':'\u0F7A','o':'\u0F7C',
    ' ':'\u0F0B','/':'\u0F0D','-':'\u0F0C',
    '0':'\u0F20','1':'\u0F21','2':'\u0F22','3':'\u0F23',
    '4':'\u0F24','5':'\u0F25','6':'\u0F26','7':'\u0F27',
    '8':'\u0F28','9':'\u0F29',
    'K':'\u0F90','G':'\u0F92','C':'\u0F95','X':'\u0F96',
    'J':'\u0F97','T':'\u0F9F','D':'\u0FA1','N':'\u0FA3',
    'P':'\u0FA4','B':'\u0FA6','M':'\u0FA8','V':'\u0FAD',
    'W':'\u0FAE','Z':'\u0FAF','Y':'\u0FB1','R':'\u0FB2',
    'L':'\u0FB3','Q':'\u0FB4','S':'\u0FB6','H':'\u0FB7','A':'\u0FB8',
  };
  const REVERSE = {};
  for (const [k, v] of Object.entries(MAP)) { if (!REVERSE[v]) REVERSE[v] = k; }

  const KEY_LABELS = {
    'k':'ka','[':'kha','g':'ga',',':'nga','c':'ca','x':'cha','j':'ja','.':'nya',
    't':'ta',']':'tha','d':'da','n':'na','p':'pa','f':'pha','b':'ba','m':'ma',
    ';':'tsa',':':'tsha','\\':'dza','v':'wa','w':'zha','z':'za',"'":'a','y':'ya',
    'r':'ra','l':'la','q':'sha','s':'sa','h':'ha','a':'a',
    'i':'i (gigu)','u':'u (zhabo)','e':'e (drenbu)','o':'o (naro)',
    ' ':'tsheg','/':'shad','-':'nb-tsheg',
  };

  const PASSTHROUGH = new Set([
    'Backspace','Delete','ArrowLeft','ArrowRight','ArrowUp','ArrowDown',
    'Home','End','PageUp','PageDown','Tab','Enter','Escape',
    'F1','F2','F3','F4','F5','F6','F7','F8','F9','F10','F11','F12',
    'CapsLock','Shift','Control','Alt','Meta','AltGraph',
  ]);

  // ─── Physical keyboard layout ─────────────────────────────────────────────
  // Each row: array of { key, w? (width multiplier, default 1) }
  const KB_ROWS = [
    // Number row
    { offset: 0, keys: ['1','2','3','4','5','6','7','8','9','0','-'].map(k => ({key:k})) },
    // QWERTY row
    { offset: 0.5, keys: ['q','w','e','r','t','y','u','i','o','p','[',']'].map(k => ({key:k})) },
    // Home row
    { offset: 0.8, keys: ['a','s','d','f','g','h','j','k','l',';',"'"].map(k => ({key:k})) },
    // Bottom row — with backspace at end
    { offset: 1.3, keys: [
      ...['z','x','c','v','b','n','m',',','.','/'].map(k => ({key:k})),
      {key:'Backspace', label:'⌫', w:1.6, noTib:true},
    ]},
    // Spacebar row
    { offset: 0, isSpaceRow: true, keys: [
      {key:'shift-l', label:'⇧ Shift', w: 2.5, noTib: true, cls: 'kb-shift'},
      {key:' ', w: 7, label: 'tsheg ་'},
      {key:'shift-r', label:'⇧ Shift', w: 2.5, noTib: true, cls: 'kb-shift'},
    ]},
  ];

  // ─── State ─────────────────────────────────────────────────────────────────
  const lessons = window.__LESSONS__;
  let currentLesson = 0, currentPrompt = 0;
  let typed = '', target = '';
  let startTime = null, totalChars = 0, correctChars = 0;
  let streak = 0, bestStreak = 0, isComplete = false;
  let isFreeMode = false;

  // ─── DOM ───────────────────────────────────────────────────────────────────
  const typeZone    = document.getElementById('type-zone');
  const typeTarget  = document.getElementById('type-target');
  const typingInput = document.getElementById('typing-input');
  const hintText    = document.getElementById('hint-text');
  const resultEl    = document.getElementById('type-result');
  const resultDetail= document.getElementById('result-detail');
  const nextBtn     = document.getElementById('next-btn');
  const resetBtn    = document.getElementById('reset-btn');
  const kbEl        = document.getElementById('type-keyboard');
  const statWpm     = document.querySelector('#stat-wpm b');
  const statAcc     = document.querySelector('#stat-accuracy b');
  const statStreak  = document.querySelector('#stat-streak b');
  const statProgress= document.getElementById('stat-progress');
  const freeZone    = document.getElementById('free-zone');
  const freeInput   = document.getElementById('free-input');
  const freeCopyBtn = document.getElementById('free-copy-btn');
  const freeClearBtn= document.getElementById('free-clear-btn');
  const freeCharCnt = document.getElementById('free-charcount');
  const typeStats   = document.getElementById('type-stats');
  const typeHint    = document.getElementById('type-hint');

  // ─── Build keyboard ────────────────────────────────────────────────────────
  function buildKeyboard() {
    kbEl.innerHTML = '';
    const KW = 48; // base key width px
    const GAP = 4;

    KB_ROWS.forEach(row => {
      const rowEl = document.createElement('div');
      rowEl.className = 'kb-row';

      // Left offset for staggering
      if (row.offset && !row.isSpaceRow) {
        rowEl.style.paddingLeft = (row.offset * (KW + GAP)) + 'px';
      }
      if (row.isSpaceRow) {
        rowEl.classList.add('kb-row-space');
      }

      row.keys.forEach(kd => {
        const el = document.createElement('div');
        const w = kd.w || 1;
        el.className = 'kb-key' + (kd.cls ? ' ' + kd.cls : '');
        el.style.width = (w * KW + (w - 1) * GAP) + 'px';
        el.dataset.key = kd.key;

        if (kd.noTib) {
          el.innerHTML = `<span class="kb-label">${kd.label}</span>`;
        } else {
          const tib = MAP[kd.key] || '';
          const sub = MAP[kd.key.toUpperCase()] || '';
          const eng = kd.key === ' ' ? '' : kd.key;
          el.innerHTML =
            `<span class="kb-tib">${tib}</span>` +
            (sub && kd.key !== kd.key.toUpperCase() ? `<span class="kb-sub">⇧${sub}</span>` : '') +
            `<span class="kb-eng">${eng}</span>`;
        }
        rowEl.appendChild(el);
      });
      kbEl.appendChild(rowEl);
    });
  }
  buildKeyboard();

  // ─── Keyboard helpers ──────────────────────────────────────────────────────
  function clearKeyStates() {
    kbEl.querySelectorAll('.kb-key').forEach(k => k.classList.remove('active','hint-next'));
  }
  function hintNextKey(key) {
    if (!key) return;
    // For shift keys, highlight both shift indicators
    const isShift = key === key.toUpperCase() && key !== key.toLowerCase();
    if (isShift) {
      kbEl.querySelectorAll('.kb-shift').forEach(k => k.classList.add('hint-next'));
      const lower = kbEl.querySelector(`[data-key="${CSS.escape(key.toLowerCase())}"]`);
      if (lower) lower.classList.add('hint-next');
    } else {
      const el = kbEl.querySelector(`[data-key="${CSS.escape(key)}"]`);
      if (el) el.classList.add('hint-next');
    }
  }

  // ─── Load prompt ───────────────────────────────────────────────────────────
  function loadPrompt() {
    const lesson = lessons[currentLesson];
    if (!lesson) return;
    target = lesson.prompts[currentPrompt] || '';
    typed = ''; isComplete = false; startTime = null;
    resultEl.classList.add('hidden');
    statProgress.textContent = `${currentPrompt + 1}/${lesson.prompts.length}`;
    render();
    updateHint();
    typingInput.value = '';
    typingInput.focus();
  }

  function render() {
    const tChars = [...target];
    const uChars = [...typed];
    let html = '';
    for (let i = 0; i < tChars.length; i++) {
      let cls = 'tc';
      if (i < uChars.length) cls += uChars[i] === tChars[i] ? ' ok' : ' err';
      else if (i === uChars.length) cls += ' cur';
      html += `<span class="${cls}">${tChars[i]}</span>`;
    }
    // Cursor at end
    if (uChars.length < tChars.length) {
      // cursor is embedded in .cur class
    }
    typeTarget.innerHTML = html;
  }

  function updateHint() {
    if (isComplete || !target) { hintText.textContent = 'Done! Press Next →'; return; }
    const tChars = [...target];
    const idx = [...typed].length;
    if (idx >= tChars.length) return;
    const next = tChars[idx];
    const key = REVERSE[next];
    clearKeyStates();

    if (key) {
      const isShift = key === key.toUpperCase() && key !== key.toLowerCase();
      const label = KEY_LABELS[key.toLowerCase()] || key;
      if (isShift) {
        hintText.innerHTML = `<b class="th">${next}</b> press <kbd>Shift+${key.toLowerCase()}</kbd> <span class="hd">(subjoined ${label})</span>`;
      } else if (key === ' ') {
        hintText.innerHTML = `<b class="th">་</b> press <kbd>Space</kbd> <span class="hd">(tsheg)</span>`;
      } else if (key === '/') {
        hintText.innerHTML = `<b class="th">།</b> press <kbd>/</kbd> <span class="hd">(shad)</span>`;
      } else {
        hintText.innerHTML = `<b class="th">${next}</b> press <kbd>${key}</kbd> <span class="hd">(${label})</span>`;
      }
      hintNextKey(key);
    }
  }

  function updateStats() {
    if (startTime && correctChars > 0) {
      const mins = (Date.now() - startTime) / 60000;
      statWpm.textContent = Math.min(Math.round((correctChars / 5) / Math.max(mins, 0.01)), 999);
    }
    if (totalChars > 0) statAcc.textContent = Math.round((correctChars / totalChars) * 100);
    statStreak.textContent = streak;
  }

  // ─── Typing ────────────────────────────────────────────────────────────────
  function handleKey(ev) {
    if (isComplete) return;
    if (ev.ctrlKey || ev.metaKey || ev.altKey) return;
    if (PASSTHROUGH.has(ev.key)) {
      if (ev.key === 'Backspace') {
        ev.preventDefault();
        if (typed.length > 0) {
          typed = [...typed].slice(0, -1).join('');
          render(); updateHint();
        }
      }
      return;
    }
    const mapped = MAP[ev.key];
    if (mapped === undefined) return;
    ev.preventDefault();
    if (!startTime) startTime = Date.now();

    const tChars = [...target];
    const idx = [...typed].length;
    typed += mapped;
    totalChars++;

    if (mapped === tChars[idx]) {
      correctChars++; streak++;
      if (streak > bestStreak) bestStreak = streak;
    } else { streak = 0; }

    render(); updateStats();
    if ([...typed].length >= tChars.length) { isComplete = true; showResult(); }
    else updateHint();
  }

  function showResult() {
    const secs = startTime ? (Date.now() - startTime) / 1000 : 0;
    resultDetail.textContent = `${statWpm.textContent} wpm · ${statAcc.textContent}% · ${secs.toFixed(1)}s · streak ${bestStreak}`;
    resultEl.classList.remove('hidden');
    clearKeyStates();
    hintText.textContent = 'Nice! Press Next →';
  }

  // ─── Nav ───────────────────────────────────────────────────────────────────
  nextBtn.addEventListener('click', () => {
    const lesson = lessons[currentLesson];
    if (currentPrompt < lesson.prompts.length - 1) { currentPrompt++; }
    else if (currentLesson < lessons.length - 1) {
      currentLesson++; currentPrompt = 0;
      document.querySelectorAll('.lesson-pill').forEach(b => b.classList.remove('active'));
      document.querySelector(`[data-index="${currentLesson}"]`)?.classList.add('active');
    } else { currentPrompt = 0; }
    loadPrompt();
  });

  resetBtn.addEventListener('click', () => {
    currentPrompt = 0; totalChars = 0; correctChars = 0;
    streak = 0; bestStreak = 0;
    statWpm.textContent = '0'; statAcc.textContent = '100'; statStreak.textContent = '0';
    loadPrompt();
  });

  document.querySelectorAll('.lesson-pill').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.lesson-pill').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      if (btn.dataset.lesson === 'free') {
        enterFreeMode();
        return;
      }

      if (isFreeMode) exitFreeMode();
      currentLesson = parseInt(btn.dataset.index);
      currentPrompt = 0; totalChars = 0; correctChars = 0;
      streak = 0; bestStreak = 0;
      statWpm.textContent = '0'; statAcc.textContent = '100'; statStreak.textContent = '0';
      loadPrompt();
    });
  });

  // ─── Focus ─────────────────────────────────────────────────────────────────
  typeZone.addEventListener('click', () => typingInput.focus());
  typingInput.addEventListener('keydown', handleKey);
  typingInput.addEventListener('focus', () => typeZone.classList.add('focused'));
  typingInput.addEventListener('blur', () => typeZone.classList.remove('focused'));

  // Flash keys
  typingInput.addEventListener('keydown', (ev) => {
    if (PASSTHROUGH.has(ev.key)) {
      if (ev.key === 'Backspace') {
        const bk = kbEl.querySelector('[data-key="Backspace"]');
        if (bk) { bk.classList.add('pressed'); setTimeout(() => bk.classList.remove('pressed'), 120); }
      }
      return;
    }
    const k = ev.key.length === 1 ? ev.key.toLowerCase() : ev.key;
    const el = kbEl.querySelector(`[data-key="${CSS.escape(k)}"]`);
    if (el) { el.classList.add('pressed'); setTimeout(() => el.classList.remove('pressed'), 120); }
    // Flash shift if uppercase
    if (ev.shiftKey) {
      kbEl.querySelectorAll('.kb-shift').forEach(s => {
        s.classList.add('pressed'); setTimeout(() => s.classList.remove('pressed'), 120);
      });
    }
  });

  // ─── Shift key visual feedback (global) ─────────────────────────────────
  document.addEventListener('keydown', (ev) => {
    if (ev.key === 'Shift') {
      kbEl.querySelectorAll('.kb-shift').forEach(s => s.classList.add('pressed'));
    }
  });
  document.addEventListener('keyup', (ev) => {
    if (ev.key === 'Shift') {
      kbEl.querySelectorAll('.kb-shift').forEach(s => s.classList.remove('pressed'));
    }
  });

  // ─── Free Type mode ────────────────────────────────────────────────────────
  function freeIMEHandler(ev) {
    if (ev.ctrlKey || ev.metaKey || ev.altKey) return;
    if (PASSTHROUGH.has(ev.key)) return; // let backspace/delete/arrows work natively
    const mapped = MAP[ev.key];
    if (mapped === undefined) return;
    ev.preventDefault();
    const el = freeInput;
    const s = el.selectionStart ?? el.value.length;
    const e = el.selectionEnd ?? el.value.length;
    el.value = el.value.slice(0, s) + mapped + el.value.slice(e);
    const pos = s + mapped.length;
    el.setSelectionRange(pos, pos);
    freeCharCnt.textContent = [...el.value].length + ' chars';
  }

  function enterFreeMode() {
    isFreeMode = true;
    typeZone.classList.add('hidden');
    typeHint.classList.add('hidden');
    freeZone.classList.remove('hidden');
    typeStats.classList.add('hidden');
    clearKeyStates();
    freeInput.focus();
  }

  function exitFreeMode() {
    isFreeMode = false;
    typeZone.classList.remove('hidden');
    typeHint.classList.remove('hidden');
    freeZone.classList.add('hidden');
    typeStats.classList.remove('hidden');
  }

  freeInput.addEventListener('keydown', freeIMEHandler);
  freeInput.addEventListener('keydown', (ev) => {
    // Flash keys on keyboard for free mode too
    if (PASSTHROUGH.has(ev.key)) {
      if (ev.key === 'Backspace') {
        const bk = kbEl.querySelector('[data-key="Backspace"]');
        if (bk) { bk.classList.add('pressed'); setTimeout(() => bk.classList.remove('pressed'), 120); }
      }
      return;
    }
    const k = ev.key.length === 1 ? ev.key.toLowerCase() : ev.key;
    const el = kbEl.querySelector(`[data-key="${CSS.escape(k)}"]`);
    if (el) { el.classList.add('pressed'); setTimeout(() => el.classList.remove('pressed'), 120); }
  });
  freeInput.addEventListener('input', () => {
    freeCharCnt.textContent = [...freeInput.value].length + ' chars';
  });

  freeCopyBtn.addEventListener('click', () => {
    navigator.clipboard.writeText(freeInput.value).then(() => {
      freeCopyBtn.textContent = '✓ Copied!';
      setTimeout(() => { freeCopyBtn.textContent = '📋 Copy'; }, 1500);
    });
  });
  freeClearBtn.addEventListener('click', () => {
    freeInput.value = '';
    freeCharCnt.textContent = '0 chars';
    freeInput.focus();
  });

  // Init
  loadPrompt();

  // Reveal
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('in-view'); });
  }, { threshold: 0.05 });
  document.querySelectorAll('.type-page .reveal').forEach(el => obs.observe(el));
</script>

