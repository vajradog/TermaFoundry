---
import SiteLayout from './SiteLayout.astro';
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'The world\'s first utility-first CSS framework for Tibetan language rendering.' } = Astro.props;
const currentPath = Astro.url.pathname;
---

<SiteLayout title={title} description={description}>

  <!-- termaUI sub-nav -->
  <div class="termaui-subnav">
    <div class="termaui-subnav-inner">
      <span class="termaui-brand-tag">◈ termaUI</span>
      <div class="termaui-subnav-links">
        <a href="/termaui/" class={`termaui-subnav-link ${currentPath === '/termaui/' ? 'tsn-active' : ''}`}>Overview</a>
        <a href="/termaui/docs/" class={`termaui-subnav-link ${currentPath.startsWith('/termaui/docs') ? 'tsn-active' : ''}`}>Documentation</a>
        <a href="/termaui/playground/" class={`termaui-subnav-link ${currentPath.startsWith('/termaui/playground') ? 'tsn-active' : ''}`}>Playground</a>
        <a href="/termaui/debugger/" class={`termaui-subnav-link ${currentPath.startsWith('/termaui/debugger') ? 'tsn-active' : ''}`}>Debugger</a>
      </div>
      <a href="https://github.com/vajradog/TermaFoundry" target="_blank" rel="noopener" class="termaui-subnav-gh">GitHub ↗</a>
    </div>
  </div>

  <!-- Page content -->
  <slot />

</SiteLayout>

<script>
  // Copy buttons for termaUI code demo blocks
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const code = btn.closest('.code-block')?.querySelector('code')?.textContent || '';
      navigator.clipboard.writeText(code).then(() => {
        btn.textContent = 'Copied!';
        btn.classList.add('copied');
        setTimeout(() => { btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 2000);
      });
    });
  });
</script>

<style is:global>
  /* ── termaUI sub-nav ── */
  .termaui-subnav {
    position: sticky;
    top: 60px;
    z-index: 150;
    background: rgba(232,230,220,0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(20,20,19,0.08);
  }
  .termaui-subnav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    height: 44px;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  .termaui-brand-tag {
    font-size: .78rem;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: -.01em;
    flex-shrink: 0;
  }
  .termaui-subnav-links { display: flex; gap: .15rem; }
  .termaui-subnav-link {
    font-size: .8rem;
    font-weight: 500;
    color: var(--text2);
    padding: .25rem .65rem;
    border-radius: 5px;
    transition: color .15s, background .15s;
  }
  .termaui-subnav-link:hover { color: var(--text); background: rgba(20,20,19,0.05); }
  .termaui-subnav-link.tsn-active { color: var(--text); background: rgba(20,20,19,0.06); }
  .termaui-subnav-gh {
    margin-left: auto;
    font-size: .75rem;
    font-weight: 500;
    color: var(--muted);
    transition: color .15s;
  }
  .termaui-subnav-gh:hover { color: var(--text2); }

  /* ── termaUI page sections (wider than hub .page-section) ── */
  .section {
    max-width: 1200px; margin: 0 auto;
    padding: 5rem 2rem; position: relative;
  }

  /* ── Code blocks ── */
  .code-block {
    position: relative; background: #1e1e1e;
    border: 1px solid rgba(20,20,19,0.1);
    border-radius: 12px; overflow: hidden;
  }
  .code-block-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: .75rem 1.25rem; border-bottom: 1px solid rgba(255,255,255,0.06);
    background: rgba(0,0,0,0.15);
  }
  .code-block-title {
    font-family: 'JetBrains Mono', monospace;
    font-size: .75rem; color: #999;
  }
  .copy-btn {
    font-family: 'Inter', sans-serif; font-size: .75rem; font-weight: 500;
    color: #999; background: transparent;
    border: 1px solid rgba(255,255,255,0.12); border-radius: 5px;
    padding: .25rem .65rem; cursor: pointer; transition: all .15s;
  }
  .copy-btn:hover { color: #e0e0e0; border-color: rgba(255,255,255,0.25); }
  .copy-btn.copied { color: #d97757; border-color: rgba(217,119,87,0.3); }
  .code-block pre {
    padding: 1.25rem; font-family: 'JetBrains Mono', monospace;
    font-size: .82rem; line-height: 1.75; color: #b0b0b0;
    overflow-x: auto; background: transparent; border: none;
  }
  .code-block pre .tag { color: #e06c75; }
  .code-block pre .attr { color: #c678dd; }
  .code-block pre .str { color: #d97757; }
  .code-block pre .cmt { color: #666; }

  /* ── termaUI grid/card (slightly different from hub cards) ── */
  .grid {
    display: grid; gap: 1px; background: rgba(20,20,19,0.06);
    border-radius: 16px; overflow: hidden;
    border: 1px solid rgba(20,20,19,0.06);
  }
  .grid-2 { grid-template-columns: repeat(2,1fr); }
  .grid-3 { grid-template-columns: repeat(3,1fr); }

  @media (max-width: 900px) {
    .termaui-subnav-gh { display: none; }
  }
  @media (max-width: 768px) {
    .grid-2, .grid-3 { grid-template-columns: 1fr; }
    .section { padding: 3.5rem 1.25rem; }
  }
</style>
