{
  "name": "Terma Foundry",
  "type": "module",
  "version": "2.2.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "npm run css:dist && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "css:build": "postcss src/termaui/termaui.css -o public/dist/termaui.css --no-map",
    "css:minify": "postcss public/dist/termaui.css --use cssnano -o public/dist/termaui.min.css --no-map",
    "css:dist": "npm run css:build && npm run css:minify",
    "pkg:build": "npm run css:dist && node scripts/build-pkg.mjs",
    "pkg:copy": "node scripts/build-pkg.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.0.2",
    "@astrojs/sitemap": "^3.2.1",
    "@astrojs/tailwind": "^5.1.3",
    "@fontsource-variable/bricolage-grotesque": "^5.0.6",
    "@fontsource-variable/inter": "^5.0.18",
    "@iconify-json/bx": "^1.1.10",
    "@iconify-json/simple-icons": "^1.1.102",
    "@iconify-json/uil": "^1.1.8",
    "@tailwindcss/typography": "^0.5.13",
    "astro": "^5.0.7",
    "astro-icon": "^1.1.0",
    "astro-navbar": "^2.3.2",
    "astro-seo": "^0.8.3",
    "sharp": "^0.33.4",
    "tailwindcss": "^3.4.3"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "cssnano": "^7.1.2",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1"
  }
}
